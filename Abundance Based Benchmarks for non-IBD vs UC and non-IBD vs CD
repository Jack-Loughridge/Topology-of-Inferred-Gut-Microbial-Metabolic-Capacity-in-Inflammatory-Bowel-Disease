#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
Species-abundance baseline models for the additional pairwise binary tasks:

  1. nonIBD vs UC
  2. nonIBD vs CD

This replaces the older raw-abundance version
  abundance_baseline_models_nonibd_vs_uc_cd.py

Correct baseline structure:
  - one row per External ID
  - participant-grouped 5-fold CV
  - CLR transform applied inside each fold
  - variance filtering fitted only on training data
  - scaling fitted only on training data
  - fold-specific sample weights
  - fresh copied model per fold
  - identical splits for all models within each task

Models:
  - L1 logistic regression
  - random forest
  - XGBoost, if installed

Outputs:
  ~/Real_Data/Species_Only_Baselines_Balanced_pairwise_nonIBD_CLR/
"""

from pathlib import Path
import warnings
import copy
import numpy as np
import pandas as pd

from sklearn.model_selection import StratifiedGroupKFold
from sklearn.preprocessing import StandardScaler
from sklearn.feature_selection import VarianceThreshold
from sklearn.metrics import (
    accuracy_score,
    balanced_accuracy_score,
    f1_score,
    roc_auc_score,
    confusion_matrix,
    classification_report,
)
from sklearn.linear_model import LogisticRegression
from sklearn.ensemble import RandomForestClassifier
from sklearn.utils.class_weight import compute_sample_weight

warnings.filterwarnings("ignore")


# ============================================================
# Config
# ============================================================

BASE = Path.home() / "Real_Data"

SPECIES_FILE = BASE / "Real_Species_Abundances_canon.xlsx"
LABEL_FILE = BASE / "sample_labels.csv"
META_FILE = BASE / "hmp2_metadata.csv"

OUT_BASE = BASE / "Species_Only_Baselines_Balanced_pairwise_nonIBD_CLR"
OUT_BASE.mkdir(exist_ok=True)

RANDOM_SEED = 13
N_SPLITS = 5
EPS = 1e-6

TASKS = {
    "nonIBD_vs_UC": {
        "class_order": ["nonIBD", "UC"],
        "positive_class": "UC",
        "auc_col": "roc_auc_UC_vs_nonIBD",
    },
    "nonIBD_vs_CD": {
        "class_order": ["nonIBD", "CD"],
        "positive_class": "CD",
        "auc_col": "roc_auc_CD_vs_nonIBD",
    },
}


# ============================================================
# Helpers
# ============================================================

def find_col(df: pd.DataFrame, candidates):
    lower = {str(c).lower(): c for c in df.columns}

    for cand in candidates:
        if cand in df.columns:
            return cand
        if cand.lower() in lower:
            return lower[cand.lower()]

    return None


def normalise_label(x):
    s = str(x).strip()
    sl = s.lower()

    if sl == "cd":
        return "CD"
    if sl == "uc":
        return "UC"
    if sl in {"nonibd", "non-ibd", "non ibd", "control", "healthy"}:
        return "nonIBD"

    return None


def clr_transform(X, eps=1e-6):
    """
    Per-sample CLR transform with pseudocount.

    This is deterministic and uses only each sample's abundance vector, so it
    does not estimate cohort-level parameters. It is nevertheless applied
    inside each fold to keep the preprocessing pipeline explicit and parallel
    to the other baseline scripts.
    """
    X = np.asarray(X, dtype=np.float64)
    X = np.clip(X, 0.0, None)
    X = X + eps
    logX = np.log(X)
    return logX - logX.mean(axis=1, keepdims=True)


def safe_auc(y_true, prob_pos):
    try:
        return float(roc_auc_score(y_true, prob_pos))
    except Exception:
        return np.nan


def load_species_abundance():
    print("\nLoading species abundance file...")

    species = pd.read_excel(SPECIES_FILE, sheet_name="Sheet1")

    sample_col = find_col(species, ["External ID", "external_id", "sample_id", "Sample"])
    if sample_col is None:
        raise ValueError("Could not find sample column in species abundance file.")

    species = species.copy()
    species[sample_col] = species[sample_col].astype(str)

    feature_cols = [c for c in species.columns if c != sample_col]

    species[feature_cols] = (
        species[feature_cols]
        .apply(pd.to_numeric, errors="coerce")
        .fillna(0.0)
    )

    print("Raw species rows:", len(species))
    print("Unique External IDs:", species[sample_col].nunique())

    # One abundance row per External ID.
    species = species.groupby(sample_col, as_index=False)[feature_cols].mean()
    species = species.rename(columns={sample_col: "External ID"})

    print("After duplicate aggregation:", species.shape)

    return species, feature_cols


def load_labels():
    labels = pd.read_csv(LABEL_FILE)

    sample_col = find_col(labels, ["External ID", "external_id", "sample_id", "Sample"])
    if sample_col is None:
        sample_col = labels.columns[0]

    label_col = find_col(labels, ["label", "diagnosis", "condition"])
    if label_col is None:
        label_candidates = [c for c in labels.columns if "label" in str(c).lower() or "diagnosis" in str(c).lower()]
        if not label_candidates:
            raise ValueError(f"Could not infer label column from {labels.columns.tolist()}")
        label_col = label_candidates[0]

    labels = labels[[sample_col, label_col]].copy()
    labels.columns = ["External ID", "label"]
    labels["External ID"] = labels["External ID"].astype(str)
    labels["label"] = labels["label"].map(normalise_label)
    labels = labels.dropna(subset=["label"])
    labels = labels.drop_duplicates(subset=["External ID"])

    return labels


def load_participants():
    meta = pd.read_csv(META_FILE, low_memory=False)

    external_col = find_col(meta, ["External ID", "external_id", "sample_id", "Sample"])
    participant_col = find_col(meta, ["Participant ID", "participant_id", "Participant"])

    if external_col is None or participant_col is None:
        raise ValueError(
            "Could not find External ID / Participant ID columns in metadata.\n"
            f"Columns: {meta.columns.tolist()}"
        )

    meta = meta[[external_col, participant_col]].copy()
    meta.columns = ["External ID", "Participant ID"]
    meta["External ID"] = meta["External ID"].astype(str)
    meta["Participant ID"] = meta["Participant ID"].astype(str)
    meta = meta.drop_duplicates(subset=["External ID"])

    return meta


def build_models():
    models = {}

    models["logistic_regression_l1"] = LogisticRegression(
        penalty="l1",
        solver="saga",
        C=0.2,
        class_weight=None,  # fold-specific sample_weight is passed to fit
        max_iter=10000,
        tol=1e-4,
        random_state=RANDOM_SEED,
        n_jobs=-1,
    )

    models["random_forest"] = RandomForestClassifier(
        n_estimators=1000,
        max_depth=None,
        min_samples_leaf=3,
        max_features="sqrt",
        class_weight=None,  # fold-specific sample_weight is passed to fit
        random_state=RANDOM_SEED,
        n_jobs=-1,
    )

    try:
        from xgboost import XGBClassifier

        models["xgboost"] = XGBClassifier(
            n_estimators=700,
            max_depth=3,
            learning_rate=0.02,
            subsample=0.85,
            colsample_bytree=0.85,
            reg_lambda=2.0,
            reg_alpha=0.25,
            objective="binary:logistic",
            eval_metric="auc",
            random_state=RANDOM_SEED,
            n_jobs=-1,
            scale_pos_weight=1.0,  # overwritten per fold
        )

    except Exception as e:
        print("\n[warning] xgboost not available, skipping XGBoost.")
        print("Reason:", e)

    return models


def fit_model_with_weights(model_name, model, X_train, y_train, sample_weight):
    fitted = copy.deepcopy(model)

    if model_name == "xgboost":
        n_neg = int(np.sum(y_train == 0))
        n_pos = int(np.sum(y_train == 1))
        fitted.set_params(scale_pos_weight=n_neg / max(n_pos, 1))

        fitted.fit(
            X_train,
            y_train,
            sample_weight=sample_weight,
            verbose=False,
        )

    else:
        try:
            fitted.fit(X_train, y_train, sample_weight=sample_weight)
        except TypeError:
            fitted.fit(X_train, y_train)

    return fitted


def evaluate_model_for_task(
    task_name,
    task_df,
    feature_cols,
    model_name,
    model,
    class_order,
    positive_class,
    auc_col,
):
    print("\n" + "-" * 100)
    print(f"TASK: {task_name} | MODEL: {model_name}")
    print("-" * 100)

    out_model = OUT_BASE / task_name / model_name
    out_model.mkdir(parents=True, exist_ok=True)

    label_to_int = {c: i for i, c in enumerate(class_order)}
    int_to_label = {i: c for c, i in label_to_int.items()}
    pos_idx = label_to_int[positive_class]

    X = task_df[feature_cols].to_numpy(dtype=np.float64)
    y = task_df["label"].map(label_to_int).astype(int).to_numpy()
    groups = task_df["Participant ID"].astype(str).to_numpy()
    sample_ids = task_df["External ID"].astype(str).to_numpy()

    cv = StratifiedGroupKFold(
        n_splits=N_SPLITS,
        shuffle=True,
        random_state=RANDOM_SEED,
    )

    fold_rows = []
    pred_rows = []

    all_true = []
    all_pred = []

    for fold, (train_idx, test_idx) in enumerate(cv.split(X, y, groups), start=1):
        X_train_raw = X[train_idx]
        X_test_raw = X[test_idx]
        y_train = y[train_idx]
        y_test = y[test_idx]

        # ----------------------------------------------------
        # Fold-internal preprocessing
        # ----------------------------------------------------

        X_train_clr = clr_transform(X_train_raw, EPS)
        X_test_clr = clr_transform(X_test_raw, EPS)

        selector = VarianceThreshold(threshold=1e-10)
        X_train_sel = selector.fit_transform(X_train_clr)
        X_test_sel = selector.transform(X_test_clr)

        scaler = StandardScaler()
        X_train_proc = scaler.fit_transform(X_train_sel)
        X_test_proc = scaler.transform(X_test_sel)

        # ----------------------------------------------------
        # Fold-specific sample weights
        # ----------------------------------------------------

        sample_weight = compute_sample_weight(
            class_weight="balanced",
            y=y_train,
        )

        fitted = fit_model_with_weights(
            model_name=model_name,
            model=model,
            X_train=X_train_proc,
            y_train=y_train,
            sample_weight=sample_weight,
        )

        if hasattr(fitted, "predict_proba"):
            prob = fitted.predict_proba(X_test_proc)

            # Defensive check: class order should be [0, 1] for all models here.
            if prob.shape[1] != 2:
                raise RuntimeError(f"Expected binary predict_proba output, got shape {prob.shape}")

            prob_pos = prob[:, pos_idx]
        else:
            score = fitted.decision_function(X_test_proc)
            prob_pos = 1.0 / (1.0 + np.exp(-score))

        pred = (prob_pos >= 0.5).astype(int)

        acc = accuracy_score(y_test, pred)
        bal_acc = balanced_accuracy_score(y_test, pred)
        macro_f1 = f1_score(y_test, pred, average="macro", zero_division=0)
        auc = safe_auc((y_test == pos_idx).astype(int), prob_pos)

        fold_rows.append({
            "task": task_name,
            "model": model_name,
            "fold": fold,
            "n_train": int(len(train_idx)),
            "n_test": int(len(test_idx)),
            "n_train_participants": int(len(np.unique(groups[train_idx]))),
            "n_test_participants": int(len(np.unique(groups[test_idx]))),
            "accuracy": float(acc),
            "balanced_accuracy": float(bal_acc),
            "macro_f1": float(macro_f1),
            auc_col: float(auc) if np.isfinite(auc) else np.nan,
        })

        for i, sid in enumerate(sample_ids[test_idx]):
            pred_rows.append({
                "task": task_name,
                "model": model_name,
                "fold": fold,
                "sample_id": sid,
                "true_label": int_to_label[int(y_test[i])],
                "pred_label": int_to_label[int(pred[i])],
                f"prob_{positive_class}": float(prob_pos[i]),
            })

        all_true.extend(y_test.tolist())
        all_pred.extend(pred.tolist())

        print(
            f"[{task_name} | {model_name} | fold {fold}] "
            f"acc={acc:.4f}, bal_acc={bal_acc:.4f}, "
            f"macro_f1={macro_f1:.4f}, auc={auc:.4f}"
        )

    cv_df = pd.DataFrame(fold_rows)
    pred_df = pd.DataFrame(pred_rows)

    cm = confusion_matrix(
        all_true,
        all_pred,
        labels=np.arange(len(class_order)),
    )

    cm_df = pd.DataFrame(
        cm,
        index=[f"true_{c}" for c in class_order],
        columns=[f"pred_{c}" for c in class_order],
    )

    report_df = pd.DataFrame(
        classification_report(
            all_true,
            all_pred,
            target_names=class_order,
            output_dict=True,
            zero_division=0,
        )
    ).T

    cv_df.to_csv(out_model / "cv_results.csv", index=False)
    pred_df.to_csv(out_model / "predictions.csv", index=False)
    cm_df.to_csv(out_model / "confusion_matrix.csv")
    report_df.to_csv(out_model / "classification_report.csv")

    print("\nCV results:")
    print(cv_df.to_string(index=False))

    print("\nConfusion matrix:")
    print(cm_df)

    return cv_df, pred_df, cm_df


def run_task(task_name, cfg, merged, feature_cols):
    class_order = cfg["class_order"]
    positive_class = cfg["positive_class"]
    auc_col = cfg["auc_col"]

    out_task = OUT_BASE / task_name
    out_task.mkdir(parents=True, exist_ok=True)

    print("\n" + "=" * 100)
    print("TASK:", task_name)
    print("Classes:", class_order)
    print("Positive class:", positive_class)
    print("=" * 100)

    task_df = merged[merged["label"].isin(class_order)].copy()

    task_df["label"] = pd.Categorical(
        task_df["label"],
        categories=class_order,
        ordered=True,
    )

    task_df = task_df.sort_values(["label", "External ID"]).reset_index(drop=True)

    print("Samples:", len(task_df))
    print("Participants:", task_df["Participant ID"].nunique())
    print("Class counts:")
    print(task_df["label"].value_counts().to_string())

    # Defensive check: participant should not have conflicting labels in the same task.
    participant_label_counts = task_df.groupby("Participant ID")["label"].nunique()
    mixed = participant_label_counts[participant_label_counts > 1]

    if len(mixed) > 0:
        raise RuntimeError(
            f"{len(mixed)} participants have multiple labels within task {task_name}. "
            "This would make participant-grouped classification ambiguous."
        )

    models = build_models()

    all_cv = []

    for model_name, model in models.items():
        cv_df, _pred_df, _cm_df = evaluate_model_for_task(
            task_name=task_name,
            task_df=task_df,
            feature_cols=feature_cols,
            model_name=model_name,
            model=model,
            class_order=class_order,
            positive_class=positive_class,
            auc_col=auc_col,
        )
        all_cv.append(cv_df)

    all_cv = pd.concat(all_cv, ignore_index=True)
    all_cv.to_csv(out_task / "all_model_cv_results.csv", index=False)

    metric_cols = ["accuracy", "balanced_accuracy", "macro_f1", auc_col]

    summary = (
        all_cv
        .groupby(["task", "model"])
        .agg(
            accuracy_mean=("accuracy", "mean"),
            accuracy_std=("accuracy", "std"),
            balanced_accuracy_mean=("balanced_accuracy", "mean"),
            balanced_accuracy_std=("balanced_accuracy", "std"),
            macro_f1_mean=("macro_f1", "mean"),
            macro_f1_std=("macro_f1", "std"),
            auc_mean=(auc_col, "mean"),
            auc_std=(auc_col, "std"),
        )
        .reset_index()
        .sort_values(["balanced_accuracy_mean", "auc_mean"], ascending=False)
    )

    summary.to_csv(out_task / "model_summary.csv", index=False)

    print("\n" + "=" * 100)
    print("FINAL MODEL SUMMARY:", task_name)
    print("=" * 100)
    print(summary.to_string(index=False))

    return summary


def main():
    species, feature_cols = load_species_abundance()
    labels = load_labels()
    meta = load_participants()

    merged = species.merge(labels, on="External ID", how="inner")
    merged = merged.merge(meta, on="External ID", how="left")
    merged = merged.dropna(subset=["Participant ID"]).copy()

    print("\nMerged shape:", merged.shape)
    print("Unique samples:", merged["External ID"].nunique())
    print("Participants:", merged["Participant ID"].nunique())
    print("Class counts:")
    print(merged["label"].value_counts().to_string())

    all_summaries = []

    for task_name, cfg in TASKS.items():
        all_summaries.append(run_task(task_name, cfg, merged, feature_cols))

    final = pd.concat(all_summaries, ignore_index=True)
    final.to_csv(OUT_BASE / "all_model_summaries.csv", index=False)

    print("\n" + "=" * 100)
    print("ALL FINAL MODEL SUMMARIES")
    print("=" * 100)
    print(final.to_string(index=False))

    print("\nSaved all outputs under:")
    print(OUT_BASE)


if __name__ == "__main__":
    main()
