def build_tasks(args) -> List[Dict[str, Any]]:
    base = Path(args.base).expanduser()
    graph_dir = Path(args.graph_dir).expanduser()
    meta_path = Path(args.meta).expanduser()
    out_dir = Path(args.out_dir).expanduser()
    sample_dir = out_dir / "sample_results"
    sample_dir.mkdir(parents=True, exist_ok=True)

    meta = pd.read_csv(meta_path, low_memory=False)
    meta = meta[["External ID", "diagnosis", "Participant ID"]].copy()
    meta.columns = ["sample_id", "diagnosis", "participant_id"]
    meta["cond"] = meta["diagnosis"].apply(norm_cond)
    meta = meta[meta["cond"].isin(["cd", "uc", "nonibd"])].copy()
    meta = meta.drop_duplicates(subset=["sample_id"]).copy()

    graph_files = {p.stem: p for p in graph_dir.glob("*.graphml")}
    meta = meta[meta["sample_id"].isin(graph_files)].copy()

    if args.max_samples is not None:
        meta = meta.head(int(args.max_samples)).copy()

    tasks = []

    for _, row in meta.iterrows():
        sid = str(row["sample_id"])
        result_path = sample_dir / f"{safe_stem(sid)}.json"

        if args.resume and result_path.exists() and result_path.stat().st_size > 0:
            continue

        tasks.append({
            "sample_id": sid,
            "participant_id": str(row["participant_id"]),
            "cond": str(row["cond"]),
            "graph_path": str(graph_files[sid]),
            "n_source": int(args.n_source),
            "n_target": int(args.n_target),
            "long_min_hop": int(args.long_min_hop),
            "active_tol": float(args.active_tol),
            "seed": stable_seed(int(args.seed), sid),
            "quantiles": list(args.quantiles),
            "result_path": str(result_path),
        })

    print("Metadata samples matched to graphs:", len(meta))
    print("Participants:", meta["participant_id"].nunique())
    print("Condition counts:")
    print(meta["cond"].value_counts().to_string())
    print("Samples still to process:", len(tasks))

    return tasks


def main() -> None:
    parser = argparse.ArgumentParser()
    parser.add_argument("--base", default=str(Path.home() / "Real_Data"))
    parser.add_argument("--graph-dir", default=str(Path.home() / "Real_Data" / "out_graphs"))
    parser.add_argument("--meta", default=str(Path.home() / "Real_Data" / "hmp2_metadata.csv"))
    parser.add_argument("--out-dir", default=str(Path.home() / "Real_Data" / "Path_Backbone_LongRange_Diagnostics"))
    parser.add_argument("--n-source", type=int, default=100)
    parser.add_argument("--n-target", type=int, default=100)
    parser.add_argument("--long-min-hop", type=int, default=4)
    parser.add_argument("--active-tol", type=float, default=1e-12)
    parser.add_argument("--seed", type=int, default=20260707)
    parser.add_argument("--workers", type=int, default=4)
    parser.add_argument("--max-samples", type=int, default=None)
    parser.add_argument("--no-resume", action="store_true")
    parser.add_argument("--quantiles", type=int, nargs="+", default=DEFAULT_QUANTILES)
    parser.add_argument("--write-only", action="store_true", help="Only aggregate existing sample JSON files.")
    args = parser.parse_args()

    args.resume = not args.no_resume

    out_dir = Path(args.out_dir).expanduser()
    out_dir.mkdir(parents=True, exist_ok=True)
    sample_dir = out_dir / "sample_results"
    sample_dir.mkdir(parents=True, exist_ok=True)

    config = {
        "graph_dir": str(Path(args.graph_dir).expanduser()),
        "meta": str(Path(args.meta).expanduser()),
        "out_dir": str(out_dir),
        "n_source": args.n_source,
        "n_target": args.n_target,
        "long_min_hop": args.long_min_hop,
        "active_tol": args.active_tol,
        "seed": args.seed,
        "workers": args.workers,
        "quantiles": args.quantiles,
        "protocol": "sample graph diagnostics -> participant averaging -> condition summary",
        "long_range_definition": f"minimum-hop distance >= {args.long_min_hop}",
        "active_edge_definition": f"w < 1 - {args.active_tol}",
    }
    (out_dir / "run_config.json").write_text(json.dumps(config, indent=2))

    print("=" * 100)
    print("Long-range path-backbone diagnostics")
    print("=" * 100)
    print(json.dumps(config, indent=2))

    if args.write_only:
        write_outputs(out_dir, args.quantiles, args.long_min_hop)
        return

    tasks = build_tasks(args)

    if tasks:
        t0 = time.time()
        done = 0
        errors = 0

        with ProcessPoolExecutor(max_workers=int(args.workers)) as ex:
            futures = {ex.submit(worker, t): t for t in tasks}

            for fut in as_completed(futures):
                task = futures[fut]
                sid = task["sample_id"]
                result_path = Path(task["result_path"])

                try:
                    obj = fut.result()
                except Exception:
                    obj = {
                        "sample_id": sid,
                        "path_rows": [],
                        "edge_rows": [],
                        "error": traceback.format_exc(),
                    }

                if obj.get("error"):
                    errors += 1

                atomic_write_json(result_path, obj)

                done += 1
                if done == 1 or done % 10 == 0 or done == len(tasks):
                    elapsed = time.time() - t0
                    rate = done / elapsed if elapsed > 0 else float("nan")
                    remaining = len(tasks) - done
                    eta = remaining / rate if rate > 0 else float("nan")
                    print(
                        f"[progress] {done}/{len(tasks)} processed | errors={errors} | "
                        f"rate={rate:.3f} samples/s | ETA={eta/3600:.2f} h | latest={sid}",
                        flush=True,
                    )

    print("\nAggregating outputs...")
    write_outputs(out_dir, args.quantiles, args.long_min_hop)

    failed = out_dir / "path_backbone_failed_samples.csv"
    if failed.exists():
        try:
            fdf = pd.read_csv(failed)
            if len(fdf):
                print("\n[WARNING] Some samples failed. See:")
                print(" ", failed)
            else:
                print("\n[READY] No failed samples recorded.")
        except Exception:
            pass

    print("\n[READY] Path-backbone diagnostics finished.")


if __name__ == "__main__":
    main()
