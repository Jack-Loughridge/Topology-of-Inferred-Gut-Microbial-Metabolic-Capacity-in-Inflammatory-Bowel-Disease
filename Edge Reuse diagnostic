# Aggregation and summaries
# -----------------------------

def load_all_sample_json(sample_dir: Path) -> Tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    path_rows = []
    edge_rows = []
    error_rows = []

    for p in sorted(sample_dir.glob("*.json")):
        try:
            obj = json.loads(p.read_text())
        except Exception as e:
            error_rows.append({"file": str(p), "sample_id": p.stem, "error": f"Could not read JSON: {e}"})
            continue

        if obj.get("error"):
            error_rows.append({"file": str(p), "sample_id": obj.get("sample_id"), "error": obj.get("error")})
            continue

        path_rows.extend(obj.get("path_rows", []))
        edge_rows.extend(obj.get("edge_rows", []))

    return pd.DataFrame(path_rows), pd.DataFrame(edge_rows), pd.DataFrame(error_rows)


def participant_average(df: pd.DataFrame) -> pd.DataFrame:
    if df.empty:
        return df.copy()

    id_cols = ["participant_id", "mode", "path_set"]
    meta_cols = ["cond"]

    numeric_cols = [
        c for c in df.columns
        if c not in set(id_cols + meta_cols + ["sample_id"])
        and pd.api.types.is_numeric_dtype(df[c])
    ]

    grouped_rows = []

    for keys, sub in df.groupby(id_cols, dropna=False):
        row = dict(zip(id_cols, keys))
        row["cond"] = sub["cond"].astype(str).value_counts().idxmax()
        row["n_samples_for_participant"] = int(sub["sample_id"].nunique()) if "sample_id" in sub.columns else int(len(sub))

        for c in numeric_cols:
            vals = pd.to_numeric(sub[c], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
            row[c] = float(vals.mean()) if len(vals) else np.nan

        grouped_rows.append(row)

    return pd.DataFrame(grouped_rows)


def condition_summary(sample_df: pd.DataFrame, participant_df: pd.DataFrame) -> pd.DataFrame:
    rows = []

    def add_rows(level_name: str, df: pd.DataFrame):
        if df.empty:
            return

        numeric_cols = [
            c for c in df.columns
            if pd.api.types.is_numeric_dtype(df[c])
            and c not in {
                "n_source_requested",
                "n_target_requested_per_source",
                "long_min_hop",
            }
        ]

        for mode in sorted(df["mode"].dropna().unique()):
            for path_set in sorted(df["path_set"].dropna().unique()):
                base_sub = df[(df["mode"] == mode) & (df["path_set"] == path_set)]

                for cond in ["overall", "cd", "uc", "nonibd"]:
                    sub = base_sub if cond == "overall" else base_sub[base_sub["cond"] == cond]
                    if len(sub) == 0:
                        continue

                    row = {
                        "level": level_name,
                        "mode": mode,
                        "path_set": path_set,
                        "cond": cond,
                        "n": int(len(sub)),
                    }

                    for c in numeric_cols:
                        vals = pd.to_numeric(sub[c], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
                        row[f"{c}_mean"] = float(vals.mean()) if len(vals) else np.nan
                        row[f"{c}_sd"] = float(vals.std(ddof=0)) if len(vals) else np.nan

                    rows.append(row)

    add_rows("sample graphwise", sample_df)
    add_rows("participant average", participant_df)

    return pd.DataFrame(rows)


def fmt_mean_sd(row: pd.Series, col: str, digits: int = 3) -> str:
    m = row.get(f"{col}_mean", np.nan)
    s = row.get(f"{col}_sd", np.nan)

    try:
        m = float(m)
        s = float(s)
    except Exception:
        return "--"

    if not math.isfinite(m):
        return "--"
    if not math.isfinite(s):
        return f"{m:.{digits}f}"
    return f"{m:.{digits}f} $\\pm$ {s:.{digits}f}"


def latex_quantile_table(
    summary: pd.DataFrame,
    metric: str,
    path_set: str,
    out_path: Path,
    caption: str,
    label: str,
    quantiles: List[int],
) -> None:
    sub = summary[summary["path_set"] == path_set].copy()
    sub = sub[sub["mode"].isin(["minimum_hop", "minimax"])].copy()

    lines = []
    lines.append(r"\begin{table}[ht]")
    lines.append(r"\centering")
    lines.append(caption)
    lines.append(label)
    lines.append(r"\resizebox{\textwidth}{!}{%")
    lines.append(r"\begin{tabular}{lll" + "r" * (1 + len(quantiles)) + r"}")
    lines.append(r"\toprule")
    header = "Level & Path type & Condition & $n$ & " + " & ".join([f"q{q}" for q in quantiles]) + r" \\"
    lines.append(header)
    lines.append(r"\midrule")

    level_order = {"sample graphwise": 0, "participant average": 1}
    mode_order = {"minimum_hop": 0, "minimax": 1}
    cond_order = {"overall": 0, "cd": 1, "uc": 2, "nonibd": 3}

    sub["_level_order"] = sub["level"].map(level_order)
    sub["_mode_order"] = sub["mode"].map(mode_order)
    sub["_cond_order"] = sub["cond"].map(cond_order)
    sub = sub.sort_values(["_level_order", "_mode_order", "_cond_order"])

    for _, r in sub.iterrows():
        mode_disp = "minimum-hop" if r["mode"] == "minimum_hop" else "minimax"
        vals = [fmt_mean_sd(r, f"{metric}_q{q}") for q in quantiles]
        line = (
            f"{r['level']} & {mode_disp} & {display_cond(r['cond'])} & {int(r['n'])} & "
            + " & ".join(vals)
            + r" \\"
        )
        lines.append(line)

    lines.append(r"\bottomrule")
    lines.append(r"\end{tabular}%")
    lines.append(r"}")
    lines.append(r"\end{table}")
    out_path.write_text("\n".join(lines) + "\n")


