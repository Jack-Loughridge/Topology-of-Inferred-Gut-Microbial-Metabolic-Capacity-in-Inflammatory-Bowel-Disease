def write_outputs(out_dir: Path, quantiles: List[int], long_min_hop: int) -> None:
    sample_dir = out_dir / "sample_results"
    path_df, edge_df, errors_df = load_all_sample_json(sample_dir)

    path_sample_csv = out_dir / "path_backbone_sample_path_quantiles.csv"
    edge_sample_csv = out_dir / "path_backbone_sample_edge_concentration.csv"
    path_part_csv = out_dir / "path_backbone_participant_path_quantiles.csv"
    edge_part_csv = out_dir / "path_backbone_participant_edge_concentration.csv"
    path_summary_csv = out_dir / "path_backbone_condition_path_summary.csv"
    edge_summary_csv = out_dir / "path_backbone_condition_edge_summary.csv"
    errors_csv = out_dir / "path_backbone_failed_samples.csv"

    path_df.to_csv(path_sample_csv, index=False)
    edge_df.to_csv(edge_sample_csv, index=False)
    errors_df.to_csv(errors_csv, index=False)

    path_part = participant_average(path_df)
    edge_part = participant_average(edge_df)

    path_part.to_csv(path_part_csv, index=False)
    edge_part.to_csv(edge_part_csv, index=False)

    path_summary = condition_summary(path_df, path_part)
    edge_summary = condition_summary(edge_df, edge_part)

    path_summary.to_csv(path_summary_csv, index=False)
    edge_summary.to_csv(edge_summary_csv, index=False)

    long_set = f"long_hop_ge{long_min_hop}"

    latex_quantile_table(
        path_summary,
        metric="path_length",
        path_set=long_set,
        out_path=out_dir / "latex_long_range_path_length_quantiles.tex",
        caption=(
            r"\caption{Long-range directed path-length quantiles. Long-range paths are defined as sampled source--target pairs with minimum-hop distance at least "
            + str(long_min_hop)
            + r". Sample-level rows are computed on individual sample graphs. Participant-average rows are obtained by averaging sample-level quantiles within participant. Values are mean $\pm$ SD.}"
        ),
        label=r"\label{tab:long_range_path_length_quantiles}",
        quantiles=quantiles,
    )

    latex_quantile_table(
        path_summary,
        metric="bottleneck_w",
        path_set=long_set,
        out_path=out_dir / "latex_long_range_bottleneck_weight_quantiles.tex",
        caption=(
            r"\caption{Long-range directed path bottleneck-weight quantiles. The bottleneck weight of a path is $\max_{e\in p} w(e)$, the weakest-supported edge along the path. Lower values indicate that even the weakest edge on the path has stronger inferred microbial support. Values are mean $\pm$ SD.}"
        ),
        label=r"\label{tab:long_range_bottleneck_weight_quantiles}",
        quantiles=quantiles,
    )

    latex_quantile_table(
        path_summary,
        metric="min_support",
        path_set=long_set,
        out_path=out_dir / "latex_long_range_minimum_support_quantiles.tex",
        caption=(
            r"\caption{Long-range directed path minimum-support quantiles. Minimum support is defined as $1-\max_{e\in p} w(e)$, so larger values indicate that the whole path avoids weakly supported transitions. Values are mean $\pm$ SD.}"
        ),
        label=r"\label{tab:long_range_minimum_support_quantiles}",
        quantiles=quantiles,
    )

    latex_quantile_table(
        path_summary,
        metric="mean_w2",
        path_set=long_set,
        out_path=out_dir / "latex_long_range_mean_w2_quantiles.tex",
        caption=(
            r"\caption{Long-range directed path mean-$w^2$ quantiles. For each sampled path, mean $w^2$ is computed across the directed edges in the selected path. Values are mean $\pm$ SD.}"
        ),
        label=r"\label{tab:long_range_mean_w2_quantiles}",
        quantiles=quantiles,
    )

    latex_edge_concentration_table(
        edge_summary,
        path_set=long_set,
        out_path=out_dir / "latex_long_range_edge_concentration.tex",
    )

    print("\nWrote main outputs:")
    for p in [
        path_sample_csv,
        edge_sample_csv,
        path_part_csv,
        edge_part_csv,
        path_summary_csv,
        edge_summary_csv,
        errors_csv,
        out_dir / "latex_long_range_path_length_quantiles.tex",
        out_dir / "latex_long_range_bottleneck_weight_quantiles.tex",
        out_dir / "latex_long_range_minimum_support_quantiles.tex",
        out_dir / "latex_long_range_mean_w2_quantiles.tex",
        out_dir / "latex_long_range_edge_concentration.tex",
    ]:
        print(" ", p)

    print("\nRows:")
    print("  sample path rows:", len(path_df))
    print("  sample edge rows:", len(edge_df))
    print("  participant path rows:", len(path_part))
    print("  participant edge rows:", len(edge_part))
    print("  failed sample rows:", len(errors_df))


