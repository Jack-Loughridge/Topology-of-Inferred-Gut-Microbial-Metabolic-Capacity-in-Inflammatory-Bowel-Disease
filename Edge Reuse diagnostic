DEFAULT_QUANTILES = [1, 5, 10, 20, 30, 50, 70, 80, 90, 95, 99]
TOP_EDGE_FRACTIONS = [0.01, 0.05, 0.10]
WEIGHT_KEY_CANDIDATES = {"weight", "d1", "Weight", "D1"}


# -----------------------------
# Small helpers
# -----------------------------

def norm_cond(x: Any) -> str:
    s = str(x).strip().lower()
    if "crohn" in s or s == "cd":
        return "cd"
    if "ulcerative" in s or s == "uc":
        return "uc"
    if "non" in s:
        return "nonibd"
    return s


def display_cond(c: str) -> str:
    return {"cd": "CD", "uc": "UC", "nonibd": "non-IBD", "overall": "overall"}.get(c, c)


def safe_stem(s: str) -> str:
    return re.sub(r"[^A-Za-z0-9_.-]+", "_", str(s))


def stable_seed(global_seed: int, sample_id: str) -> int:
    h = hashlib.sha256(f"{global_seed}::{sample_id}".encode("utf-8")).hexdigest()
    return int(h[:16], 16) % (2**32)


def finite_float(x: Any) -> Optional[float]:
    try:
        y = float(x)
    except Exception:
        return None
    if math.isfinite(y):
        return y
    return None


def atomic_write_json(path: Path, obj: Any) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    with tempfile.NamedTemporaryFile("w", delete=False, dir=str(path.parent), suffix=".tmp") as f:
        json.dump(obj, f)
        tmp = Path(f.name)
    tmp.replace(path)


def quantile_dict(values: List[float], prefix: str, qs: List[int]) -> Dict[str, float]:
    if len(values) == 0:
        return {f"{prefix}_q{q}": np.nan for q in qs}

    arr = np.asarray(values, dtype=float)
    arr = arr[np.isfinite(arr)]

    if len(arr) == 0:
        return {f"{prefix}_q{q}": np.nan for q in qs}

    out = {}
    for q in qs:
        out[f"{prefix}_q{q}"] = float(np.percentile(arr, q))
    return out


def mean_or_nan(values: List[float]) -> float:
    arr = np.asarray(values, dtype=float)
    arr = arr[np.isfinite(arr)]
    if len(arr) == 0:
        return np.nan
    return float(np.mean(arr))


def std_or_nan(values: List[float]) -> float:
    arr = np.asarray(values, dtype=float)
    arr = arr[np.isfinite(arr)]
    if len(arr) == 0:
        return np.nan
    return float(np.std(arr, ddof=0))


# -----------------------------
# GraphML parsing
# -----------------------------

def parse_graphml_active_digraph(
    path: Path,
    active_tol: float,
) -> Tuple[List[str], Dict[str, List[str]], Dict[Tuple[str, str], float]]:
    """
    Parse one GraphML file into an active directed adjacency list.

    Active edge criterion:
      w < 1 - active_tol

    Duplicate directed edges, if any, are collapsed by retaining the smaller w,
    i.e. the stronger inferred support.
    """
    key_id_to_name: Dict[str, str] = {}
    weight_key_ids = set(WEIGHT_KEY_CANDIDATES)

    nodes = set()
    edge_min_w: Dict[Tuple[str, str], float] = {}

    for _, elem in ET.iterparse(path, events=("end",)):
        tag = elem.tag.rsplit("}", 1)[-1]

        if tag == "key":
            kid = elem.attrib.get("id")
            attr_name = elem.attrib.get("attr.name")
            if kid is not None and attr_name is not None:
                key_id_to_name[kid] = attr_name
                if kid in WEIGHT_KEY_CANDIDATES or attr_name in WEIGHT_KEY_CANDIDATES:
                    weight_key_ids.add(kid)
            elem.clear()

        elif tag == "node":
            nid = elem.attrib.get("id")
            if nid is not None:
                nodes.add(nid)
            elem.clear()

        elif tag == "edge":
            u = elem.attrib.get("source")
            v = elem.attrib.get("target")
            if u is not None:
                nodes.add(u)
            if v is not None:
                nodes.add(v)

            w = None
            for child in elem:
                ctag = child.tag.rsplit("}", 1)[-1]
                if ctag != "data":
                    continue

                k = child.attrib.get("key")
                k_name = key_id_to_name.get(k, k)

                if k in weight_key_ids or k_name in WEIGHT_KEY_CANDIDATES:
                    w = finite_float(child.text)
                    break

            if u is not None and v is not None and w is not None:
                if w < 1.0 - active_tol:
                    e = (u, v)
                    if e not in edge_min_w or w < edge_min_w[e]:
                        edge_min_w[e] = float(w)

            elem.clear()

    active_nodes = set()
    for u, v in edge_min_w:
        active_nodes.add(u)
        active_nodes.add(v)

    adjacency: Dict[str, List[str]] = {n: [] for n in active_nodes}
    for u, v in edge_min_w:
        adjacency.setdefault(u, []).append(v)
        adjacency.setdefault(v, adjacency.get(v, []))

    for u in adjacency:
        adjacency[u].sort()

    return sorted(active_nodes), adjacency, edge_min_w


# -----------------------------
# Shortest path routines
# -----------------------------

def bfs_paths_from_source(
    adjacency: Dict[str, List[str]],
    source: str,
) -> Dict[str, List[str]]:
    """
    Single-source unweighted directed shortest paths by BFS.
    Returns one shortest path to each reachable vertex.
    """
    pred: Dict[str, Optional[str]] = {source: None}
    q = deque([source])

    while q:
        u = q.popleft()
        for v in adjacency.get(u, []):
            if v not in pred:
                pred[v] = u
                q.append(v)

    paths: Dict[str, List[str]] = {}

    for target in pred:
        if target == source:
            continue
        rev = [target]
        cur = target
        while pred[cur] is not None:
            cur = pred[cur]
            rev.append(cur)
        paths[target] = list(reversed(rev))

    return paths


def minimax_paths_from_source(
    adjacency: Dict[str, List[str]],
    edge_w: Dict[Tuple[str, str], float],
    source: str,
    targets: set,
) -> Dict[str, List[str]]:
    """
    Single-source minimax paths with path-length tie-breaking.

    Cost is lexicographic:
      (max edge weight along path, number of edges)

    Stops once all requested targets are settled.
    """
    if not targets:
        return {}

    dist: Dict[str, Tuple[float, int]] = {source: (0.0, 0)}
    pred: Dict[str, Optional[str]] = {source: None}
    heap: List[Tuple[float, int, str]] = [(0.0, 0, source)]
    settled = set()
    remaining = set(targets)

    while heap and remaining:
        bottleneck, length, u = heapq.heappop(heap)

        if u in settled:
            continue

        current = dist.get(u)
        if current is None or current != (bottleneck, length):
            continue

        settled.add(u)

        if u in remaining:
            remaining.remove(u)

        for v in adjacency.get(u, []):
            w = edge_w[(u, v)]
            nb = max(bottleneck, w)
            nl = length + 1
            old = dist.get(v)

            if old is None or (nb, nl) < old:
                dist[v] = (nb, nl)
                pred[v] = u
                heapq.heappush(heap, (nb, nl, v))

    paths: Dict[str, List[str]] = {}

    for target in targets:
        if target not in pred:
            continue

        rev = [target]
        cur = target

        while pred[cur] is not None:
            cur = pred[cur]
            rev.append(cur)

        paths[target] = list(reversed(rev))

    return paths


def path_metrics(path: List[str], edge_w: Dict[Tuple[str, str], float]) -> Dict[str, float]:
    weights = [edge_w[(path[i], path[i + 1])] for i in range(len(path) - 1)]
    if not weights:
        return {
            "path_length": np.nan,
            "bottleneck_w": np.nan,
            "min_support": np.nan,
            "mean_w2": np.nan,
        }

    b = max(weights)
    return {
        "path_length": float(len(weights)),
        "bottleneck_w": float(b),
        "min_support": float(1.0 - b),
        "mean_w2": float(np.mean(np.asarray(weights, dtype=float) ** 2)),
    }


def add_path_edges(counter: Counter, path: List[str]) -> None:
    for i in range(len(path) - 1):
        counter[(path[i], path[i + 1])] += 1


# -----------------------------
# Per-sample diagnostics
# -----------------------------

def summarise_paths(
    metrics: List[Dict[str, float]],
    base: Dict[str, Any],
    quantiles: List[int],
) -> Dict[str, Any]:
    row = dict(base)
    row["n_paths"] = int(len(metrics))

    for metric_name in ["path_length", "bottleneck_w", "min_support", "mean_w2"]:
        vals = [m[metric_name] for m in metrics if math.isfinite(float(m[metric_name]))]
        row[f"{metric_name}_mean"] = mean_or_nan(vals)
        row[f"{metric_name}_sd"] = std_or_nan(vals)
        row.update(quantile_dict(vals, metric_name, quantiles))

    return row


def summarise_edge_concentration(
    counter: Counter,
    edge_w: Dict[Tuple[str, str], float],
    base: Dict[str, Any],
) -> Dict[str, Any]:
    row = dict(base)

    active_edges = list(edge_w.keys())
    n_active_edges = len(active_edges)
    total_traversals = int(sum(counter.values()))
    used_edges = [e for e, c in counter.items() if c > 0]

    row["total_edge_traversals"] = total_traversals
    row["unique_edges_used"] = int(len(used_edges))
    row["unique_edges_used_fraction_of_active"] = (
        float(len(used_edges) / n_active_edges) if n_active_edges > 0 else np.nan
    )

    if total_traversals > 0:
        shares = np.asarray([counter[e] / total_traversals for e in used_edges], dtype=float)
        hhi = float(np.sum(shares ** 2))
        row["edge_traversal_hhi"] = hhi
        row["effective_edges"] = float(1.0 / hhi) if hhi > 0 else np.nan
        row["effective_edges_fraction_of_active"] = (
            float((1.0 / hhi) / n_active_edges) if hhi > 0 and n_active_edges > 0 else np.nan
        )
    else:
        row["edge_traversal_hhi"] = np.nan
        row["effective_edges"] = np.nan
        row["effective_edges_fraction_of_active"] = np.nan

    ranked_edges = sorted(active_edges, key=lambda e: counter.get(e, 0), reverse=True)

    for frac in TOP_EDGE_FRACTIONS:
        pct = int(round(frac * 100))
        k = max(1, int(math.ceil(frac * n_active_edges))) if n_active_edges > 0 else 0
        top_edges = ranked_edges[:k]
        top_counts = [counter.get(e, 0) for e in top_edges]
        top_used = [e for e in top_edges if counter.get(e, 0) > 0]

        prefix = f"top{pct}pct"

        row[f"{prefix}_n_active_edges_in_set"] = int(k)
        row[f"{prefix}_n_positively_used_edges_in_set"] = int(len(top_used))
        row[f"{prefix}_traversal_share"] = (
            float(sum(top_counts) / total_traversals) if total_traversals > 0 else np.nan
        )

        if top_used:
            ws = np.asarray([edge_w[e] for e in top_used], dtype=float)
            supports = 1.0 - ws
            counts = np.asarray([counter[e] for e in top_used], dtype=float)

            row[f"{prefix}_mean_w_top_used"] = float(np.mean(ws))
            row[f"{prefix}_median_w_top_used"] = float(np.median(ws))
            row[f"{prefix}_mean_support_top_used"] = float(np.mean(supports))
            row[f"{prefix}_median_support_top_used"] = float(np.median(supports))
            row[f"{prefix}_usage_weighted_mean_w_top_used"] = float(np.average(ws, weights=counts))
            row[f"{prefix}_usage_weighted_mean_support_top_used"] = float(np.average(supports, weights=counts))
        else:
            row[f"{prefix}_mean_w_top_used"] = np.nan
            row[f"{prefix}_median_w_top_used"] = np.nan
            row[f"{prefix}_mean_support_top_used"] = np.nan
            row[f"{prefix}_median_support_top_used"] = np.nan
            row[f"{prefix}_usage_weighted_mean_w_top_used"] = np.nan
            row[f"{prefix}_usage_weighted_mean_support_top_used"] = np.nan

    return row


def process_one_sample(task: Dict[str, Any]) -> Dict[str, Any]:
    sample_id = task["sample_id"]
    participant_id = task["participant_id"]
    cond = task["cond"]
    graph_path = Path(task["graph_path"])

    n_source = int(task["n_source"])
    n_target = int(task["n_target"])
    long_min_hop = int(task["long_min_hop"])
    active_tol = float(task["active_tol"])
    seed = int(task["seed"])
    quantiles = list(task["quantiles"])

    rng = np.random.default_rng(seed)

    nodes, adjacency, edge_w = parse_graphml_active_digraph(graph_path, active_tol=active_tol)

    n_active_vertices = len(nodes)
    n_active_edges = len(edge_w)

    base_common = {
        "sample_id": sample_id,
        "participant_id": participant_id,
        "cond": cond,
        "n_active_vertices": n_active_vertices,
        "n_active_edges": n_active_edges,
        "n_source_requested": n_source,
        "n_target_requested_per_source": n_target,
        "long_min_hop": long_min_hop,
    }

    if n_active_vertices == 0 or n_active_edges == 0:
        path_rows = []
        edge_rows = []
        for mode in ["minimum_hop", "minimax"]:
            for path_set in ["all", f"long_hop_ge{long_min_hop}"]:
                b = dict(base_common)
                b.update({
                    "mode": mode,
                    "path_set": path_set,
                    "n_sources_sampled": 0,
                    "n_ordered_source_target_pairs": 0,
                    "mean_reachable_fraction_sampled_sources": np.nan,
                })
                path_rows.append(summarise_paths([], b, quantiles))
                edge_rows.append(summarise_edge_concentration(Counter(), edge_w, b))
        return {"sample_id": sample_id, "path_rows": path_rows, "edge_rows": edge_rows, "error": None}

    candidate_sources = [u for u in nodes if len(adjacency.get(u, [])) > 0]

    if len(candidate_sources) == 0:
        sources = []
    else:
        source_count = min(n_source, len(candidate_sources))
        sources = list(rng.choice(candidate_sources, size=source_count, replace=False))

    hop_metrics_all: List[Dict[str, float]] = []
    hop_metrics_long: List[Dict[str, float]] = []
    minimax_metrics_all: List[Dict[str, float]] = []
    minimax_metrics_long: List[Dict[str, float]] = []

    hop_edge_counter_all = Counter()
    hop_edge_counter_long = Counter()
    minimax_edge_counter_all = Counter()
    minimax_edge_counter_long = Counter()

    reachable_fractions: List[float] = []
    n_pairs = 0

    for source in sources:
        hop_paths_by_target = bfs_paths_from_source(adjacency, source)

        reachable_targets = list(hop_paths_by_target.keys())
        if not reachable_targets:
            reachable_fractions.append(0.0)
            continue

        reachable_fractions.append(len(reachable_targets) / max(1, n_active_vertices - 1))

        target_count = min(n_target, len(reachable_targets))
        targets = list(rng.choice(reachable_targets, size=target_count, replace=False))
        target_set = set(targets)
        n_pairs += len(targets)

        # First compute minimum-hop paths.
        hop_long_targets = set()

        for target in targets:
            p = hop_paths_by_target[target]
            m = path_metrics(p, edge_w)
            hop_metrics_all.append(m)
            add_path_edges(hop_edge_counter_all, p)

            if m["path_length"] >= long_min_hop:
                hop_metrics_long.append(m)
                add_path_edges(hop_edge_counter_long, p)
                hop_long_targets.add(target)

        # Then compute minimax paths for the exact same ordered source-target pairs.
        minimax_paths_by_target = minimax_paths_from_source(adjacency, edge_w, source, target_set)

        for target in targets:
            p = minimax_paths_by_target.get(target)
            if p is None:
                continue

            m = path_metrics(p, edge_w)
            minimax_metrics_all.append(m)
            add_path_edges(minimax_edge_counter_all, p)

            # Long-range set is defined by minimum-hop distance for the same source-target pair.
            if target in hop_long_targets:
                minimax_metrics_long.append(m)
                add_path_edges(minimax_edge_counter_long, p)

    mean_reachable_fraction = mean_or_nan(reachable_fractions)

    path_rows = []
    edge_rows = []

    combos = [
        ("minimum_hop", "all", hop_metrics_all, hop_edge_counter_all),
        ("minimum_hop", f"long_hop_ge{long_min_hop}", hop_metrics_long, hop_edge_counter_long),
        ("minimax", "all", minimax_metrics_all, minimax_edge_counter_all),
        ("minimax", f"long_hop_ge{long_min_hop}", minimax_metrics_long, minimax_edge_counter_long),
    ]

    for mode, path_set, metrics, counter in combos:
        b = dict(base_common)
        b.update({
            "mode": mode,
            "path_set": path_set,
            "n_sources_sampled": len(sources),
            "n_ordered_source_target_pairs": n_pairs,
            "mean_reachable_fraction_sampled_sources": mean_reachable_fraction,
        })
        path_rows.append(summarise_paths(metrics, b, quantiles))
        edge_rows.append(summarise_edge_concentration(counter, edge_w, b))

    return {"sample_id": sample_id, "path_rows": path_rows, "edge_rows": edge_rows, "error": None}


def worker(task: Dict[str, Any]) -> Dict[str, Any]:
    try:
        return process_one_sample(task)
    except Exception:
        return {
            "sample_id": task.get("sample_id"),
            "path_rows": [],
            "edge_rows": [],
            "error": traceback.format_exc(),
        }


