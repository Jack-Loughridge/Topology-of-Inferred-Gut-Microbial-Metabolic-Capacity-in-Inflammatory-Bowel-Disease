def compute_interpretation_curves(
    model: AlphaPiModel,
    bounds: np.ndarray,
    grid_size: int,
    device: torch.device,
    chunk_size: int,
) -> pd.DataFrame:
    grid = np.geomspace(1e-6, 0.999, int(grid_size)).astype(np.float32)
    alpha = model.alpha_positive().detach().cpu().numpy()
    bins = np.searchsorted(bounds, grid, side="right") - 1
    bins = np.clip(bins, 0, len(alpha) - 1)
    alpha_raw = alpha[bins]
    alpha_norm = alpha_raw / max(float(np.mean(alpha_raw)), 1e-12)

    delta_weight = model.clf_head.weight[1] - model.clf_head.weight[0]
    x_flat = model.x_points.reshape(-1)
    w_flat = model.w_points.reshape(-1)
    log_x = torch.log(x_flat + EPS)
    interval_count, quad_points = model.x_points.shape
    inv_two_sigma_sq = 1.0 / (2.0 * model.sigma_log * model.sigma_log)
    influence_parts = []

    with torch.no_grad():
        grid_tensor = torch.tensor(grid, dtype=torch.float32, device=device)
        bin_tensor = torch.tensor(bins, dtype=torch.long, device=device)
        alpha_tensor = model.alpha_positive()[bin_tensor]
        for start in range(0, len(grid), chunk_size):
            end = min(len(grid), start + chunk_size)
            log_d = torch.log(grid_tensor[start:end] + EPS)
            diff = log_x.view(1, -1) - log_d.view(-1, 1)
            kernel = torch.exp(-(diff * diff) * inv_two_sigma_sq)
            weighted = kernel * w_flat.view(1, -1)
            per_interval = weighted.view(end - start, interval_count, quad_points).sum(dim=2)
            influence = alpha_tensor[start:end] * (per_interval @ delta_weight)
            influence_parts.append(influence.cpu().numpy())
    signed_influence = np.concatenate(influence_parts)
    return pd.DataFrame(
        {
            "death_value": grid,
            "alpha_raw_piecewise": alpha_raw,
            "alpha_normalized_mean1_loggrid": alpha_norm,
            "signed_single_death_logit_influence": signed_influence,
        }
    )


def check_influence_identity(model: AlphaPiModel, bounds: np.ndarray, device: torch.device) -> float:
    # Numerical identity check: for one death d, the logit difference minus the
    # intercept must equal the saved single-death influence formula.
    d = float(np.median(0.5 * (bounds[:-1] + bounds[1:])))
    d = min(max(d, 1e-6), 0.999)
    bin_idx = int(np.clip(np.searchsorted(bounds, d, side="right") - 1, 0, len(bounds) - 2))
    deaths = torch.tensor([[d]], dtype=torch.float32, device=device)
    bins = torch.tensor([[bin_idx]], dtype=torch.long, device=device)
    mask = torch.ones((1, 1), dtype=torch.float32, device=device)
    with torch.no_grad():
        _z, logits = model(deaths, bins, mask)
        observed = float((logits[0, 1] - logits[0, 0] - (model.clf_head.bias[1] - model.clf_head.bias[0])).item())

        alpha_d = model.alpha_positive()[bin_idx]
        x_flat = model.x_points.reshape(-1)
        w_flat = model.w_points.reshape(-1)
        diff = torch.log(x_flat + EPS) - math.log(d + EPS)
        kernel = torch.exp(-(diff * diff) / (2.0 * model.sigma_log * model.sigma_log))
        interval_count, quad_points = model.x_points.shape
        per_interval = (kernel * w_flat).view(interval_count, quad_points).sum(dim=1)
        delta_weight = model.clf_head.weight[1] - model.clf_head.weight[0]
        expected = float((alpha_d * torch.dot(per_interval, delta_weight)).item())
    return abs(observed - expected)


