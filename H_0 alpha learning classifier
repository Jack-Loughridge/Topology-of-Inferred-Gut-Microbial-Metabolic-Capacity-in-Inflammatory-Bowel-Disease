# Training
# -----------------------------------------------------------------------------


def epoch_is_better(candidate: dict[str, float], best: Optional[dict[str, float]]) -> bool:
    if best is None:
        return True
    candidate_key = (
        safe_rank(candidate["balanced_accuracy"]),
        safe_rank(candidate["macro_f1"]),
        safe_rank(candidate["roc_auc"]),
        (-float(candidate["loss"]) if math.isfinite(float(candidate["loss"])) else float("-inf")),
        -int(candidate["epoch"]),
    )
    best_key = (
        safe_rank(best["balanced_accuracy"]),
        safe_rank(best["macro_f1"]),
        safe_rank(best["roc_auc"]),
        (-float(best["loss"]) if math.isfinite(float(best["loss"])) else float("-inf")),
        -int(best["epoch"]),
    )
    return candidate_key > best_key


def train_one_epoch(
    model: AlphaPiModel,
    loader: DataLoader,
    optimizer: torch.optim.Optimizer,
    ce_loss: nn.CrossEntropyLoss,
    device: torch.device,
    args: argparse.Namespace,
) -> dict[str, float]:
    model.train()
    total_examples = 0
    totals = {"loss": 0.0, "ce": 0.0, "within": 0.0, "radius": 0.0, "between": 0.0, "grad_norm": 0.0}
    y_true_parts = []
    probability_parts = []

    for deaths, bins, mask, labels, _sids, _pids, _global_indices in loader:
        deaths = deaths.to(device, non_blocking=True)
        bins = bins.to(device, non_blocking=True)
        mask = mask.to(device, non_blocking=True)
        labels = labels.to(device, non_blocking=True)
        optimizer.zero_grad(set_to_none=True)
        z, logits = model(deaths, bins, mask)
        ce = ce_loss(logits, labels)
        _, parts = model.alpha_pi_loss(z, labels, args.margin_between)
        loss = combine_loss(
            ce,
            parts,
            args.lambda_ce,
            args.lambda_within,
            args.lambda_radius,
            args.lambda_between,
        )
        if not torch.isfinite(loss):
            raise FloatingPointError("Non-finite training loss")
        loss.backward()
        if args.max_grad_norm > 0:
            grad_norm = torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=args.max_grad_norm)
        else:
            grad_sq = torch.zeros((), dtype=torch.float32, device=device)
            for parameter in model.parameters():
                if parameter.grad is not None:
                    grad_sq = grad_sq + torch.sum(parameter.grad.detach() ** 2)
            grad_norm = torch.sqrt(grad_sq)
        if not torch.isfinite(grad_norm):
            raise FloatingPointError("Non-finite gradient norm")
        optimizer.step()

        probabilities = F.softmax(logits, dim=1)[:, 1]
        batch_size = int(labels.size(0))
        total_examples += batch_size
        totals["loss"] += float(loss.item()) * batch_size
        totals["ce"] += float(ce.item()) * batch_size
        totals["within"] += float(parts["within"].item()) * batch_size
        totals["radius"] += float(parts["radius"].item()) * batch_size
        totals["between"] += float(parts["between"].item()) * batch_size
        totals["grad_norm"] += float(grad_norm.item()) * batch_size
        y_true_parts.append(labels.detach().cpu().numpy())
        probability_parts.append(probabilities.detach().cpu().numpy())

    y_true = np.concatenate(y_true_parts)
    probability_ibd = np.concatenate(probability_parts)
    metrics = binary_metrics(y_true, probability_ibd)
    return {
        **metrics,
        **{f"mean_{key}": value / max(total_examples, 1) for key, value in totals.items()},
    }


def create_model(bounds: np.ndarray, device: torch.device, args: argparse.Namespace) -> AlphaPiModel:
    centers = 0.5 * (bounds[:-1] + bounds[1:])
    sigma_log = compute_sigma_log(centers)
    return AlphaPiModel(
        n_intervals=len(bounds) - 1,
        n_classes=2,
        bounds=bounds,
        sigma_log=sigma_log,
        quad_points=args.quad_points,
        point_chunk=args.point_chunk,
        device=device,
    ).to(device)


def save_model_package(
    path: Path,
    model: AlphaPiModel,
    bounds: np.ndarray,
    metadata: dict[str, Any],
) -> None:
    package = {
        "schema_version": SCHEMA_VERSION,
        "state_dict": model.state_dict(),
        "bounds": np.asarray(bounds, dtype=np.float32),
        "interval_centers": 0.5 * (bounds[:-1] + bounds[1:]),
        "sigma_log": model.sigma_log,
        "quad_points": model.quad_points,
        "point_chunk": model.point_chunk,
        "label_order": LABEL_ORDER,
        "prediction_rule": "softmax(logits), argmax; IBD probability is column 1",
        "centroid_outputs": "diagnostic only",
        "alpha_parameterization": "softplus(raw_alpha) + 1e-8",
        "metadata": metadata,
    }
    atomic_torch_save(path, package)


def candidate_seed(base_seed: int, repeat_idx: int, fold_idx: int) -> int:
    return int(base_seed + repeat_idx * 100_003 + fold_idx * 1_009 + 17)


def final_seed(base_seed: int, repeat_idx: int, fold_idx: int) -> int:
    return int(base_seed + repeat_idx * 100_003 + fold_idx * 1_009 + 53)


def fit_candidate(
    bundle: H0DatasetBundle,
    inner_train_idx: np.ndarray,
    validation_idx: np.ndarray,
    percentile_step: float,
    repeat_idx: int,
    fold_idx: int,
    candidate_dir: Path,
    device: torch.device,
    args: argparse.Namespace,
) -> dict[str, Any]:
    result_path = candidate_dir / "candidate_result.json"
    completion_path = candidate_dir / "CANDIDATE_COMPLETE.json"
    if args.resume and completion_path.exists() and result_path.exists():
        return json.loads(result_path.read_text())

    candidate_dir.mkdir(parents=True, exist_ok=True)
    seed = candidate_seed(args.model_seed, repeat_idx, fold_idx)
    set_all_seeds(seed, deterministic=args.deterministic)
    bounds = build_adaptive_bounds(
        bundle.deaths_list,
        inner_train_idx,
        percentile_step,
        args.min_interval_width,
    )
    model = create_model(bounds, device, args)
    ce_loss = make_ce_loss(bundle.labels[inner_train_idx], 2, device)
    train_loader = make_loader(
        bundle,
        inner_train_idx,
        bounds,
        args.batch_size,
        True,
        seed,
        args.num_workers,
    )
    validation_loader = make_loader(
        bundle,
        validation_idx,
        bounds,
        args.batch_size,
        False,
        seed,
        args.num_workers,
    )
    optimizer = torch.optim.Adam(model.parameters(), lr=args.learning_rate, weight_decay=args.weight_decay)

    history_rows = []
    best_record: Optional[dict[str, float]] = None
    best_state = None
    started = time.time()

    for epoch in range(1, args.epochs + 1):
        train_metrics = train_one_epoch(model, train_loader, optimizer, ce_loss, device, args)
        validation = evaluate_model(model, validation_loader, ce_loss, device, args, return_latents=False)
        val_metrics = validation["metrics"]
        record = {
            "epoch": epoch,
            "balanced_accuracy": val_metrics["balanced_accuracy"],
            "macro_f1": val_metrics["macro_f1"],
            "roc_auc": val_metrics["roc_auc"],
            "loss": validation["mean_loss"],
        }
        if epoch_is_better(record, best_record):
            best_record = record.copy()
            best_state = copy.deepcopy(model.state_dict())

        alpha = model.alpha_positive().detach().cpu().numpy()
        history_rows.append(
            {
                "epoch": epoch,
                **{f"train_{key}": value for key, value in train_metrics.items()},
                **{f"val_{key}": value for key, value in val_metrics.items()},
                "val_mean_loss": validation["mean_loss"],
                "val_mean_ce": validation["mean_ce"],
                "val_mean_within": validation["mean_within"],
                "val_mean_radius": validation["mean_radius"],
                "val_mean_between": validation["mean_between"],
                "alpha_min": float(alpha.min()),
                "alpha_max": float(alpha.max()),
                "alpha_mean": float(alpha.mean()),
                "alpha_sd": float(alpha.std(ddof=0)),
                "center_distance": float(torch.linalg.vector_norm(model.centers[1] - model.centers[0]).item()),
            }
        )
        if epoch == 1 or epoch == args.epochs or epoch % args.print_every == 0:
            print(
                f"[candidate r{repeat_idx:02d} f{fold_idx} q={percentile_step:g}] "
                f"epoch={epoch:03d} train_bacc={train_metrics['balanced_accuracy']:.3f} "
                f"val_bacc={val_metrics['balanced_accuracy']:.3f} "
                f"val_f1={val_metrics['macro_f1']:.3f} val_auc={val_metrics['roc_auc']:.3f}",
                flush=True,
            )

    if best_state is None or best_record is None:
        raise RuntimeError("Candidate training did not produce a best state")
    model.load_state_dict(best_state)
    best_validation = evaluate_model(model, validation_loader, ce_loss, device, args, return_latents=False)
    best_predictions = best_validation["predictions"]
    best_participant_predictions = participant_predictions(best_predictions)
    participant_metrics = binary_metrics(
        best_participant_predictions["true_idx"].to_numpy(),
        best_participant_predictions["probability_ibd"].to_numpy(),
    )

    history = pd.DataFrame(history_rows)
    atomic_to_csv(history, candidate_dir / "training_history.csv", index=False)
    atomic_to_csv(best_predictions, candidate_dir / "best_validation_predictions_sample.csv", index=False)
    atomic_to_csv(best_participant_predictions, candidate_dir / "best_validation_predictions_participant.csv", index=False)
    atomic_save_npy(candidate_dir / "adaptive_bounds_inner_train.npy", bounds)
    atomic_save_npy(candidate_dir / "alpha_best.npy", model.alpha_positive().detach().cpu().numpy())
    save_model_package(
        candidate_dir / "candidate_best_model.pt",
        model,
        bounds,
        {
            "stage": "inner_candidate",
            "repeat": repeat_idx,
            "fold": fold_idx,
            "percentile_step": percentile_step,
            "seed": seed,
            "best_epoch": int(best_record["epoch"]),
        },
    )

    result = {
        "repeat": repeat_idx,
        "fold": fold_idx,
        "percentile_step": float(percentile_step),
        "n_intervals": int(len(bounds) - 1),
        "sigma_log": float(model.sigma_log),
        "seed": seed,
        "best_epoch": int(best_record["epoch"]),
        "best_epoch_at_limit": bool(int(best_record["epoch"]) == args.epochs),
        "validation_accuracy": float(best_validation["metrics"]["accuracy"]),
        "validation_balanced_accuracy": float(best_validation["metrics"]["balanced_accuracy"]),
        "validation_macro_f1": float(best_validation["metrics"]["macro_f1"]),
        "validation_positive_f1": float(best_validation["metrics"]["positive_f1"]),
        "validation_roc_auc": float(best_validation["metrics"]["roc_auc"]),
        "validation_brier": float(best_validation["metrics"]["brier"]),
        "validation_log_loss": float(best_validation["metrics"]["log_loss"]),
        "validation_loss": float(best_validation["mean_loss"]),
        "validation_centroid_roc_auc": float(best_validation["centroid_roc_auc"]),
        "validation_participant_balanced_accuracy": float(participant_metrics["balanced_accuracy"]),
        "validation_participant_roc_auc": float(participant_metrics["roc_auc"]),
        "elapsed_seconds": float(time.time() - started),
    }
    write_json(result_path, result)
    write_json(completion_path, {"completed_utc": now_iso(), "result": result})
    return result


def choose_candidate(candidate_results: list[dict[str, Any]]) -> dict[str, Any]:
    if not candidate_results:
        raise ValueError("No candidate results supplied")
    frame = pd.DataFrame(candidate_results).copy()
    frame["_bacc"] = frame["validation_balanced_accuracy"].map(safe_rank)
    frame["_f1"] = frame["validation_macro_f1"].map(safe_rank)
    frame["_auc"] = frame["validation_roc_auc"].map(safe_rank)
    frame = frame.sort_values(
        ["_bacc", "_f1", "_auc", "n_intervals", "percentile_step"],
        ascending=[False, False, False, True, False],
    ).reset_index(drop=True)
    selected = frame.iloc[0].drop(labels=["_bacc", "_f1", "_auc"]).to_dict()
    return selected


