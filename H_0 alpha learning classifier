def compare_resume_config(existing: dict[str, Any], current: dict[str, Any]) -> None:
    # created_utc and software device metadata are not used for compatibility.
    keys = ["schema_version", "task", "paths", "outer_cv", "inner_selection", "final_refit", "model", "randomness", "input_fingerprint"]
    mismatches = []
    for key in keys:
        if existing.get(key) != current.get(key):
            mismatches.append(key)
    if mismatches:
        raise ValueError(
            "Existing output directory has an incompatible run configuration. "
            f"Mismatched sections: {mismatches}. Use a new output directory or remove the old one."
        )


def main(args: argparse.Namespace) -> None:
    args.output_dir.mkdir(parents=True, exist_ok=True)
    manifest, sample_meta, n_repeats, n_splits = load_and_validate_manifest(args.split_manifest)
    if args.expected_repeats is not None and n_repeats != args.expected_repeats:
        raise ValueError(f"Expected {args.expected_repeats} repeats, manifest has {n_repeats}")
    if args.expected_splits is not None and n_splits != args.expected_splits:
        raise ValueError(f"Expected {args.expected_splits} folds, manifest has {n_splits}")

    bundle = load_h0_bundle(
        args.pd_dir,
        args.label_csv,
        args.metadata_csv,
        sample_meta,
        args.require_exact_pd_set,
    )
    input_fingerprint = make_input_fingerprint(
        args.split_manifest,
        args.label_csv,
        args.metadata_csv,
        bundle.pd_paths,
    )
    config = build_run_config(args, input_fingerprint, n_repeats, n_splits)
    config_path = args.output_dir / "run_config.json"
    if config_path.exists() and args.resume:
        existing = json.loads(config_path.read_text())
        compare_resume_config(existing, config)
    else:
        write_json(config_path, config)

    device = torch.device(args.device)
    if device.type == "cuda" and not torch.cuda.is_available():
        raise RuntimeError("CUDA device requested but torch.cuda.is_available() is False")
    set_all_seeds(args.model_seed, deterministic=args.deterministic)

    print("=" * 110, flush=True)
    print("Repeated H0 Alpha-Pi classifier: IBD vs non-IBD", flush=True)
    print("=" * 110, flush=True)
    print(f"Device: {device}", flush=True)
    print(f"Samples: {len(bundle.sample_ids)}", flush=True)
    print(f"Participants: {bundle.metadata['participant_id'].nunique()}", flush=True)
    print(f"Outer manifest: {n_repeats} repeats x {n_splits} folds", flush=True)
    print(f"Percentile steps: {args.percentile_steps}", flush=True)
    print(f"Output: {args.output_dir}", flush=True)
    print("Primary prediction: logit/CE head; centroid diagnostics only", flush=True)
    print("Final bounds: rebuilt from all outer-training diagrams after inner selection", flush=True)
    print("=" * 110, flush=True)

    fold_results = []
    sample_predictions_all = []
    participant_predictions_all = []
    curves_all = []
    candidates_all = []

    for repeat_idx in range(1, n_repeats + 1):
        for fold_idx in range(1, n_splits + 1):
            result, sample_predictions, participant_predictions_df, curves, candidate_frame = run_outer_fold(
                bundle,
                manifest,
                repeat_idx,
                fold_idx,
                args.output_dir,
                device,
                args,
            )
            fold_results.append(result)
            sample_predictions_all.append(sample_predictions)
            participant_predictions_all.append(participant_predictions_df)
            curves_all.append(curves)
            candidates_all.append(candidate_frame)
            write_partial_progress(
                args.output_dir,
                bundle,
                fold_results,
                sample_predictions_all,
                participant_predictions_all,
                candidates_all,
                n_splits,
            )

    aggregate_outputs(
        args.output_dir,
        bundle,
        fold_results,
        sample_predictions_all,
        participant_predictions_all,
        curves_all,
        candidates_all,
        n_repeats,
        n_splits,
        args,
    )
    print(f"\nCompleted repeated H0 Alpha-Pi analysis. Outputs: {args.output_dir}", flush=True)


def make_parser() -> argparse.ArgumentParser:
    home = Path.home() / "Real_Data"
    parser = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.ArgumentDefaultsHelpFormatter)
    parser.add_argument("--pd-dir", type=Path, default=home / "out_pds")
    parser.add_argument("--label-csv", type=Path, default=home / "sample_labels.csv")
    parser.add_argument("--metadata-csv", type=Path, default=home / "hmp2_metadata.csv")
    parser.add_argument("--split-manifest", type=Path, default=home / "Ricci_IBD_RepeatedCV_CPath" / "splits" / "sample_split_manifest.csv")
    parser.add_argument("--output-dir", type=Path, default=home / "H0_AlphaPi_RepeatedCV_TrainOnlyBins_IBD")
    parser.add_argument("--percentile-steps", type=parse_percentile_steps, default=parse_percentile_steps("0.3,0.4,0.5,0.6,0.7"))
    parser.add_argument("--expected-repeats", type=int, default=20)
    parser.add_argument("--expected-splits", type=int, default=5)
    parser.add_argument("--inner-splits", type=int, default=5)
    parser.add_argument("--epochs", type=int, default=70)
    parser.add_argument("--batch-size", type=int, default=32)
    parser.add_argument("--learning-rate", type=float, default=4e-4)
    parser.add_argument("--weight-decay", type=float, default=1e-4)
    parser.add_argument("--quad-points", type=int, default=5)
    parser.add_argument("--point-chunk", type=int, default=256)
    parser.add_argument("--lambda-within", type=float, default=1.0)
    parser.add_argument("--lambda-radius", type=float, default=1.0)
    parser.add_argument("--lambda-between", type=float, default=200.0)
    parser.add_argument("--lambda-ce", type=float, default=1000.0)
    parser.add_argument("--margin-between", type=float, default=10.0)
    parser.add_argument("--max-grad-norm", type=float, default=0.0, help="0 disables clipping and preserves the original optimization; positive values enable clipping")
    parser.add_argument("--min-interval-width", type=float, default=1e-8)
    parser.add_argument("--model-seed", type=int, default=1337)
    parser.add_argument("--inner-split-seed", type=int, default=7331)
    parser.add_argument("--num-workers", type=int, default=0)
