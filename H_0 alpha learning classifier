REQUIRED_MANIFEST_COLUMNS = {
    "repeat",
    "fold",
    "split_seed",
    "role",
    "sample_id",
    "participant_id",
    "label",
    "label_name",
}


def load_and_validate_manifest(path: Path) -> tuple[pd.DataFrame, pd.DataFrame, int, int]:
    if not path.exists():
        raise FileNotFoundError(f"Split manifest not found: {path}")

    manifest = pd.read_csv(
        path,
        dtype={"sample_id": str, "participant_id": str, "role": str, "label_name": str},
        low_memory=False,
    )
    missing = REQUIRED_MANIFEST_COLUMNS - set(manifest.columns)
    if missing:
        raise ValueError(f"Split manifest is missing required columns: {sorted(missing)}")

    manifest = manifest.copy()
    manifest["sample_id"] = manifest["sample_id"].map(normalise_sample_id)
    manifest["participant_id"] = manifest["participant_id"].astype(str).str.strip()
    manifest["role"] = manifest["role"].astype(str).str.strip().str.lower()
    manifest["repeat"] = pd.to_numeric(manifest["repeat"], errors="raise").astype(int)
    manifest["fold"] = pd.to_numeric(manifest["fold"], errors="raise").astype(int)
    manifest["split_seed"] = pd.to_numeric(manifest["split_seed"], errors="raise").astype(int)
    manifest["label"] = pd.to_numeric(manifest["label"], errors="raise").astype(int)

    if not set(manifest["role"]).issubset({"train", "test"}):
        raise ValueError(f"Manifest roles must be train/test, found {sorted(set(manifest['role']))}")
    if set(manifest["label"]) != {0, 1}:
        raise ValueError(f"Manifest binary labels must be exactly {{0,1}}, found {sorted(set(manifest['label']))}")

    # A unique authoritative metadata row per sample.
    consistency_cols = ["sample_id", "participant_id", "label", "label_name"]
    if "condition" in manifest.columns:
        consistency_cols.append("condition")
    unique_meta = manifest[consistency_cols].drop_duplicates()
    counts = unique_meta.groupby("sample_id").size()
    bad = counts[counts != 1]
    if len(bad):
        raise ValueError(
            "Manifest contains inconsistent metadata for sample IDs. Examples: "
            + ", ".join(bad.index.astype(str).tolist()[:10])
        )
    sample_meta = unique_meta.drop_duplicates("sample_id").reset_index(drop=True)

    participant_label_counts = sample_meta.groupby("participant_id")["label"].nunique()
    mixed = participant_label_counts[participant_label_counts > 1]
    if len(mixed):
        raise ValueError(
            "Manifest contains participants with mixed binary labels. Examples: "
            + ", ".join(mixed.index.astype(str).tolist()[:10])
        )

    repeats = sorted(manifest["repeat"].unique().tolist())
    folds = sorted(manifest["fold"].unique().tolist())
    if repeats != list(range(1, len(repeats) + 1)):
        raise ValueError(f"Repeat IDs must be consecutive from 1, found {repeats}")
    if folds != list(range(1, len(folds) + 1)):
        raise ValueError(f"Fold IDs must be consecutive from 1, found {folds}")

    all_samples = set(sample_meta["sample_id"])
    all_participants = set(sample_meta["participant_id"])

    for repeat_idx in repeats:
        repeat_rows = manifest[manifest["repeat"] == repeat_idx]
        test_count = repeat_rows.loc[repeat_rows["role"] == "test"].groupby("sample_id").size()
        if set(test_count.index) != all_samples or not np.all(test_count.to_numpy() == 1):
            raise ValueError(f"Repeat {repeat_idx} does not test every sample exactly once")

        for fold_idx in folds:
            fold_rows = repeat_rows[repeat_rows["fold"] == fold_idx]
            train_rows = fold_rows[fold_rows["role"] == "train"]
            test_rows = fold_rows[fold_rows["role"] == "test"]
            if len(train_rows) == 0 or len(test_rows) == 0:
                raise ValueError(f"Empty train/test role in repeat={repeat_idx}, fold={fold_idx}")

            train_samples = set(train_rows["sample_id"])
            test_samples = set(test_rows["sample_id"])
            if train_samples & test_samples:
                raise ValueError(f"Sample leakage in repeat={repeat_idx}, fold={fold_idx}")
            if train_samples | test_samples != all_samples:
                raise ValueError(f"Train/test sample union is incomplete in repeat={repeat_idx}, fold={fold_idx}")

            train_participants = set(train_rows["participant_id"])
            test_participants = set(test_rows["participant_id"])
            if train_participants & test_participants:
                raise ValueError(f"Participant leakage in repeat={repeat_idx}, fold={fold_idx}")
            if train_participants | test_participants != all_participants:
                raise ValueError(f"Train/test participant union is incomplete in repeat={repeat_idx}, fold={fold_idx}")

            if set(train_rows["label"]) != {0, 1} or set(test_rows["label"]) != {0, 1}:
                raise ValueError(f"A class is absent in repeat={repeat_idx}, fold={fold_idx}")

            if fold_rows["split_seed"].nunique() != 1:
                raise ValueError(f"Multiple split seeds in repeat={repeat_idx}, fold={fold_idx}")

    return manifest, sample_meta, len(repeats), len(folds)


def _normalise_required_sample_ids(required_sample_ids: Optional[Iterable[str]]) -> Optional[set[str]]:
    """Return normalized manifest IDs, or None when validation is intentionally global."""
    if required_sample_ids is None:
        return None
    return {normalise_sample_id(value) for value in required_sample_ids}


def load_labels_for_verification(
    path: Path,
    required_sample_ids: Optional[Iterable[str]] = None,
) -> pd.DataFrame:
    """Load and validate labels, restricted to the analysed manifest when supplied.

    Large source tables can contain duplicate or conflicting records for samples
    that are irrelevant to the current task. Such records must not block a
    manifest-locked analysis. Conflicts remain fatal for every required sample.
    """
    if not path.exists():
        raise FileNotFoundError(f"Label CSV not found: {path}")
    labels = pd.read_csv(path, low_memory=False)
    sample_col = find_col(labels, ["sample_id", "sample", "External ID", "external_id", "id"])
    label_col = find_col(labels, ["label", "condition", "diagnosis", "disease", "status"])
    if sample_col is None or label_col is None:
        raise ValueError(f"Could not detect sample/label columns in {path}. Columns={labels.columns.tolist()}")

    out = labels[[sample_col, label_col]].copy()
    out.columns = ["sample_id", "condition"]
    out["sample_id"] = out["sample_id"].map(normalise_sample_id)

    required = _normalise_required_sample_ids(required_sample_ids)
    if required is not None:
        out = out[out["sample_id"].isin(required)].copy()

    out["condition"] = out["condition"].map(normalise_condition)
    out = out.dropna(subset=["condition"])
    dup = out.groupby("sample_id")["condition"].nunique()
    bad = dup[dup > 1]
    if len(bad):
        raise ValueError(f"Conflicting labels for required sample IDs: {bad.index.astype(str).tolist()[:10]}")
    return out.drop_duplicates("sample_id")


def load_metadata_for_verification(
    path: Path,
    required_sample_ids: Optional[Iterable[str]] = None,
) -> pd.DataFrame:
    """Load and validate participant IDs for the analysed manifest samples only.

    Conflicting records outside the shared split manifest are ignored because
    they cannot enter this analysis. Missing or conflicting participant IDs for
    any required sample remain fatal.
    """
    if not path.exists():
        raise FileNotFoundError(f"Metadata CSV not found: {path}")
    meta = pd.read_csv(path, low_memory=False)
    sample_col = find_col(meta, ["External ID", "external_id", "sample_id", "sample", "id"])
    participant_col = find_col(meta, ["Participant ID", "participant_id", "participant", "subject_id", "host_subject_id"])
    if sample_col is None or participant_col is None:
        raise ValueError(f"Could not detect sample/participant columns in {path}. Columns={meta.columns.tolist()}")

    out = meta[[sample_col, participant_col]].copy()
    out.columns = ["sample_id", "participant_id"]
    out["sample_id"] = out["sample_id"].map(normalise_sample_id)

    required = _normalise_required_sample_ids(required_sample_ids)
    if required is not None:
        out = out[out["sample_id"].isin(required)].copy()

    participant_text = out["participant_id"].astype("string").str.strip()
    missing_mask = participant_text.isna() | participant_text.isin(["", "nan", "None", "<NA>"])
    if missing_mask.any():
        examples = out.loc[missing_mask, "sample_id"].astype(str).drop_duplicates().tolist()[:10]
        raise ValueError(
            "Required metadata rows contain missing/blank participant IDs; "
            f"these are not replaced by sample IDs. Examples: {examples}"
        )
    out["participant_id"] = participant_text.astype(str)

    dup = out.groupby("sample_id")["participant_id"].nunique()
    bad = dup[dup > 1]
    if len(bad):
        raise ValueError(f"Conflicting participant IDs for required samples: {bad.index.astype(str).tolist()[:10]}")
    return out.drop_duplicates("sample_id")


def discover_pd_paths(pd_dir: Path) -> dict[str, Path]:
    if not pd_dir.exists():
        raise FileNotFoundError(f"PD directory not found: {pd_dir}")
    paths: dict[str, Path] = {}
    duplicates: list[str] = []
    for path in sorted(pd_dir.glob("*_H0.npy")):
        sample_id = normalise_sample_id(path.name)
        if sample_id in paths:
            duplicates.append(sample_id)
        paths[sample_id] = path
    if duplicates:
        raise ValueError(f"Duplicate normalized H0 files for sample IDs: {duplicates[:10]}")
    if not paths:
        raise FileNotFoundError(f"No *_H0.npy files found in {pd_dir}")
    return paths


def load_h0_bundle(
    pd_dir: Path,
    label_csv: Path,
    metadata_csv: Path,
    sample_meta: pd.DataFrame,
    require_exact_pd_set: bool,
) -> H0DatasetBundle:
    manifest_ids = set(sample_meta["sample_id"].astype(str))
    labels = load_labels_for_verification(label_csv, required_sample_ids=manifest_ids)
    metadata = load_metadata_for_verification(metadata_csv, required_sample_ids=manifest_ids)
    pd_paths_all = discover_pd_paths(pd_dir)

    label_ids = set(labels["sample_id"].astype(str))
    metadata_ids = set(metadata["sample_id"].astype(str))
    pd_ids = set(pd_paths_all)

    missing_labels = sorted(manifest_ids - label_ids)
    missing_meta = sorted(manifest_ids - metadata_ids)
    missing_pds = sorted(manifest_ids - pd_ids)
    if missing_labels:
        raise ValueError(f"Manifest samples missing from label CSV. Examples: {missing_labels[:10]}")
    if missing_meta:
        raise ValueError(f"Manifest samples missing from metadata CSV. Examples: {missing_meta[:10]}")
    if missing_pds:
        raise ValueError(f"Manifest samples missing H0 diagrams. Examples: {missing_pds[:10]}")

    extra_pds = sorted(pd_ids - manifest_ids)
    if extra_pds and require_exact_pd_set:
        raise ValueError(f"H0 directory contains diagrams outside the manifest. Examples: {extra_pds[:10]}")
    if extra_pds:
        print(f"[input] Ignoring {len(extra_pds)} H0 diagrams not present in the shared manifest", flush=True)

    labels_verify = labels.rename(columns={"condition": "condition_csv"})
    verify = sample_meta.merge(labels_verify, on="sample_id", how="left").merge(
        metadata, on="sample_id", how="left", suffixes=("_manifest", "_csv")
    )

    participant_mismatch = verify[verify["participant_id_manifest"].astype(str) != verify["participant_id_csv"].astype(str)]
    if len(participant_mismatch):
        raise ValueError(
            "Participant IDs disagree between manifest and metadata. Examples: "
            + ", ".join(participant_mismatch["sample_id"].astype(str).tolist()[:10])
        )

    label_binary_csv = verify["condition_csv"].map(condition_to_binary)
    label_mismatch = verify[label_binary_csv.to_numpy(dtype=int) != verify["label"].to_numpy(dtype=int)]
    if len(label_mismatch):
        raise ValueError(
            "Binary labels disagree between manifest and label CSV. Examples: "
            + ", ".join(label_mismatch["sample_id"].astype(str).tolist()[:10])
        )

    # Preserve a stable order independent of manifest row duplication.
    stable_meta = sample_meta.sort_values("sample_id").reset_index(drop=True).copy()
    sample_ids: list[str] = []
    participant_ids: list[str] = []
    labels_int: list[int] = []
    label_names: list[str] = []
    conditions: list[str] = []
    deaths_list: list[np.ndarray] = []
    selected_paths: dict[str, Path] = {}

    for row in stable_meta.itertuples(index=False):
        sample_id = str(row.sample_id)
        path = pd_paths_all[sample_id]
        arr = np.load(path, allow_pickle=False)
        arr = np.asarray(arr)
        if arr.size == 0:
            deaths = np.zeros((0,), dtype=np.float32)
        elif arr.ndim == 1:
            deaths = arr.astype(np.float32, copy=False)
        elif arr.ndim == 2 and arr.shape[1] >= 2:
            deaths = arr[:, 1].astype(np.float32, copy=False)
        else:
            deaths = arr.ravel().astype(np.float32, copy=False)
        deaths = deaths[np.isfinite(deaths)]
        deaths = deaths[(deaths > 0.0) & (deaths < (1.0 - TOL))]
        deaths = deaths.astype(np.float32, copy=False)

        sample_ids.append(sample_id)
        participant_ids.append(str(row.participant_id))
        labels_int.append(int(row.label))
        label_names.append(str(row.label_name))
        condition_value = str(getattr(row, "condition", "IBD" if int(row.label) == 1 else "non-IBD"))
        conditions.append(condition_value)
        deaths_list.append(deaths)
        selected_paths[sample_id] = path

    bundle_meta = pd.DataFrame(
        {
            "sample_id": sample_ids,
            "participant_id": participant_ids,
            "label": labels_int,
            "label_name": label_names,
            "condition": conditions,
            "n_h0_deaths": [len(x) for x in deaths_list],
        }
    )
    sample_to_index = {sample_id: idx for idx, sample_id in enumerate(sample_ids)}

    return H0DatasetBundle(
        sample_ids=sample_ids,
        participant_ids=participant_ids,
        labels=np.asarray(labels_int, dtype=int),
        label_names=label_names,
        conditions=conditions,
        deaths_list=deaths_list,
        pd_paths=selected_paths,
        metadata=bundle_meta,
        sample_to_index=sample_to_index,
    )


def make_input_fingerprint(
    split_manifest: Path,
    label_csv: Path,
    metadata_csv: Path,
    pd_paths: dict[str, Path],
) -> dict[str, Any]:
    return {
        "split_manifest_sha256": sha256_file(split_manifest),
        "label_csv_sha256": sha256_file(label_csv),
        "metadata_csv_sha256": sha256_file(metadata_csv),
        "pd_inventory_sha256": fingerprint_pd_inventory(pd_paths),
        "n_pd_files": len(pd_paths),
    }


# -----------------------------------------------------------------------------
# Adaptive intervals and binned datasets
# -----------------------------------------------------------------------------


def build_adaptive_bounds(
    deaths_list: list[np.ndarray],
    indices: np.ndarray,
    percentile_step: float,
    min_interval_width: float,
) -> np.ndarray:
    if len(indices) == 0:
        raise ValueError("Cannot build adaptive bounds from an empty index set")
    pieces = [deaths_list[int(i)] for i in indices if deaths_list[int(i)].size]
    if not pieces:
        raise ValueError("Training diagrams contain no positive nontrivial H0 deaths")
    deaths = np.concatenate(pieces).astype(np.float64, copy=False)
    deaths = deaths[np.isfinite(deaths)]
    deaths = deaths[(deaths > 0.0) & (deaths < (1.0 - TOL))]
    if deaths.size < 10:
        raise ValueError(f"Too few training deaths to build adaptive intervals: {deaths.size}")

    quantiles = np.arange(float(percentile_step), 100.0, float(percentile_step), dtype=np.float64)
    quantiles = quantiles[(quantiles > 0.0) & (quantiles < 100.0)]
    percentile_bounds = np.percentile(deaths, quantiles)
    raw = np.concatenate(([0.0], percentile_bounds, [1.0]))
    raw = np.clip(raw[np.isfinite(raw)], 0.0, 1.0)
    raw.sort()

    unique = [0.0]
    for value in raw:
        value = float(value)
        if value <= 0.0 or value >= 1.0:
            continue
        if value > unique[-1] + min_interval_width:
            unique.append(value)
    if 1.0 > unique[-1] + min_interval_width:
        unique.append(1.0)
    else:
        unique[-1] = 1.0

    bounds = np.asarray(unique, dtype=np.float32)
    if bounds.ndim != 1 or bounds.size < 3:
        raise ValueError(f"Adaptive bounds are too small after duplicate removal: {bounds}")
    if not np.all(np.diff(bounds) > 0.0):
        raise ValueError("Adaptive bounds are not strictly increasing")
    return bounds


def compute_sigma_log(centers: np.ndarray) -> float:
    centers = np.asarray(centers, dtype=np.float64)
    centers = centers[np.isfinite(centers) & (centers > 0.0)]
    if centers.size < 2:
        return 0.1
    log_centers = np.sort(np.log(centers + EPS))
    diffs = np.diff(log_centers)
    diffs = diffs[diffs > 0.0]
    if diffs.size == 0:
        return 0.1
    return float(max(2.0 * np.median(diffs), 1e-4))


def gauss_legendre_nodes_weights(q: int, device: torch.device) -> tuple[torch.Tensor, torch.Tensor]:
    nodes, weights = np.polynomial.legendre.leggauss(q)
    return (
        torch.tensor(nodes, dtype=torch.float32, device=device),
        torch.tensor(weights, dtype=torch.float32, device=device),
    )


def build_interval_quadrature(bounds: np.ndarray, q: int, device: torch.device) -> tuple[torch.Tensor, torch.Tensor]:
    a = torch.tensor(bounds[:-1], dtype=torch.float32, device=device)
    b = torch.tensor(bounds[1:], dtype=torch.float32, device=device)
    nodes, weights = gauss_legendre_nodes_weights(q, device)
    half = 0.5 * (b - a)
    mid = 0.5 * (a + b)
    x_points = half.unsqueeze(1) * nodes.unsqueeze(0) + mid.unsqueeze(1)
    w_points = half.unsqueeze(1) * weights.unsqueeze(0)
    return x_points, w_points


class BinnedH0Dataset(Dataset):
    def __init__(self, bundle: H0DatasetBundle, indices: np.ndarray, bounds: np.ndarray):
        self.bundle = bundle
        self.indices = np.asarray(indices, dtype=int)
        self.bounds = np.asarray(bounds, dtype=np.float32)
        self.n_intervals = int(len(self.bounds) - 1)

    def __len__(self) -> int:
        return int(len(self.indices))

    def __getitem__(self, local_idx: int):
        global_idx = int(self.indices[local_idx])
        deaths = self.bundle.deaths_list[global_idx]
        if deaths.size:
            upper = np.nextafter(self.bounds[-1], self.bounds[0], dtype=np.float32)
            d = np.clip(deaths, self.bounds[0], upper).astype(np.float32, copy=False)
            bins = np.searchsorted(self.bounds, d, side="right") - 1
            bins = np.clip(bins, 0, self.n_intervals - 1).astype(np.int64, copy=False)
        else:
            d = np.zeros((0,), dtype=np.float32)
            bins = np.zeros((0,), dtype=np.int64)
        return (
            torch.from_numpy(d),
            torch.from_numpy(bins),
            torch.tensor(int(self.bundle.labels[global_idx]), dtype=torch.int64),
            self.bundle.sample_ids[global_idx],
            self.bundle.participant_ids[global_idx],
            global_idx,
        )


def pad_collate(batch):
    deaths_list, bins_list, labels, sample_ids, participant_ids, global_indices = zip(*batch)
    batch_size = len(batch)
    max_count = max(max(int(x.shape[0]) for x in deaths_list), 1)
    deaths_pad = torch.zeros((batch_size, max_count), dtype=torch.float32)
    bins_pad = torch.zeros((batch_size, max_count), dtype=torch.int64)
    mask = torch.zeros((batch_size, max_count), dtype=torch.float32)
    for idx, (deaths, bins) in enumerate(zip(deaths_list, bins_list)):
        count = int(deaths.shape[0])
        if count:
            deaths_pad[idx, :count] = deaths
            bins_pad[idx, :count] = bins
            mask[idx, :count] = 1.0
    return (
        deaths_pad,
        bins_pad,
        mask,
        torch.stack(labels),
        list(sample_ids),
        list(participant_ids),
        np.asarray(global_indices, dtype=int),
    )


def make_loader(
    bundle: H0DatasetBundle,
    indices: np.ndarray,
    bounds: np.ndarray,
    batch_size: int,
    shuffle: bool,
    seed: int,
    num_workers: int,
) -> DataLoader:
    generator = torch.Generator()
    generator.manual_seed(seed)
    dataset = BinnedH0Dataset(bundle, indices, bounds)
    return DataLoader(
        dataset,
        batch_size=batch_size,
        shuffle=shuffle,
        collate_fn=pad_collate,
        generator=generator,
        num_workers=num_workers,
        pin_memory=torch.cuda.is_available(),
        persistent_workers=bool(num_workers > 0),
    )


# -----------------------------------------------------------------------------
# Alpha-Pi model and losses
# -----------------------------------------------------------------------------


class AlphaPiModel(nn.Module):
    def __init__(
        self,
        n_intervals: int,
        n_classes: int,
        bounds: np.ndarray,
        sigma_log: float,
        quad_points: int,
        point_chunk: int,
        device: torch.device,
    ):
        super().__init__()
        self.n_intervals = int(n_intervals)
        self.n_classes = int(n_classes)
        self.sigma_log = float(sigma_log)
        self.quad_points = int(quad_points)
        self.point_chunk = int(point_chunk)
        self.raw_alpha = nn.Parameter(
            torch.full((self.n_intervals,), inverse_softplus(1.0), dtype=torch.float32)
        )
        self.centers = nn.Parameter(torch.zeros(self.n_classes, self.n_intervals, dtype=torch.float32))
        self.clf_head = nn.Linear(self.n_intervals, self.n_classes)
        x_points, w_points = build_interval_quadrature(bounds, self.quad_points, device)
        self.register_buffer("x_points", x_points)
        self.register_buffer("w_points", w_points)

    def alpha_positive(self) -> torch.Tensor:
        return F.softplus(self.raw_alpha) + 1e-8

    def compute_z(self, deaths: torch.Tensor, bins: torch.Tensor, mask: torch.Tensor) -> torch.Tensor:
        batch_size, _ = deaths.shape
        n_intervals, quad_points = self.x_points.shape
        if n_intervals != self.n_intervals:
            raise RuntimeError("Quadrature interval count differs from model interval count")

        log_deaths = torch.log(deaths + EPS)
        alpha_per_death = self.alpha_positive()[bins] * mask
        x_flat = self.x_points.reshape(-1)
        w_flat = self.w_points.reshape(-1)
        log_x_flat = torch.log(x_flat + EPS)
        total_points = int(log_x_flat.shape[0])
        inv_two_sigma_sq = 1.0 / (2.0 * self.sigma_log * self.sigma_log)
        out = torch.zeros((batch_size, total_points), dtype=torch.float32, device=deaths.device)

        for start in range(0, total_points, self.point_chunk):
            end = min(total_points, start + self.point_chunk)
            log_x = log_x_flat[start:end]
            diff = log_x.view(1, 1, -1) - log_deaths.unsqueeze(2)
            phi = torch.exp(-(diff * diff) * inv_two_sigma_sq)
            out[:, start:end] = (phi * alpha_per_death.unsqueeze(2)).sum(dim=1)

        out = out.view(batch_size, n_intervals, quad_points)
        weights = w_flat.view(n_intervals, quad_points).unsqueeze(0)
        return (out * weights).sum(dim=2)

    def forward(self, deaths: torch.Tensor, bins: torch.Tensor, mask: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor]:
        z = self.compute_z(deaths, bins, mask)
        return z, self.clf_head(z)

    def distances_to_centers(self, z: torch.Tensor) -> torch.Tensor:
        return torch.sum((z.unsqueeze(1) - self.centers.unsqueeze(0)) ** 2, dim=2)

    def alpha_pi_loss(self, z: torch.Tensor, y: torch.Tensor, margin_between: float) -> tuple[torch.Tensor, dict[str, torch.Tensor]]:
        distances_sq = self.distances_to_centers(z)
        own_sq = torch.gather(distances_sq, 1, y.view(-1, 1)).view(-1)
        within = own_sq.mean()

        center_diffs = self.centers.unsqueeze(0) - self.centers.unsqueeze(1)
        center_distances = torch.sqrt(torch.sum(center_diffs ** 2, dim=2) + 1e-12)
        masked = center_distances + torch.eye(self.n_classes, device=z.device) * 1e9
        nearest_other = masked.min(dim=1).values
        own_distance = torch.sqrt(own_sq + 1e-12)
        radius = F.relu(own_distance - 0.5 * nearest_other[y]).pow(2).mean()

        if self.n_classes > 1:
            i_idx, j_idx = torch.triu_indices(self.n_classes, self.n_classes, offset=1, device=z.device)
            pair_distances = center_distances[i_idx, j_idx]
            between = F.relu(float(margin_between) - pair_distances).pow(4).mean()
        else:
            between = torch.tensor(0.0, device=z.device)
        return within, {"within": within, "radius": radius, "between": between}


def nearest_centroid_probabilities(model: AlphaPiModel, z: torch.Tensor) -> tuple[torch.Tensor, torch.Tensor]:
    distance_sq = model.distances_to_centers(z)
    return torch.argmin(distance_sq, dim=1), F.softmax(-distance_sq, dim=1)


def make_ce_loss(labels: np.ndarray, n_classes: int, device: torch.device) -> nn.CrossEntropyLoss:
    counts = np.bincount(np.asarray(labels, dtype=int), minlength=n_classes).astype(np.float64)
    inverse = 1.0 / np.maximum(counts, 1.0)
    weights = inverse * (n_classes / inverse.sum())
    return nn.CrossEntropyLoss(weight=torch.tensor(weights, dtype=torch.float32, device=device))


def combine_loss(
    ce: torch.Tensor,
    parts: dict[str, torch.Tensor],
    lambda_ce: float,
    lambda_within: float,
    lambda_radius: float,
    lambda_between: float,
) -> torch.Tensor:
    return (
        float(lambda_ce) * ce
        + float(lambda_within) * parts["within"]
        + float(lambda_radius) * parts["radius"]
        + float(lambda_between) * parts["between"]
    )


# -----------------------------------------------------------------------------
# Metrics and evaluation
# -----------------------------------------------------------------------------


def binary_metrics(y_true: np.ndarray, probability_ibd: np.ndarray) -> dict[str, float]:
    y_true = np.asarray(y_true, dtype=int)
    probability_ibd = np.asarray(probability_ibd, dtype=float)
    prediction = (probability_ibd >= 0.5).astype(int)
    cm = confusion_matrix(y_true, prediction, labels=[0, 1])
    tn, fp, fn, tp = cm.ravel()
    result = {
        "accuracy": float(accuracy_score(y_true, prediction)),
        "balanced_accuracy": float(balanced_accuracy_score(y_true, prediction)),
        "macro_f1": float(f1_score(y_true, prediction, average="macro", zero_division=0)),
        "positive_f1": float(f1_score(y_true, prediction, pos_label=1, zero_division=0)),
        "recall_nonibd": float(tn / max(tn + fp, 1)),
        "recall_ibd": float(tp / max(tp + fn, 1)),
        "brier": float(brier_score_loss(y_true, probability_ibd)),
    }
    try:
        result["roc_auc"] = float(roc_auc_score(y_true, probability_ibd))
    except Exception:
        result["roc_auc"] = np.nan
    try:
        result["log_loss"] = float(log_loss(y_true, np.column_stack([1.0 - probability_ibd, probability_ibd]), labels=[0, 1]))
    except Exception:
        result["log_loss"] = np.nan
    return result


def participant_predictions(sample_predictions: pd.DataFrame) -> pd.DataFrame:
    grouped = sample_predictions.groupby("participant_id", sort=False)
    rows: list[dict[str, Any]] = []
    for participant_id, group in grouped:
        labels = group["true_idx"].unique()
        if len(labels) != 1:
            raise ValueError(f"Participant {participant_id} has multiple labels in predictions")
        probability = float(group["probability_ibd"].mean())
        centroid_probability = float(group["centroid_probability_ibd"].mean())
        rows.append(
            {
                "participant_id": str(participant_id),
                "true_idx": int(labels[0]),
                "true_label": LABEL_ORDER[int(labels[0])],
                "n_samples": int(len(group)),
                "probability_ibd": probability,
                "pred_idx": int(probability >= 0.5),
                "pred_label": LABEL_ORDER[int(probability >= 0.5)],
                "centroid_probability_ibd": centroid_probability,
            }
        )
    return pd.DataFrame(rows)


def calibration_table(y_true: np.ndarray, probabilities: np.ndarray, n_bins: int = 10) -> pd.DataFrame:
    y_true = np.asarray(y_true, dtype=int)
    probabilities = np.asarray(probabilities, dtype=float)
    edges = np.linspace(0.0, 1.0, n_bins + 1)
    bins = np.clip(np.digitize(probabilities, edges[1:-1], right=False), 0, n_bins - 1)
    rows = []
    for bin_idx in range(n_bins):
        mask = bins == bin_idx
        rows.append(
            {
                "bin": bin_idx + 1,
                "lower": float(edges[bin_idx]),
                "upper": float(edges[bin_idx + 1]),
                "n": int(mask.sum()),
                "mean_probability": float(np.mean(probabilities[mask])) if mask.any() else np.nan,
                "observed_fraction_ibd": float(np.mean(y_true[mask])) if mask.any() else np.nan,
            }
        )
    return pd.DataFrame(rows)


def evaluate_model(
    model: AlphaPiModel,
    loader: DataLoader,
    ce_loss: nn.CrossEntropyLoss,
    device: torch.device,
    args: argparse.Namespace,
    return_latents: bool,
) -> dict[str, Any]:
    model.eval()
    total_loss = 0.0
    total_ce = 0.0
    total_within = 0.0
    total_radius = 0.0
    total_between = 0.0
    total_examples = 0
    y_true_parts = []
    y_pred_parts = []
    probability_parts = []
    centroid_probability_parts = []
    sample_ids: list[str] = []
    participant_ids: list[str] = []
    global_indices_parts = []
    z_parts = []
    interval_contribution_parts = []
    logit_difference_parts = []

    with torch.no_grad():
        for deaths, bins, mask, labels, sids, pids, global_indices in loader:
            deaths = deaths.to(device, non_blocking=True)
            bins = bins.to(device, non_blocking=True)
            mask = mask.to(device, non_blocking=True)
            labels = labels.to(device, non_blocking=True)
            z, logits = model(deaths, bins, mask)
            ce = ce_loss(logits, labels)
            _, parts = model.alpha_pi_loss(z, labels, args.margin_between)
            loss = combine_loss(
                ce,
                parts,
                args.lambda_ce,
                args.lambda_within,
                args.lambda_radius,
                args.lambda_between,
            )
            probabilities = F.softmax(logits, dim=1)
            predictions = torch.argmax(probabilities, dim=1)
            _, centroid_probabilities = nearest_centroid_probabilities(model, z)

            batch_size = int(labels.size(0))
            total_examples += batch_size
            total_loss += float(loss.item()) * batch_size
            total_ce += float(ce.item()) * batch_size
            total_within += float(parts["within"].item()) * batch_size
            total_radius += float(parts["radius"].item()) * batch_size
            total_between += float(parts["between"].item()) * batch_size

            y_true_parts.append(labels.cpu().numpy())
            y_pred_parts.append(predictions.cpu().numpy())
            probability_parts.append(probabilities[:, 1].cpu().numpy())
            centroid_probability_parts.append(centroid_probabilities[:, 1].cpu().numpy())
            sample_ids.extend(sids)
            participant_ids.extend(pids)
            global_indices_parts.append(np.asarray(global_indices, dtype=int))

            if return_latents:
                delta_weight = model.clf_head.weight[1] - model.clf_head.weight[0]
                contributions = z * delta_weight.view(1, -1)
                logit_difference = logits[:, 1] - logits[:, 0]
                z_parts.append(z.cpu().numpy())
                interval_contribution_parts.append(contributions.cpu().numpy())
                logit_difference_parts.append(logit_difference.cpu().numpy())

    if total_examples == 0:
        raise ValueError("Evaluation loader contained no samples")

    y_true = np.concatenate(y_true_parts)
    y_pred = np.concatenate(y_pred_parts)
    probability_ibd = np.concatenate(probability_parts)
    centroid_probability_ibd = np.concatenate(centroid_probability_parts)
    global_indices = np.concatenate(global_indices_parts)
    metrics = binary_metrics(y_true, probability_ibd)
    try:
        centroid_auc = float(roc_auc_score(y_true, centroid_probability_ibd))
    except Exception:
        centroid_auc = np.nan

    predictions = pd.DataFrame(
        {
            "sample_id": sample_ids,
            "participant_id": participant_ids,
            "global_index": global_indices,
            "true_idx": y_true,
            "true_label": [LABEL_ORDER[int(x)] for x in y_true],
            "pred_idx": y_pred,
            "pred_label": [LABEL_ORDER[int(x)] for x in y_pred],
            "probability_ibd": probability_ibd,
            "centroid_probability_ibd": centroid_probability_ibd,
        }
    )

    result = {
        "metrics": metrics,
        "centroid_roc_auc": centroid_auc,
        "mean_loss": total_loss / total_examples,
        "mean_ce": total_ce / total_examples,
        "mean_within": total_within / total_examples,
        "mean_radius": total_radius / total_examples,
        "mean_between": total_between / total_examples,
        "predictions": predictions,
    }
    if return_latents:
        result["z"] = np.vstack(z_parts)
        result["interval_contributions"] = np.vstack(interval_contribution_parts)
        result["logit_difference"] = np.concatenate(logit_difference_parts)
    return result


