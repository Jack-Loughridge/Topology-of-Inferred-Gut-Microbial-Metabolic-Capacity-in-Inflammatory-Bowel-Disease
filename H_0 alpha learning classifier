    atomic_to_csv(influence, final_dir / "interpretation_curves.csv", index=False)

    sample_metrics = test_evaluation["metrics"]
    result = {
        "repeat": repeat_idx,
        "fold": fold_idx,
        "selected_percentile_step": percentile_step,
        "selected_inner_n_intervals": int(selected["n_intervals"]),
        "final_outer_n_intervals": int(len(bounds) - 1),
        "selected_epoch": epochs,
        "selected_epoch_at_limit": bool(selected["best_epoch_at_limit"]),
        "seed": seed,
        "n_outer_train_samples": int(len(outer_train_idx)),
        "n_outer_test_samples": int(len(outer_test_idx)),
        "n_outer_train_participants": int(len(set(np.asarray(bundle.participant_ids)[outer_train_idx]))),
        "n_outer_test_participants": int(len(set(np.asarray(bundle.participant_ids)[outer_test_idx]))),
        **{f"test_sample_{key}": float(value) for key, value in sample_metrics.items()},
