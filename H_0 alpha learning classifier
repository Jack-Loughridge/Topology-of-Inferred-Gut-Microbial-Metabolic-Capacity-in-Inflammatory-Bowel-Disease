def indices_for_outer_fold(
    manifest: pd.DataFrame,
    sample_to_index: dict[str, int],
    repeat_idx: int,
    fold_idx: int,
) -> tuple[np.ndarray, np.ndarray, int]:
    rows = manifest[(manifest["repeat"] == repeat_idx) & (manifest["fold"] == fold_idx)]
    train_ids = rows.loc[rows["role"] == "train", "sample_id"].astype(str).tolist()
    test_ids = rows.loc[rows["role"] == "test", "sample_id"].astype(str).tolist()
    train_idx = np.asarray([sample_to_index[x] for x in train_ids], dtype=int)
    test_idx = np.asarray([sample_to_index[x] for x in test_ids], dtype=int)
    split_seed = int(rows["split_seed"].iloc[0])
    return train_idx, test_idx, split_seed


def inner_split(
    outer_train_idx: np.ndarray,
    bundle: H0DatasetBundle,
    repeat_idx: int,
    fold_idx: int,
    args: argparse.Namespace,
) -> tuple[np.ndarray, np.ndarray, int]:
    y = bundle.labels[outer_train_idx]
    groups = np.asarray(bundle.participant_ids, dtype=str)[outer_train_idx]
    seed = int(args.inner_split_seed + repeat_idx * 10_007 + fold_idx * 101)
    splitter = StratifiedGroupKFold(
        n_splits=args.inner_splits,
        shuffle=True,
        random_state=seed,
    )
    splits = list(splitter.split(np.zeros(len(outer_train_idx), dtype=np.uint8), y, groups))
    if not splits:
        raise RuntimeError("No inner split generated")
    inner_train_rel, validation_rel = splits[0]
    inner_train_idx = outer_train_idx[inner_train_rel]
    validation_idx = outer_train_idx[validation_rel]

    train_participants = set(np.asarray(bundle.participant_ids)[inner_train_idx])
    validation_participants = set(np.asarray(bundle.participant_ids)[validation_idx])
    if train_participants & validation_participants:
        raise RuntimeError("Participant leakage in inner split")
    if set(bundle.labels[inner_train_idx]) != {0, 1} or set(bundle.labels[validation_idx]) != {0, 1}:
        raise RuntimeError("A class is absent from the inner train or validation split")
    return inner_train_idx, validation_idx, seed


def write_split_diagnostics(
    path: Path,
    bundle: H0DatasetBundle,
    repeat_idx: int,
    fold_idx: int,
    outer_train_idx: np.ndarray,
    outer_test_idx: np.ndarray,
    inner_train_idx: np.ndarray,
    validation_idx: np.ndarray,
    outer_split_seed: int,
    inner_seed: int,
) -> None:
    rows = []
    memberships = [
        ("inner_train", inner_train_idx),
        ("validation", validation_idx),
        ("outer_test", outer_test_idx),
    ]
    for role, indices in memberships:
        for idx in indices:
            rows.append(
                {
                    "repeat": repeat_idx,
                    "fold": fold_idx,
                    "role": role,
                    "sample_id": bundle.sample_ids[int(idx)],
                    "participant_id": bundle.participant_ids[int(idx)],
                    "label": int(bundle.labels[int(idx)]),
                    "label_name": LABEL_ORDER[int(bundle.labels[int(idx)])],
                    "outer_split_seed": outer_split_seed,
                    "inner_split_seed": inner_seed,
                }
            )
    atomic_to_csv(pd.DataFrame(rows), path, index=False)


