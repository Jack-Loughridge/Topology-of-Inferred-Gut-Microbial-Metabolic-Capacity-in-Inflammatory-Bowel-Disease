    return parser


if __name__ == "__main__":
    parsed = make_parser().parse_args()
    if parsed.inner_splits < 2:
        raise ValueError("--inner-splits must be at least 2")
    if parsed.epochs < 1:
        raise ValueError("--epochs must be at least 1")
    main(parsed)
