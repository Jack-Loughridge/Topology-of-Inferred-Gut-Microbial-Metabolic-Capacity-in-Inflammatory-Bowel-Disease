        "logit_delta_weight_l1": float(np.abs(delta_weight).sum()),
        "logit_delta_weight_l2": float(np.linalg.norm(delta_weight)),
        "logit_delta_intercept": delta_intercept,
        "center_distance": float(torch.linalg.vector_norm(model.centers[1] - model.centers[0]).item()),
        "elapsed_seconds_final_refit": float(time.time() - started),
