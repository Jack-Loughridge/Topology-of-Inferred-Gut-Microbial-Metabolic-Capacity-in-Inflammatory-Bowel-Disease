def aggregate_curves(all_curves: pd.DataFrame) -> pd.DataFrame:
    rows = []
    for death_value, group in all_curves.groupby("death_value", sort=True):
        alpha_raw = group["alpha_raw_piecewise"].to_numpy(dtype=float)
        alpha_norm = group["alpha_normalized_mean1_loggrid"].to_numpy(dtype=float)
        influence = group["signed_single_death_logit_influence"].to_numpy(dtype=float)
        rows.append(
            {
                "death_value": float(death_value),
                "n_models": int(len(group)),
                "alpha_raw_mean": float(np.mean(alpha_raw)),
                "alpha_raw_sd": float(np.std(alpha_raw, ddof=1)) if len(alpha_raw) > 1 else 0.0,
                "alpha_raw_median": float(np.median(alpha_raw)),
                "alpha_raw_q025": float(np.quantile(alpha_raw, 0.025)),
                "alpha_raw_q25": float(np.quantile(alpha_raw, 0.25)),
                "alpha_raw_q75": float(np.quantile(alpha_raw, 0.75)),
                "alpha_raw_q975": float(np.quantile(alpha_raw, 0.975)),
                "alpha_norm_mean": float(np.mean(alpha_norm)),
                "alpha_norm_sd": float(np.std(alpha_norm, ddof=1)) if len(alpha_norm) > 1 else 0.0,
                "alpha_norm_median": float(np.median(alpha_norm)),
                "alpha_norm_q025": float(np.quantile(alpha_norm, 0.025)),
                "alpha_norm_q25": float(np.quantile(alpha_norm, 0.25)),
                "alpha_norm_q75": float(np.quantile(alpha_norm, 0.75)),
                "alpha_norm_q975": float(np.quantile(alpha_norm, 0.975)),
                "influence_mean": float(np.mean(influence)),
                "influence_sd": float(np.std(influence, ddof=1)) if len(influence) > 1 else 0.0,
                "influence_median": float(np.median(influence)),
                "influence_q025": float(np.quantile(influence, 0.025)),
                "influence_q25": float(np.quantile(influence, 0.25)),
                "influence_q75": float(np.quantile(influence, 0.75)),
                "influence_q975": float(np.quantile(influence, 0.975)),
                "influence_positive_fraction": float(np.mean(influence > 0.0)),
                "influence_negative_fraction": float(np.mean(influence < 0.0)),
            }
        )
    return pd.DataFrame(rows)


def pooled_repetition_results(
    sample_predictions: pd.DataFrame,
    participant_predictions_df: pd.DataFrame,
    n_repeats: int,
    output_dir: Path,
    calibration_bins: int,
) -> tuple[pd.DataFrame, pd.DataFrame]:
    sample_rows = []
    participant_rows = []
    sample_calibration = []
    participant_calibration = []

    for repeat_idx in range(1, n_repeats + 1):
        sample_rep = sample_predictions[sample_predictions["repeat"] == repeat_idx].copy()
        participant_rep = participant_predictions_df[participant_predictions_df["repeat"] == repeat_idx].copy()
        if sample_rep["sample_id"].duplicated().any():
            raise RuntimeError(f"Sample appears more than once in pooled OOF predictions for repeat {repeat_idx}")
        if participant_rep["participant_id"].duplicated().any():
            raise RuntimeError(f"Participant appears more than once in pooled OOF predictions for repeat {repeat_idx}")

        sample_metric = binary_metrics(sample_rep["true_idx"], sample_rep["probability_ibd"])
        participant_metric = binary_metrics(participant_rep["true_idx"], participant_rep["probability_ibd"])
        sample_cm = confusion_matrix(sample_rep["true_idx"], sample_rep["pred_idx"], labels=[0, 1])
        participant_cm = confusion_matrix(participant_rep["true_idx"], participant_rep["pred_idx"], labels=[0, 1])
        sample_rows.append({"repeat": repeat_idx, **sample_metric, "tn": int(sample_cm[0, 0]), "fp": int(sample_cm[0, 1]), "fn": int(sample_cm[1, 0]), "tp": int(sample_cm[1, 1])})
        participant_rows.append({"repeat": repeat_idx, **participant_metric, "tn": int(participant_cm[0, 0]), "fp": int(participant_cm[0, 1]), "fn": int(participant_cm[1, 0]), "tp": int(participant_cm[1, 1])})

        sc = calibration_table(sample_rep["true_idx"].to_numpy(), sample_rep["probability_ibd"].to_numpy(), calibration_bins)
        sc.insert(0, "repeat", repeat_idx)
        sample_calibration.append(sc)
        pc = calibration_table(participant_rep["true_idx"].to_numpy(), participant_rep["probability_ibd"].to_numpy(), calibration_bins)
        pc.insert(0, "repeat", repeat_idx)
        participant_calibration.append(pc)

    sample_results = pd.DataFrame(sample_rows)
    participant_results = pd.DataFrame(participant_rows)
    atomic_to_csv(sample_results, output_dir / "repetition_pooled_oof_sample_metrics.csv", index=False)
    atomic_to_csv(participant_results, output_dir / "repetition_pooled_oof_participant_metrics.csv", index=False)
    atomic_to_csv(pd.concat(sample_calibration, ignore_index=True), output_dir / "repetition_calibration_sample.csv", index=False)
    atomic_to_csv(pd.concat(participant_calibration, ignore_index=True), output_dir / "repetition_calibration_participant.csv", index=False)
    return sample_results, participant_results


def performance_summary(sample_results: pd.DataFrame, participant_results: pd.DataFrame) -> pd.DataFrame:
    metric_names = ["accuracy", "balanced_accuracy", "macro_f1", "positive_f1", "recall_nonibd", "recall_ibd", "roc_auc", "brier", "log_loss"]
    rows = []
    for level, frame in [("sample", sample_results), ("participant", participant_results)]:
        row: dict[str, Any] = {"level": level, "n_repetitions": int(len(frame))}
        for metric in metric_names:
            row.update(summarize_numeric(frame[metric], metric))
        rows.append(row)
    return pd.DataFrame(rows)


def consensus_predictions(sample_predictions: pd.DataFrame, participant_predictions_df: pd.DataFrame, output_dir: Path) -> None:
    sample_consensus = (
        sample_predictions.groupby(["sample_id", "participant_id", "true_idx", "true_label"], as_index=False)
        .agg(
            n_repetitions=("repeat", "nunique"),
            probability_ibd_mean=("probability_ibd", "mean"),
            probability_ibd_sd=("probability_ibd", "std"),
            probability_ibd_min=("probability_ibd", "min"),
            probability_ibd_max=("probability_ibd", "max"),
        )
    )
    sample_consensus["consensus_pred_idx"] = (sample_consensus["probability_ibd_mean"] >= 0.5).astype(int)
    sample_consensus["consensus_pred_label"] = sample_consensus["consensus_pred_idx"].map({0: "non-IBD", 1: "IBD"})
    atomic_to_csv(sample_consensus, output_dir / "consensus_prediction_by_sample_across_repetitions.csv", index=False)

    participant_consensus = (
        participant_predictions_df.groupby(["participant_id", "true_idx", "true_label"], as_index=False)
        .agg(
            n_repetitions=("repeat", "nunique"),
            n_samples=("n_samples", "first"),
            probability_ibd_mean=("probability_ibd", "mean"),
            probability_ibd_sd=("probability_ibd", "std"),
            probability_ibd_min=("probability_ibd", "min"),
            probability_ibd_max=("probability_ibd", "max"),
        )
    )
    participant_consensus["consensus_pred_idx"] = (participant_consensus["probability_ibd_mean"] >= 0.5).astype(int)
    participant_consensus["consensus_pred_label"] = participant_consensus["consensus_pred_idx"].map({0: "non-IBD", 1: "IBD"})
    atomic_to_csv(participant_consensus, output_dir / "consensus_prediction_by_participant_across_repetitions.csv", index=False)


def write_partial_progress(
    output_dir: Path,
    bundle: H0DatasetBundle,
    fold_results: list[dict[str, Any]],
    sample_prediction_frames: list[pd.DataFrame],
    participant_prediction_frames: list[pd.DataFrame],
    candidate_frames: list[pd.DataFrame],
    n_splits: int,
) -> None:
    """Write restart-independent, user-readable progress after every outer fold."""
    partial_dir = output_dir / "partial_progress"
    partial_dir.mkdir(parents=True, exist_ok=True)
    fold_frame = pd.DataFrame(fold_results).sort_values(["repeat", "fold"]).reset_index(drop=True)
    sample_predictions = pd.concat(sample_prediction_frames, ignore_index=True).sort_values(["repeat", "fold", "sample_id"]).reset_index(drop=True)
    participant_predictions_df = pd.concat(participant_prediction_frames, ignore_index=True).sort_values(["repeat", "fold", "participant_id"]).reset_index(drop=True)
    candidates = pd.concat(candidate_frames, ignore_index=True).sort_values(["repeat", "fold", "percentile_step"]).reset_index(drop=True)
    atomic_to_csv(fold_frame, partial_dir / "completed_outer_fold_results.csv", index=False)
    atomic_to_csv(sample_predictions, partial_dir / "completed_oof_sample_predictions.csv", index=False)
    atomic_to_csv(participant_predictions_df, partial_dir / "completed_oof_participant_predictions.csv", index=False)
    atomic_to_csv(candidates, partial_dir / "completed_candidate_validation_results.csv", index=False)

    complete_repeat_rows_sample = []
    complete_repeat_rows_participant = []
    for repeat_idx, repeat_folds in fold_frame.groupby("repeat"):
        if len(repeat_folds) != n_splits:
            continue
        sample_rep = sample_predictions[sample_predictions["repeat"] == repeat_idx]
        participant_rep = participant_predictions_df[participant_predictions_df["repeat"] == repeat_idx]
        if sample_rep["sample_id"].nunique() != len(bundle.sample_ids) or sample_rep["sample_id"].duplicated().any():
            continue
        expected_participants = bundle.metadata["participant_id"].nunique()
        if participant_rep["participant_id"].nunique() != expected_participants or participant_rep["participant_id"].duplicated().any():
            continue
        complete_repeat_rows_sample.append(
            {"repeat": int(repeat_idx), **binary_metrics(sample_rep["true_idx"], sample_rep["probability_ibd"])}
        )
        complete_repeat_rows_participant.append(
            {"repeat": int(repeat_idx), **binary_metrics(participant_rep["true_idx"], participant_rep["probability_ibd"])}
        )
    atomic_to_csv(pd.DataFrame(complete_repeat_rows_sample), partial_dir / "completed_repetition_sample_metrics.csv", index=False)
    atomic_to_csv(pd.DataFrame(complete_repeat_rows_participant), partial_dir / "completed_repetition_participant_metrics.csv", index=False)
    write_json(
        partial_dir / "progress.json",
        {
            "updated_utc": now_iso(),
            "completed_outer_folds": int(len(fold_frame)),
            "completed_repetitions": int(len(complete_repeat_rows_sample)),
            "latest_repeat": int(fold_frame["repeat"].iloc[-1]),
            "latest_fold": int(fold_frame["fold"].iloc[-1]),
        },
    )


def aggregate_outputs(
    output_dir: Path,
    bundle: H0DatasetBundle,
    fold_results: list[dict[str, Any]],
    all_sample_predictions: list[pd.DataFrame],
    all_participant_predictions: list[pd.DataFrame],
    all_curves: list[pd.DataFrame],
    all_candidate_results: list[pd.DataFrame],
    n_repeats: int,
    n_splits: int,
    args: argparse.Namespace,
) -> None:
    fold_frame = pd.DataFrame(fold_results).sort_values(["repeat", "fold"]).reset_index(drop=True)
    sample_predictions = pd.concat(all_sample_predictions, ignore_index=True).sort_values(["repeat", "fold", "sample_id"]).reset_index(drop=True)
    participant_predictions_df = pd.concat(all_participant_predictions, ignore_index=True).sort_values(["repeat", "fold", "participant_id"]).reset_index(drop=True)
    curves = pd.concat(all_curves, ignore_index=True)
    candidates = pd.concat(all_candidate_results, ignore_index=True).sort_values(["repeat", "fold", "percentile_step"]).reset_index(drop=True)

    expected_folds = n_repeats * n_splits
    if len(fold_frame) != expected_folds:
        raise RuntimeError(f"Expected {expected_folds} completed folds, found {len(fold_frame)}")
    if sample_predictions.groupby("repeat")["sample_id"].nunique().min() != len(bundle.sample_ids):
        raise RuntimeError("At least one repetition does not contain one OOF prediction per sample")
    if participant_predictions_df.groupby("repeat")["participant_id"].nunique().min() != bundle.metadata["participant_id"].nunique():
        raise RuntimeError("At least one repetition does not contain one OOF prediction per participant")

    atomic_to_csv(fold_frame, output_dir / "all_outer_fold_results.csv", index=False)
    atomic_to_csv(sample_predictions, output_dir / "all_oof_sample_predictions.csv", index=False)
    atomic_to_csv(participant_predictions_df, output_dir / "all_oof_participant_predictions.csv", index=False)
    atomic_to_csv(candidates, output_dir / "all_candidate_validation_results.csv", index=False)
    atomic_to_csv(bundle.metadata, output_dir / "analysis_sample_metadata.csv", index=False)

    sample_results, participant_results = pooled_repetition_results(
        sample_predictions,
        participant_predictions_df,
        n_repeats,
        output_dir,
        args.calibration_bins,
    )
    summary = performance_summary(sample_results, participant_results)
    atomic_to_csv(summary, output_dir / "performance_summary_across_repetitions.csv", index=False)
    consensus_predictions(sample_predictions, participant_predictions_df, output_dir)

    selection_summary = (
        fold_frame.groupby("selected_percentile_step")
        .agg(
            n_folds=("fold", "size"),
            fraction_folds=("fold", lambda s: len(s) / len(fold_frame)),
            selected_epoch_mean=("selected_epoch", "mean"),
            selected_epoch_sd=("selected_epoch", "std"),
            final_intervals_mean=("final_outer_n_intervals", "mean"),
            final_intervals_sd=("final_outer_n_intervals", "std"),
            test_sample_balanced_accuracy_mean=("test_sample_balanced_accuracy", "mean"),
            test_sample_roc_auc_mean=("test_sample_roc_auc", "mean"),
        )
        .reset_index()
        .sort_values("selected_percentile_step")
    )
    atomic_to_csv(selection_summary, output_dir / "selected_resolution_summary.csv", index=False)

    candidate_summary = (
        candidates.groupby("percentile_step")
        .agg(
            n_candidate_fits=("fold", "size"),
            n_selected=("selected", "sum"),
            selection_fraction=("selected", "mean"),
            validation_balanced_accuracy_mean=("validation_balanced_accuracy", "mean"),
            validation_balanced_accuracy_sd=("validation_balanced_accuracy", "std"),
            validation_macro_f1_mean=("validation_macro_f1", "mean"),
            validation_roc_auc_mean=("validation_roc_auc", "mean"),
            best_epoch_mean=("best_epoch", "mean"),
            best_epoch_at_limit_fraction=("best_epoch_at_limit", "mean"),
            n_intervals_mean=("n_intervals", "mean"),
            elapsed_seconds_mean=("elapsed_seconds", "mean"),
        )
        .reset_index()
        .sort_values("percentile_step")
    )
    atomic_to_csv(candidate_summary, output_dir / "candidate_resolution_diagnostics.csv", index=False)

    curve_summary = aggregate_curves(curves)
    atomic_to_csv(curve_summary, output_dir / "interpretation_curve_summary_across_100_models.csv", index=False)
    atomic_to_csv(curves, output_dir / "all_final_model_interpretation_curves.csv", index=False)

    plot_selection_diagnostics(fold_frame, output_dir)
    plot_curve_band(
        curve_summary,
        "alpha_norm_median",
        "alpha_norm_q025",
        "alpha_norm_q975",
        "Normalized alpha (mean 1 per fold model)",
        "Repeated-CV Alpha-Pi representation emphasis",
        output_dir / "alpha_normalized_repeated_cv.png",
    )
    plot_curve_band(
        curve_summary,
        "influence_median",
        "influence_q025",
        "influence_q975",
        "IBD minus non-IBD logit contribution",
        "Signed influence of one H0 death across repeated CV",
        output_dir / "signed_single_death_influence_repeated_cv.png",
        zero_line=True,
    )

    # Aggregate confusion matrices across the consensus mean predictions. This is
    # diagnostic only; the 20 repetition metrics remain primary.
    sample_consensus = pd.read_csv(output_dir / "consensus_prediction_by_sample_across_repetitions.csv")
    participant_consensus = pd.read_csv(output_dir / "consensus_prediction_by_participant_across_repetitions.csv")
    sample_cm = confusion_matrix(sample_consensus["true_idx"], sample_consensus["consensus_pred_idx"], labels=[0, 1])
    participant_cm = confusion_matrix(participant_consensus["true_idx"], participant_consensus["consensus_pred_idx"], labels=[0, 1])
    pd.DataFrame(sample_cm, index=["true_non-IBD", "true_IBD"], columns=["pred_non-IBD", "pred_IBD"]).to_csv(output_dir / "consensus_confusion_sample.csv")
    pd.DataFrame(participant_cm, index=["true_non-IBD", "true_IBD"], columns=["pred_non-IBD", "pred_IBD"]).to_csv(output_dir / "consensus_confusion_participant.csv")
    plot_confusion(sample_cm, output_dir / "consensus_confusion_sample.png", "Consensus sample-level confusion across repetitions")
    plot_confusion(participant_cm, output_dir / "consensus_confusion_participant.png", "Consensus participant-level confusion across repetitions")

    diagnostics = {
        "completed_utc": now_iso(),
        "n_repeats": n_repeats,
        "n_splits": n_splits,
        "n_outer_fold_models": int(len(fold_frame)),
        "n_candidate_models": int(len(candidates)),
        "n_samples": int(len(bundle.sample_ids)),
        "n_participants": int(bundle.metadata["participant_id"].nunique()),
        "selected_epoch_at_limit_fraction": float(fold_frame["selected_epoch_at_limit"].mean()),
        "max_signed_influence_identity_abs_error": float(fold_frame["signed_influence_identity_abs_error"].max()),
        "all_sample_repetitions_complete": bool(sample_predictions.groupby("repeat")["sample_id"].nunique().eq(len(bundle.sample_ids)).all()),
        "all_participant_repetitions_complete": bool(participant_predictions_df.groupby("repeat")["participant_id"].nunique().eq(bundle.metadata["participant_id"].nunique()).all()),
    }
    write_json(output_dir / "RUN_COMPLETE.json", diagnostics)


