def fold_tag(repeat_idx: int, fold_idx: int) -> str:
    return f"repeat_{repeat_idx:02d}_fold_{fold_idx}"


def percentile_tag(value: float) -> str:
    return f"percentile_step_{value:.6g}".replace(".", "p").replace("-", "m")


def load_completed_fold(fold_dir: Path) -> tuple[dict[str, Any], pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    completion = fold_dir / "FOLD_COMPLETE.json"
    result_path = fold_dir / "final_outer_model" / "final_fold_result.json"
    sample_path = fold_dir / "final_outer_model" / "test_predictions_sample.csv"
    participant_path = fold_dir / "final_outer_model" / "test_predictions_participant.csv"
    curves_path = fold_dir / "final_outer_model" / "interpretation_curves.csv"
    required = [completion, result_path, sample_path, participant_path, curves_path]
    if not all(path.exists() for path in required):
        raise FileNotFoundError("Fold completion marker exists but required artifacts are missing")
    return (
        json.loads(result_path.read_text()),
        pd.read_csv(sample_path, dtype={"sample_id": str, "participant_id": str}),
        pd.read_csv(participant_path, dtype={"participant_id": str}),
        pd.read_csv(curves_path),
    )


def run_outer_fold(
    bundle: H0DatasetBundle,
    manifest: pd.DataFrame,
    repeat_idx: int,
    fold_idx: int,
    output_dir: Path,
    device: torch.device,
    args: argparse.Namespace,
) -> tuple[dict[str, Any], pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    fold_dir = output_dir / "folds" / fold_tag(repeat_idx, fold_idx)
    completion_path = fold_dir / "FOLD_COMPLETE.json"
    if args.resume and completion_path.exists():
        result, sample_predictions, participant_predictions_df, curves = load_completed_fold(fold_dir)
        candidate_results = pd.read_csv(fold_dir / "candidate_summary.csv")
        print(f"[resume] Loaded completed {fold_tag(repeat_idx, fold_idx)}", flush=True)
        return result, sample_predictions, participant_predictions_df, curves, candidate_results

    fold_dir.mkdir(parents=True, exist_ok=True)
    outer_train_idx, outer_test_idx, outer_split_seed = indices_for_outer_fold(
        manifest, bundle.sample_to_index, repeat_idx, fold_idx
    )
    inner_train_idx, validation_idx, inner_seed = inner_split(
        outer_train_idx, bundle, repeat_idx, fold_idx, args
    )
    write_split_diagnostics(
        fold_dir / "split_membership.csv",
        bundle,
        repeat_idx,
        fold_idx,
        outer_train_idx,
        outer_test_idx,
        inner_train_idx,
        validation_idx,
        outer_split_seed,
        inner_seed,
    )

    print(
        f"\n[outer {fold_tag(repeat_idx, fold_idx)}] "
        f"inner_train={len(inner_train_idx)} samples/{len(set(np.asarray(bundle.participant_ids)[inner_train_idx]))} participants, "
        f"validation={len(validation_idx)} samples/{len(set(np.asarray(bundle.participant_ids)[validation_idx]))} participants, "
        f"outer_test={len(outer_test_idx)} samples/{len(set(np.asarray(bundle.participant_ids)[outer_test_idx]))} participants",
        flush=True,
    )

    candidate_results = []
    for percentile_step in args.percentile_steps:
        candidate_dir = fold_dir / "candidates" / percentile_tag(percentile_step)
        candidate_results.append(
            fit_candidate(
                bundle,
                inner_train_idx,
                validation_idx,
                percentile_step,
                repeat_idx,
                fold_idx,
                candidate_dir,
                device,
                args,
            )
        )
    candidate_frame = pd.DataFrame(candidate_results)
    selected = choose_candidate(candidate_results)
    candidate_frame["selected"] = np.isclose(
        candidate_frame["percentile_step"].to_numpy(dtype=float),
        float(selected["percentile_step"]),
    )
    atomic_to_csv(candidate_frame, fold_dir / "candidate_summary.csv", index=False)
    write_json(fold_dir / "selected_candidate.json", selected)

    final_result = train_final_model(
        bundle,
        outer_train_idx,
        outer_test_idx,
        selected,
        repeat_idx,
        fold_idx,
        fold_dir,
        device,
        args,
    )
    final_dir = fold_dir / "final_outer_model"
    sample_predictions = pd.read_csv(final_dir / "test_predictions_sample.csv", dtype={"sample_id": str, "participant_id": str})
    participant_predictions_df = pd.read_csv(final_dir / "test_predictions_participant.csv", dtype={"participant_id": str})
    curves = pd.read_csv(final_dir / "interpretation_curves.csv")

    # Strong internal consistency checks before declaring the fold complete.
    try:
        model_package = torch.load(final_dir / "final_outer_model.pt", map_location=device, weights_only=False)
    except TypeError:  # compatibility with older PyTorch versions
        model_package = torch.load(final_dir / "final_outer_model.pt", map_location=device)
    check_model = create_model(np.asarray(model_package["bounds"], dtype=np.float32), device, args)
    check_model.load_state_dict(model_package["state_dict"])
    check_model.eval()
    identity_error = check_influence_identity(check_model, np.asarray(model_package["bounds"], dtype=np.float32), device)
    if identity_error > 1e-5:
        raise RuntimeError(f"Signed influence identity check failed: absolute error={identity_error}")
    final_result["signed_influence_identity_abs_error"] = float(identity_error)
    write_json(final_dir / "final_fold_result.json", final_result)

    write_json(
        completion_path,
        {
            "completed_utc": now_iso(),
            "repeat": repeat_idx,
            "fold": fold_idx,
            "selected_percentile_step": selected["percentile_step"],
            "selected_epoch": selected["best_epoch"],
            "signed_influence_identity_abs_error": identity_error,
        },
    )
    return final_result, sample_predictions, participant_predictions_df, curves, candidate_frame


