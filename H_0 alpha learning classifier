def plot_confusion(cm: np.ndarray, output_path: Path, title: str) -> None:
    fig, ax = plt.subplots(figsize=(6, 5))
    image = ax.imshow(cm, interpolation="nearest")
    fig.colorbar(image, ax=ax)
    ax.set_title(title)
    ax.set_xticks([0, 1], LABEL_ORDER)
    ax.set_yticks([0, 1], LABEL_ORDER)
    ax.set_xlabel("Predicted label")
    ax.set_ylabel("True label")
    threshold = cm.max() / 2.0 if cm.max() else 0.0
    for i in range(2):
        for j in range(2):
            ax.text(j, i, str(int(cm[i, j])), ha="center", va="center", color="white" if cm[i, j] > threshold else "black")
    fig.tight_layout()
    fig.savefig(output_path, dpi=200)
    plt.close(fig)


def plot_curve_band(frame: pd.DataFrame, y_median: str, y_low: str, y_high: str, ylabel: str, title: str, output_path: Path, zero_line: bool = False) -> None:
    fig, ax = plt.subplots(figsize=(10, 5))
    x = frame["death_value"].to_numpy(dtype=float)
    ax.plot(x, frame[y_median].to_numpy(dtype=float), label="median")
    ax.fill_between(x, frame[y_low].to_numpy(dtype=float), frame[y_high].to_numpy(dtype=float), alpha=0.25, label="2.5–97.5% across fold models")
    if zero_line:
        ax.axhline(0.0, linewidth=1.0)
    ax.set_xscale("log")
    ax.set_xlabel("H0 death value")
    ax.set_ylabel(ylabel)
    ax.set_title(title)
    ax.grid(True, alpha=0.3)
    ax.legend()
    fig.tight_layout()
    fig.savefig(output_path, dpi=220)
    plt.close(fig)


