def parse_percentile_steps(text: str) -> list[float]:
    values = [float(x.strip()) for x in text.split(",") if x.strip()]
    if not values:
        raise ValueError("At least one percentile step is required")
    if any(x <= 0.0 or x >= 100.0 for x in values):
        raise ValueError("Percentile steps must lie strictly between 0 and 100")
    if len(set(values)) != len(values):
        raise ValueError("Percentile steps contain duplicates")
    return values


