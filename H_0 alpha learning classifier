    test_evaluation = evaluate_model(model, test_loader, ce_loss, device, args, return_latents=True)
    test_predictions = test_evaluation["predictions"].copy()
    test_predictions.insert(0, "fold", fold_idx)
    test_predictions.insert(0, "repeat", repeat_idx)
