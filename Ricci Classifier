def write_binary_process_tables(selected: pd.DataFrame, spec: dict[str, Any], task_dir: Path, max_process_rows: int):
    rows = []

    for proc, sub in selected.groupby("process"):
        bsub = sub[sub["feature_type"] == "B"]
        ksub = sub[sub["feature_type"] == "K0"]

        rows.append(
            {
                "Process": proc,
                "Total Coeff.": sub["beta_standardised"].abs().sum(),
                "Features": len(sub),
                "Edges": sub["edge"].nunique(),
                "Mean |coeff|": sub["beta_standardised"].abs().mean(),
                "Mean B coeff": bsub["beta_standardised"].mean() if len(bsub) else np.nan,
                "Mean K0 coeff": ksub["beta_standardised"].mean() if len(ksub) else np.nan,
                "% positive K0": 100.0 * (ksub["beta_standardised"] > 0).mean() if len(ksub) else np.nan,
                "K0 features": len(ksub),
            }
        )

    proc_df = pd.DataFrame(rows).sort_values("Total Coeff.", ascending=False)
    proc_df.to_csv(task_dir / "process_coefficient_table.csv", index=False)

    rows = []
    for proc, sub in selected.groupby("process"):
        b_imp = sub.loc[sub["feature_type"] == "B", "average_realised_push"].sum()
        k_imp = sub.loc[sub["feature_type"] == "K0", "average_realised_push"].sum()

        rows.append(
            {
                "Process category": proc,
                "Total imp.": b_imp + k_imp,
                "B imp.": b_imp,
                "K0 imp.": k_imp,
            }
        )

    imp_df = pd.DataFrame(rows).sort_values("Total imp.", ascending=False)
    imp_df.to_csv(task_dir / "process_realised_push_table.csv", index=False)

    write_generic_latex(
        proc_df.head(max_process_rows),
        task_dir / "latex_process_coefficient_table.tex",
        f"Biological process coefficient table for the original-style {spec['display']} Ricci classifier. Coefficients are signed with respect to {spec['label_order'][1]}.",
    )

    write_generic_latex(
        imp_df.head(max_process_rows),
        task_dir / "latex_process_realised_push_table.tex",
        f"Total realised push by process category for the original-style {spec['display']} Ricci classifier.",
    )


def write_multiclass_process_tables(selected: pd.DataFrame, spec: dict[str, Any], task_dir: Path, max_process_rows: int):
    label_order = spec["label_order"]

    rows = []
    for proc, sub in selected.groupby("process"):
