    print("Loaded corrected Ricci feature matrix:")
    print("  sparse shape:", X_sparse.shape)
    print("  sparse nnz  :", X_sparse.nnz)
    print("  metadata rows:", len(meta))
    print("  participants:", meta["participant_id"].nunique())
    print("\nParticipant counts by condition:")
    print(meta.drop_duplicates("participant_id")["cond"].value_counts().to_string())

    print("\nConverting sparse matrix to dense float32 for original-style StandardScaler...", flush=True)
    X_dense = X_sparse.toarray().astype(np.float32, copy=False)
    print("  dense shape:", X_dense.shape)
    print("  dense memory MB:", X_dense.nbytes / 1024**2)

    feature_meta.to_csv(out_dir / "feature_metadata_used.csv", index=False)
    edge_meta.to_csv(out_dir / "edge_metadata_used.csv", index=False)

    results = {}

    for task_key in args.tasks:
        spec = TASKS[task_key]
        task_dir = out_dir / spec["folder"]
        task_dir.mkdir(parents=True, exist_ok=True)

        print("\n" + "=" * 100)
        print("Running original-style Ricci task:", spec["display"])
        print("=" * 100)

        X_task, y, meta_task = make_task_data(X_dense, meta, task_key)

        print(f"Task samples: {len(y)}")
        print(f"Task participants: {meta_task['participant_id'].nunique()}")
        print("Sample counts:")
        print(pd.Series([spec["label_order"][int(v)] for v in y]).value_counts().to_string())

        if args.save_task_feature_tables:
            maybe_save_task_feature_tables(X_task, y, meta_task, feature_meta, spec, task_dir)

        fold_df, pred_df, cm = run_grouped_cv(X_task, y, meta_task, task_key, args, task_dir)

        if not args.skip_single_split:
            original_grouped_train_val_test_and_interpret(
                X_task=X_task,
                y=y,
                meta_task=meta_task,
                feature_meta=feature_meta,
                task_key=task_key,
                args=args,
                task_dir=task_dir,
            )

        results[task_key] = {
            "fold_df": fold_df,
            "cm": cm,
            "task_dir": task_dir,
        }

    write_summary_tables(results, out_dir)
    collect_latex(results, out_dir)

    print("\n[READY] Original-style Ricci all-task run finished.")
    print("Output directory:", out_dir)
    print("Combined LaTeX:", out_dir / "latex_all_original_style_ricci_tables.tex")


if __name__ == "__main__":
    main()
