def run_task(X, matched: pd.DataFrame, task_key: str, args, out_dir: Path):
    spec = TASKS[task_key]
    task_dir = out_dir / spec["folder"]
    task_dir.mkdir(parents=True, exist_ok=True)

    X_task, y, meta_task = task_subset(X, matched, task_key)
    groups = meta_task["participant_id"].to_numpy()
    n_classes = len(spec["class_names"])

    outer_splits = safe_group_splits(y, groups, args.outer_splits, spec["display"] + " outer")
    sgkf = StratifiedGroupKFold(n_splits=outer_splits, shuffle=True, random_state=args.seed)

    fold_rows = []
    all_true = []
    all_pred = []
    pred_rows = []
    selected_rows = []
    all_val_rows = []

    for fold, (tr, te) in enumerate(sgkf.split(X_task, y, groups), start=1):
        print(f"\n[{spec['display']}] outer fold {fold}/{outer_splits}", flush=True)

        selected, val_df = select_hyperparameters(
            X_train=X_task[tr],
            y_train=y[tr],
            groups_train=groups[tr],
            n_classes=n_classes,
            task_display=spec["display"],
            args=args,
        )

        val_df.insert(0, "outer_fold", fold)
        all_val_rows.append(val_df)

        model = make_model(
            C=selected["C"],
            class_weight_name=selected["class_weight"],
            max_iter=args.max_iter,
            tol=args.tol,
            seed=args.seed + fold,
            n_jobs=args.n_jobs,
        )

        with warnings.catch_warnings(record=True) as caught:
            warnings.simplefilter("always", ConvergenceWarning)
            model.fit(X_task[tr], y[tr])
            conv = any(isinstance(w.message, ConvergenceWarning) for w in caught)

        pred = model.predict(X_task[te])
        proba = model.predict_proba(X_task[te])
        metrics = score_predictions(y[te], pred, proba, n_classes)

        nnz = int(np.count_nonzero(np.abs(model.coef_) > 1e-12))

        row = {
            "fold": fold,
            "train_samples": int(len(tr)),
            "test_samples": int(len(te)),
            "train_participants": int(len(set(groups[tr]))),
            "test_participants": int(len(set(groups[te]))),
            "selected_C": selected["C"],
            "selected_class_weight": selected["class_weight"],
            "inner_val_balanced_accuracy": selected["val_balanced_accuracy"],
            "inner_val_macro_f1": selected["val_macro_f1"],
            "inner_val_roc_auc": selected["val_roc_auc"],
            "accuracy": metrics["accuracy"],
            "balanced_accuracy": metrics["balanced_accuracy"],
            "macro_f1": metrics["macro_f1"],
            "roc_auc": metrics["roc_auc"],
            "n_nonzero_coefficients": nnz,
            "convergence_warning": bool(conv),
        }
        fold_rows.append(row)

        selected_rows.append(
            {
                "fold": fold,
                "C": selected["C"],
                "class_weight": selected["class_weight"],
                "inner_val_balanced_accuracy": selected["val_balanced_accuracy"],
                "inner_val_macro_f1": selected["val_macro_f1"],
                "inner_val_roc_auc": selected["val_roc_auc"],
            }
        )

        all_true.extend(y[te].tolist())
        all_pred.extend(pred.tolist())

        for local_idx, yy, pp, prob in zip(te, y[te], pred, proba):
            prow = {
                "fold": fold,
                "sample_id": meta_task.iloc[local_idx]["sample_id"],
                "participant_id": meta_task.iloc[local_idx]["participant_id"],
                "true_label": spec["class_names"][int(yy)],
                "pred_label": spec["class_names"][int(pp)],
            }
            for ci, cname in enumerate(spec["class_names"]):
                prow[f"proba_{cname}"] = float(prob[ci])
            pred_rows.append(prow)

        print(
            f"  selected C={selected['C']}, class_weight={selected['class_weight']} | "
            f"test acc={metrics['accuracy']:.3f}, bacc={metrics['balanced_accuracy']:.3f}, "
            f"f1={metrics['macro_f1']:.3f}, auc={metrics['roc_auc']:.3f}",
            flush=True,
        )

    fold_df = pd.DataFrame(fold_rows)
    selected_df = pd.DataFrame(selected_rows)
    val_all = pd.concat(all_val_rows, axis=0, ignore_index=True) if all_val_rows else pd.DataFrame()
    pred_df = pd.DataFrame(pred_rows)

    cm = confusion_matrix(all_true, all_pred, labels=list(range(n_classes)))

    fold_df.to_csv(task_dir / "nested_outer_fold_results.csv", index=False)
    selected_df.to_csv(task_dir / "selected_hyperparameters_by_outer_fold.csv", index=False)
    val_all.to_csv(task_dir / "inner_validation_grid_results.csv", index=False)
    pred_df.to_csv(task_dir / "outer_test_predictions.csv", index=False)
    pd.DataFrame(cm, index=spec["class_names"], columns=spec["class_names"]).to_csv(task_dir / "outer_test_confusion_matrix.csv")

    write_fold_latex(fold_df, spec, task_dir / "latex_nested_outer_fold_results.tex")
    write_confusion_latex(cm, spec["class_names"], spec["display"], task_dir / "latex_outer_test_confusion_matrix.tex")

    return {
        "task_key": task_key,
        "spec": spec,
        "task_dir": task_dir,
        "X_task": X_task,
        "y": y,
        "meta_task": meta_task,
        "fold_df": fold_df,
        "selected_df": selected_df,
        "cm": cm,
    }


def choose_interpretation_hyperparams(selected_df: pd.DataFrame) -> dict[str, Any]:
    temp = selected_df.copy()
    grouped = (
        temp
        .groupby(["C", "class_weight"], as_index=False)
        .agg(
            count=("fold", "count"),
            mean_inner_val_balanced_accuracy=("inner_val_balanced_accuracy", "mean"),
            mean_inner_val_macro_f1=("inner_val_macro_f1", "mean"),
            mean_inner_val_roc_auc=("inner_val_roc_auc", "mean"),
        )
    )

    grouped["cw_rank"] = grouped["class_weight"].map({"balanced": 0, "none": 1}).fillna(2)
    grouped = grouped.sort_values(
        ["count", "mean_inner_val_balanced_accuracy", "mean_inner_val_macro_f1", "mean_inner_val_roc_auc", "C", "cw_rank"],
        ascending=[False, False, False, False, True, True],
        na_position="last",
    ).reset_index(drop=True)

    row = grouped.iloc[0]
    return {
        "C": float(row["C"]),
        "class_weight": str(row["class_weight"]),
        "selection_table": grouped,
    }


def mean_abs_sparse(X):
    Y = X.copy()
    Y.data = np.abs(Y.data)
    return np.asarray(Y.mean(axis=0)).ravel()


def make_feature_info(j: int, n_edges: int, edge_names: list[str], processes: list[str]):
    if j < n_edges:
        return "B", j, edge_names[j], processes[j]
    idx = j - n_edges
    return "K0", idx, edge_names[idx], processes[idx]


def interpretation_tables(result: dict[str, Any], edge_meta: pd.DataFrame, args):
    spec = result["spec"]
    task_dir = result["task_dir"]
    out_dir = task_dir / "interpretation_final_refit"
    out_dir.mkdir(parents=True, exist_ok=True)

    params = choose_interpretation_hyperparams(result["selected_df"])
    params["selection_table"].to_csv(out_dir / "hyperparameter_selection_counts.csv", index=False)
    write_df_latex(
        params["selection_table"],
        out_dir / "latex_hyperparameter_selection_counts.tex",
        f"Hyperparameter settings selected across outer folds for {spec['display']}.",
    )

    model = make_model(
        C=params["C"],
        class_weight_name=params["class_weight"],
        max_iter=args.max_iter,
        tol=args.tol,
        seed=args.seed + 9999,
        n_jobs=args.n_jobs,
    )

    model.fit(result["X_task"], result["y"])

    n_edges = len(edge_meta)
    edge_names = edge_meta["edge"].astype(str).tolist()
    processes = edge_meta["process"].fillna("Unannotated").astype(str).tolist()
    mean_abs_x = mean_abs_sparse(result["X_task"])

    with open(out_dir / "final_refit_hyperparameters.json", "w") as f:
        json.dump({"C": params["C"], "class_weight": params["class_weight"]}, f, indent=2)

    if spec["kind"] == "binary":
        beta = model.coef_[0].astype(float)
        binary_interpretation_tables(
            beta=beta,
            mean_abs_x=mean_abs_x,
            edge_names=edge_names,
            processes=processes,
            n_edges=n_edges,
            task_display=spec["display"],
            positive_name=spec["positive_name"],
            out_dir=out_dir,
            max_process_rows=args.max_process_rows,
            top_n=args.top_n,
        )
    else:
        beta = model.coef_.astype(float)
        multiclass_interpretation_tables(
            beta=beta,
            mean_abs_x=mean_abs_x,
            edge_names=edge_names,
            processes=processes,
            n_edges=n_edges,
            class_names=spec["class_names"],
            task_display=spec["display"],
            out_dir=out_dir,
            max_process_rows=args.max_process_rows,
            top_n=args.top_n,
        )


def binary_interpretation_tables(
    beta,
    mean_abs_x,
    edge_names,
    processes,
    n_edges,
    task_display,
    positive_name,
    out_dir,
    max_process_rows,
    top_n,
):
    nz = np.where(np.abs(beta) > 1e-12)[0]

    rows = []
    for j in nz:
        ftype, ei, edge, proc = make_feature_info(j, n_edges, edge_names, processes)
        rows.append(
            {
                "feature_index": int(j),
                "edge_index": int(ei),
                "edge": edge,
                "process": proc,
                "feature_type": ftype,
                "beta": float(beta[j]),
                "average_importance": float(abs(beta[j]) * mean_abs_x[j]),
                "positive_class": positive_name,
            }
        )

    coef_df = pd.DataFrame(rows)
    coef_df.to_csv(out_dir / "feature_coefficients.csv", index=False)

    if coef_df.empty:
        return

    proc_rows = []
    for proc, sub in coef_df.groupby("process"):
        bsub = sub[sub["feature_type"] == "B"]
        ksub = sub[sub["feature_type"] == "K0"]
        proc_rows.append(
            {
                "Process": proc,
                "Total Coeff.": sub["beta"].abs().sum(),
                "Features": len(sub),
                "Edges": sub["edge"].nunique(),
                "Mean |coeff|": sub["beta"].abs().mean(),
                "Mean B coeff": bsub["beta"].mean() if len(bsub) else np.nan,
                "Mean K0 coeff": ksub["beta"].mean() if len(ksub) else np.nan,
                "% positive K0": 100.0 * (ksub["beta"] > 0).mean() if len(ksub) else np.nan,
                "K0 features": len(ksub),
            }
        )

    proc_df = pd.DataFrame(proc_rows).sort_values("Total Coeff.", ascending=False)
    proc_df.to_csv(out_dir / "process_coefficient_table.csv", index=False)
    write_df_latex(
        proc_df.head(max_process_rows),
        out_dir / "latex_process_coefficient_table.tex",
        f"Biological process coefficient table for {task_display}. Positive coefficients correspond to {positive_name}.",
    )

    imp_rows = []
    for proc, sub in coef_df.groupby("process"):
        b_imp = sub.loc[sub["feature_type"] == "B", "average_importance"].sum()
        k_imp = sub.loc[sub["feature_type"] == "K0", "average_importance"].sum()
        imp_rows.append(
            {
                "Process category": proc,
                "Total imp.": b_imp + k_imp,
                "B imp.": b_imp,
                "K0 imp.": k_imp,
            }
        )

    imp_df = pd.DataFrame(imp_rows).sort_values("Total imp.", ascending=False)
    imp_df.to_csv(out_dir / "process_realised_importance_table.csv", index=False)
    write_df_latex(
        imp_df.head(max_process_rows),
        out_dir / "latex_process_realised_importance_table.tex",
        f"Total realised push by process category for {task_display}.",
    )

    top = coef_df.sort_values("beta", key=lambda s: s.abs(), ascending=False).head(top_n).copy()
    top = top[["positive_class", "edge", "process", "feature_type", "beta", "average_importance"]]
    top.columns = ["Class", "Edge", "Process", "Dominant", "Coefficient beta", "Average imp."]
    top.to_csv(out_dir / "top_absolute_features.csv", index=False)
    write_df_latex(
        top,
        out_dir / "latex_top_absolute_features.tex",
        f"Top absolute-value Ricci features for {task_display}.",
    )


def multiclass_interpretation_tables(
    beta,
    mean_abs_x,
    edge_names,
    processes,
    n_edges,
    class_names,
    task_display,
    out_dir,
    max_process_rows,
    top_n,
):
    rows = []

    for ci, cname in enumerate(class_names):
        nz = np.where(np.abs(beta[ci]) > 1e-12)[0]
        for j in nz:
            ftype, ei, edge, proc = make_feature_info(j, n_edges, edge_names, processes)
            rows.append(
                {
                    "class": cname,
                    "class_index": ci,
                    "feature_index": int(j),
                    "edge_index": int(ei),
                    "edge": edge,
                    "process": proc,
                    "feature_type": ftype,
                    "beta": float(beta[ci, j]),
                    "average_importance": float(abs(beta[ci, j]) * mean_abs_x[j]),
                }
            )

    coef_df = pd.DataFrame(rows)
    coef_df.to_csv(out_dir / "feature_coefficients_multiclass_long.csv", index=False)

    if coef_df.empty:
        return

    proc_rows = []
    for proc, sub in coef_df.groupby("process"):
        row = {
            "Process": proc,
            "Total Coeff.": sub["beta"].abs().sum(),
            "Features": len(sub),
            "Edges": sub["edge"].nunique(),
            "Mean |beta|": sub["beta"].abs().mean(),
        }

        for cname in class_names:
            for ftype in ["B", "K0"]:
                ss = sub[(sub["class"] == cname) & (sub["feature_type"] == ftype)]
                row[f"{ftype}_{cname}"] = ss["beta"].mean() if len(ss) else np.nan

        proc_rows.append(row)

    proc_df = pd.DataFrame(proc_rows).sort_values("Total Coeff.", ascending=False)
    proc_df.to_csv(out_dir / "process_coefficient_table.csv", index=False)
    write_df_latex(
        proc_df.head(max_process_rows),
        out_dir / "latex_process_coefficient_table.tex",
        f"Biological process coefficient table for the {task_display} Ricci classifier.",
    )

    imp_rows = []
    for proc, sub in coef_df.groupby("process"):
        row = {"Process": proc, "Total imp.": sub["average_importance"].sum()}
        for cname in class_names:
            for ftype in ["K0", "B"]:
                ss = sub[(sub["class"] == cname) & (sub["feature_type"] == ftype)]
                row[f"{cname} {ftype}"] = ss["average_importance"].sum()
        imp_rows.append(row)

    imp_df = pd.DataFrame(imp_rows).sort_values("Total imp.", ascending=False)
    imp_df.to_csv(out_dir / "process_realised_importance_table.csv", index=False)
    write_df_latex(
        imp_df.head(max_process_rows),
        out_dir / "latex_process_realised_importance_table.tex",
        f"Total realised push by process category for the {task_display} Ricci classifier.",
    )

    top = coef_df.sort_values("beta", key=lambda s: s.abs(), ascending=False).head(top_n).copy()
    top = top[["class", "edge", "process", "feature_type", "beta", "average_importance"]]
    top.columns = ["Class", "Edge", "Process", "Dom.", "beta", "Avg. imp."]
    top.to_csv(out_dir / "top_absolute_features.csv", index=False)
    write_df_latex(
        top,
        out_dir / "latex_top_absolute_features.tex",
        f"Top absolute-value features from the {task_display} Ricci classifier.",
    )


def write_all_task_summary(results: dict[str, Any], out_dir: Path):
    rows = []

    for task_key, res in results.items():
        df = res["fold_df"]
        row = {"Task": TASKS[task_key]["display"]}
        for metric in ["accuracy", "balanced_accuracy", "macro_f1", "roc_auc"]:
            row[metric] = fmt_mean_sd(df[metric].mean(), df[metric].std(ddof=0))
        rows.append(row)

    summary = pd.DataFrame(rows)
    summary.to_csv(out_dir / "nested_ricci_all_task_summary.csv", index=False)

    lines = [
        r"\begin{table}[ht]",
        r"\centering",
        r"\caption{Nested participant-grouped Ricci classification performance. Hyperparameters are selected inside each outer training fold using participant-grouped validation. Values are mean $\pm$ SD across outer folds.}",
        r"\begin{tabular}{lrrrr}",
        r"\toprule",
        r"Task & Accuracy & Balanced accuracy & Macro F1 & ROC-AUC \\",
        r"\midrule",
    ]

    for _, r in summary.iterrows():
        lines.append(
            f"{latex_escape(r['Task'])} & {r['accuracy']} & {r['balanced_accuracy']} & "
            f"{r['macro_f1']} & {r['roc_auc']} \\\\"
        )

    lines += [r"\bottomrule", r"\end{tabular}", r"\end{table}"]
    (out_dir / "latex_nested_ricci_all_task_summary.tex").write_text("\n".join(lines) + "\n")


def collect_latex(results: dict[str, Any], out_dir: Path):
    parts = []

    for name in [
        "latex_ricci_curvature_percentiles_participant_average.tex",
        "latex_nested_ricci_all_task_summary.tex",
    ]:
        p = out_dir / name
        if p.exists():
            parts.append(p.read_text())

    for task_key in results:
        task_dir = out_dir / TASKS[task_key]["folder"]

        for rel in [
            "latex_nested_outer_fold_results.tex",
            "latex_outer_test_confusion_matrix.tex",
            "interpretation_final_refit/latex_hyperparameter_selection_counts.tex",
            "interpretation_final_refit/latex_process_coefficient_table.tex",
            "interpretation_final_refit/latex_process_realised_importance_table.tex",
            "interpretation_final_refit/latex_top_absolute_features.tex",
        ]:
            p = task_dir / rel
            if p.exists():
                parts.append(p.read_text())

    (out_dir / "latex_all_nested_ricci_tables.tex").write_text("\n\n".join(parts) + "\n")


def main():
    ap = argparse.ArgumentParser()

    ap.add_argument("--ricci-dir", default=None, help="Directory containing per-sample Ricci CSV/CSV.GZ files.")
    ap.add_argument("--metadata", default=str(Path.home() / "Real_Data" / "hmp2_metadata.csv"))
    ap.add_argument("--output-dir", required=True)

    ap.add_argument("--feature-dir", default=None, help="Directory containing existing feature_matrix_B_K0.npz, matched_metadata.csv, edge_metadata.csv.")
    ap.add_argument("--reuse-features", action="store_true", help="Reuse feature files already present in output-dir.")

    ap.add_argument("--ricci-glob", default=None)
    ap.add_argument("--edge-annotation-csv", default=None)
    ap.add_argument("--tasks", nargs="+", default=list(TASKS.keys()), choices=list(TASKS.keys()))

    ap.add_argument("--C-grid", default="0.03,0.1,0.3,1,3,10")
    ap.add_argument("--class-weight-grid", default="balanced,none")
    ap.add_argument("--outer-splits", type=int, default=5)
    ap.add_argument("--inner-splits", type=int, default=5)
    ap.add_argument("--inner-mode", choices=["single", "cv"], default="single")

    ap.add_argument("--max-iter", type=int, default=8000)
    ap.add_argument("--tol", type=float, default=1e-4)
    ap.add_argument("--n-jobs", type=int, default=1)
    ap.add_argument("--seed", type=int, default=20260710)
    ap.add_argument("--chunksize", type=int, default=250000)
    ap.add_argument("--max-samples", type=int, default=None)

    ap.add_argument("--skip-ricci-diagnostics", action="store_true")
    ap.add_argument("--skip-density", action="store_true")
    ap.add_argument("--skip-interpretation", action="store_true")

    ap.add_argument("--max-process-rows", type=int, default=40)
    ap.add_argument("--top-n", type=int, default=25)

    args = ap.parse_args()

    out_dir = Path(args.output_dir).expanduser()
    out_dir.mkdir(parents=True, exist_ok=True)

    config = vars(args).copy()
    config["feature_definition"] = "[B | K0], with B(e)=1 if edge e is active/present and K0(e)=Ricci curvature if active/present; both zero otherwise."
    config["outer_protocol"] = "Participant-grouped outer CV. Test participants are held out from hyperparameter selection."
    config["inner_protocol"] = "Participant-grouped inner validation inside each outer-training fold. Select by validation balanced accuracy, macro F1 and ROC-AUC tie-breakers."
    config["interpretation_protocol"] = "Final-refit coefficient tables use the most frequently selected hyperparameter setting for the task and are for interpretation only."
    (out_dir / "run_config.json").write_text(json.dumps(config, indent=2, default=str))

    metadata_all = load_metadata(Path(args.metadata).expanduser())

    if not args.feature_dir and not args.reuse_features and not args.ricci_dir:
        raise ValueError("Provide --ricci-dir to build features, or --feature-dir / --reuse-features to reuse existing features.")

    X, matched, edge_meta = build_or_load_features(args, metadata_all)

    print("\nFinal feature matrix:", X.shape, "nnz=", X.nnz, flush=True)
    print("Matched metadata rows:", len(matched), flush=True)
    print("Unique participants:", matched["participant_id"].nunique(), flush=True)
    print(matched.drop_duplicates("participant_id")["cond"].value_counts().to_string(), flush=True)

    n_edges = len(edge_meta)
    if X.shape[1] != 2 * n_edges:
        raise ValueError(f"X has {X.shape[1]} columns but edge_meta has {n_edges} rows; expected 2*n_edges.")

    if not args.skip_ricci_diagnostics:
        ricci_percentiles_and_density(X, matched, edge_meta, out_dir, skip_density=args.skip_density)

    results = {}
    for task_key in args.tasks:
        print("\n" + "=" * 100, flush=True)
        print("Running nested task:", TASKS[task_key]["display"], flush=True)
        print("=" * 100, flush=True)

        res = run_task(X, matched, task_key, args, out_dir)
        results[task_key] = res

        if not args.skip_interpretation:
            interpretation_tables(res, edge_meta, args)

    write_all_task_summary(results, out_dir)
    collect_latex(results, out_dir)

    print("\n[READY] Nested faithful Ricci classifier finished.", flush=True)
    print("Output directory:", out_dir, flush=True)
    print("Combined LaTeX:", out_dir / "latex_all_nested_ricci_tables.tex", flush=True)


if __name__ == "__main__":
    main()
