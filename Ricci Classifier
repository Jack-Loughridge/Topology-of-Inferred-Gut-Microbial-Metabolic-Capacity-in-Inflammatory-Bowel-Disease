def norm_cond(x: Any) -> str:
    s = str(x).strip().lower()
    if "crohn" in s or s == "cd":
        return "cd"
    if "ulcerative" in s or s == "uc":
        return "uc"
    if "non" in s:
        return "nonibd"
    return s


def latex_escape(x: Any) -> str:
    s = str(x)
    repl = {
        "\\": r"\textbackslash{}",
        "&": r"\&",
        "%": r"\%",
        "$": r"\$",
        "#": r"\#",
        "_": r"\_",
        "{": r"\{",
        "}": r"\}",
        "~": r"\textasciitilde{}",
        "^": r"\textasciicircum{}",
    }
    for a, b in repl.items():
        s = s.replace(a, b)
    return s


def fmt(x: Any, digits: int = 3) -> str:
    try:
        x = float(x)
    except Exception:
        return "--"
    if not math.isfinite(x):
        return "--"
    return f"{x:.{digits}f}"


def fmt_mean_sd(mean: Any, sd: Any, digits: int = 3) -> str:
    try:
        mean = float(mean)
        sd = float(sd)
    except Exception:
        return "--"
    if not math.isfinite(mean):
        return "--"
    if not math.isfinite(sd):
        return fmt(mean, digits)
    return f"{fmt(mean, digits)} $\\pm$ {fmt(sd, digits)}"


def pick_col(columns, candidates, required=True, label="column"):
    cols = list(columns)
    lower = {str(c).lower(): c for c in cols}
    for cand in candidates:
        if cand in cols:
            return cand
        if cand.lower() in lower:
            return lower[cand.lower()]
    if required:
        raise ValueError(f"Could not find {label}. Tried {candidates}. Columns: {cols}")
    return None


def infer_sample_id_from_filename(path: Path) -> str:
    name = path.name
    for suffix in [".csv.gz", ".tsv.gz", ".csv", ".tsv", ".gz"]:
        if name.endswith(suffix):
            name = name[: -len(suffix)]
            break

    suffixes = [
        "_ricci_active",
        "_active_ricci",
        "_ricci",
        ".ricci_active",
        ".active_ricci",
        ".ricci",
    ]
    for suffix in suffixes:
        if name.endswith(suffix):
            name = name[: -len(suffix)]
            break

    return name


def read_csv_chunks(path: Path, chunksize: int):
    sep = "\t" if path.name.endswith(".tsv") or path.name.endswith(".tsv.gz") else ","
    return pd.read_csv(path, sep=sep, low_memory=False, chunksize=chunksize)


def detect_columns(chunk: pd.DataFrame) -> dict[str, str | None]:
    edge_col = pick_col(chunk.columns, EDGE_CANDIDATES, required=False, label="edge column")

    source_col = None
    target_col = None
    if edge_col is None:
        source_col = pick_col(chunk.columns, SOURCE_CANDIDATES, required=True, label="source column")
        target_col = pick_col(chunk.columns, TARGET_CANDIDATES, required=True, label="target column")

    kappa_col = pick_col(chunk.columns, KAPPA_CANDIDATES, required=True, label="curvature column")
    sample_col = pick_col(chunk.columns, SAMPLE_CANDIDATES, required=False, label="sample id column")
    process_col = pick_col(chunk.columns, PROCESS_CANDIDATES, required=False, label="process column")

    return {
        "edge_col": edge_col,
        "source_col": source_col,
        "target_col": target_col,
        "kappa_col": kappa_col,
        "sample_col": sample_col,
        "process_col": process_col,
    }


def build_edge_series(chunk: pd.DataFrame, detected: dict[str, str | None]) -> pd.Series:
    if detected["edge_col"] is not None:
        return chunk[detected["edge_col"]].astype(str)
    return chunk[detected["source_col"]].astype(str) + " -> " + chunk[detected["target_col"]].astype(str)


def find_ricci_files(ricci_dir: Path, explicit_glob: str | None) -> list[Path]:
    if explicit_glob:
        files = sorted(ricci_dir.glob(explicit_glob))
    else:
        files = sorted(ricci_dir.rglob("*ricci*.csv*"))
        files = [p for p in files if "diagnostic" not in p.name.lower()]
        if not files:
            files = sorted(ricci_dir.rglob("*.csv.gz")) + sorted(ricci_dir.rglob("*.csv"))

    files = [p for p in files if p.is_file()]
    if not files:
        raise FileNotFoundError(f"No Ricci CSV files found in {ricci_dir}")
    return files


def load_metadata(metadata_path: Path) -> pd.DataFrame:
    meta = pd.read_csv(metadata_path, low_memory=False)

    sample_col = pick_col(
        meta.columns,
        ["External ID", "sample_id", "sample", "external_id"],
        label="sample id in metadata",
    )
    participant_col = pick_col(
        meta.columns,
        ["Participant ID", "participant_id", "participant", "host_subject_id"],
        label="participant id in metadata",
    )
    diagnosis_col = pick_col(
        meta.columns,
        ["diagnosis", "Diagnosis", "condition", "cond"],
        label="diagnosis in metadata",
    )

    out = meta[[sample_col, participant_col, diagnosis_col]].copy()
    out.columns = ["sample_id", "participant_id", "diagnosis"]
    out["sample_id"] = out["sample_id"].astype(str)
    out["participant_id"] = out["participant_id"].astype(str)
    out["cond"] = out["diagnosis"].apply(norm_cond)
    out = out[out["cond"].isin(["cd", "uc", "nonibd"])]
    out = out.drop_duplicates("sample_id").reset_index(drop=True)
    return out


def balanced_limit_metadata(metadata: pd.DataFrame, max_samples: int | None, seed: int) -> pd.DataFrame:
    if max_samples is None or max_samples >= len(metadata):
        return metadata.copy()

    rng = np.random.default_rng(seed)
    conds = [c for c in ["cd", "uc", "nonibd"] if c in set(metadata["cond"])]
    base = max_samples // len(conds)
    rem = max_samples % len(conds)

    parts = []
    for i, cond in enumerate(conds):
        sub = metadata[metadata["cond"] == cond].copy()
        n_take = min(len(sub), base + (1 if i < rem else 0))
        if n_take:
            idx = rng.choice(sub.index.to_numpy(), size=n_take, replace=False)
            parts.append(sub.loc[idx])

    limited = pd.concat(parts, axis=0) if parts else metadata.head(max_samples).copy()

    if len(limited) < max_samples:
        remaining = metadata.drop(index=limited.index, errors="ignore")
        n_extra = min(max_samples - len(limited), len(remaining))
        if n_extra:
            idx = rng.choice(remaining.index.to_numpy(), size=n_extra, replace=False)
            limited = pd.concat([limited, remaining.loc[idx]], axis=0)

    limited = limited.sample(frac=1.0, random_state=seed).reset_index(drop=True)

    print(f"[max_samples] Balanced subset: {len(limited)} samples", flush=True)
    print(limited["cond"].value_counts().to_string(), flush=True)
    print("participants:", limited["participant_id"].nunique(), flush=True)

    return limited


def load_edge_annotation(path: Path | None) -> dict[str, str]:
    if path is None:
        return {}

    ann = pd.read_csv(path, low_memory=False)
    process_col = pick_col(ann.columns, PROCESS_CANDIDATES, required=True, label="process column in annotation file")
    edge_col = pick_col(ann.columns, EDGE_CANDIDATES, required=False, label="edge column in annotation file")

    if edge_col is None:
        source_col = pick_col(ann.columns, SOURCE_CANDIDATES, required=True, label="source column in annotation file")
        target_col = pick_col(ann.columns, TARGET_CANDIDATES, required=True, label="target column in annotation file")
        edge = ann[source_col].astype(str) + " -> " + ann[target_col].astype(str)
    else:
        edge = ann[edge_col].astype(str)

    proc = ann[process_col].fillna("Unannotated").astype(str)

    mapping = {}
    for e, p in zip(edge, proc):
        if e not in mapping or mapping[e] == "Unannotated":
            mapping[e] = p if p else "Unannotated"

    print(f"[annotation] Loaded process labels for {len(mapping):,} edges from {path}", flush=True)
    return mapping


def pass1_discover_edges(
    files: list[Path],
    chunksize: int,
) -> tuple[dict[str, int], dict[str, str], set[str], dict[str, Any]]:
    edge_to_idx: dict[str, int] = {}
    edge_process: dict[str, str] = {}
    sample_ids: set[str] = set()
    detected_by_file: dict[str, Any] = {}

    print("[pass1] Discovering samples and edge universe...", flush=True)
    t0 = time.time()

    for fi, path in enumerate(files, start=1):
        file_sample = infer_sample_id_from_filename(path)
        first = True
        detected = None
        n_rows = 0

        for chunk in read_csv_chunks(path, chunksize):
            if first:
                detected = detect_columns(chunk)
                detected_by_file[str(path)] = detected
                first = False

            edges = build_edge_series(chunk, detected)
            kappa = pd.to_numeric(chunk[detected["kappa_col"]], errors="coerce")
            ok = kappa.notna() & np.isfinite(kappa.to_numpy(dtype=float))

            if detected["sample_col"] is not None:
                sample_ids.update(chunk.loc[ok, detected["sample_col"]].astype(str).unique().tolist())
            else:
                sample_ids.add(file_sample)

            if detected["process_col"] is not None:
                procs = chunk.loc[ok, detected["process_col"]].fillna("Unannotated").astype(str)
            else:
                procs = pd.Series(["Unannotated"] * int(ok.sum()))

            for e, proc in zip(edges.loc[ok].astype(str), procs):
                if e not in edge_to_idx:
                    edge_to_idx[e] = len(edge_to_idx)
                    edge_process[e] = proc if proc else "Unannotated"
                elif edge_process[e] == "Unannotated" and proc:
                    edge_process[e] = proc

            n_rows += len(chunk)

        print(
            f"  [{fi}/{len(files)}] {path.name}: rows={n_rows:,}, "
            f"edges={len(edge_to_idx):,}, samples={len(sample_ids):,}",
            flush=True,
        )

    print(
        f"[pass1 done] edges={len(edge_to_idx):,}, samples={len(sample_ids):,}, "
        f"time={(time.time() - t0) / 60:.1f} min",
        flush=True,
    )

    return edge_to_idx, edge_process, sample_ids, detected_by_file


def build_sparse_features(
    files: list[Path],
    metadata: pd.DataFrame,
    edge_to_idx: dict[str, int],
    chunksize: int,
    out_dir: Path,
) -> Any:
    n_edges = len(edge_to_idx)
    samples = metadata["sample_id"].tolist()
    sample_to_row = {s: i for i, s in enumerate(samples)}

    rows_b, cols_b, data_b = [], [], []
    rows_k, cols_k, data_k = [], [], []

    print("[pass2] Building sparse [B | K0] feature matrix...", flush=True)
    t0 = time.time()

    for fi, path in enumerate(files, start=1):
        file_sample = infer_sample_id_from_filename(path)
        first = True
        detected = None
        used_rows = 0

        for chunk in read_csv_chunks(path, chunksize):
            if first:
                detected = detect_columns(chunk)
                first = False

            edges = build_edge_series(chunk, detected)
            kappa = pd.to_numeric(chunk[detected["kappa_col"]], errors="coerce")
            ok = kappa.notna() & np.isfinite(kappa.to_numpy(dtype=float))

            if detected["sample_col"] is not None:
                sid = chunk[detected["sample_col"]].astype(str)
            else:
                sid = pd.Series([file_sample] * len(chunk), index=chunk.index)

            small = pd.DataFrame(
                {
                    "sample_id": sid.loc[ok].astype(str),
                    "edge": edges.loc[ok].astype(str),
                    "kappa": kappa.loc[ok].astype(float),
                }
            )

            small = small[small["sample_id"].isin(sample_to_row)]
            if small.empty:
                continue

            small = small.groupby(["sample_id", "edge"], as_index=False)["kappa"].mean()

            for sample_id, edge, kap in small.itertuples(index=False):
                ei = edge_to_idx.get(edge)
                if ei is None:
                    continue
                ri = sample_to_row[sample_id]

                rows_b.append(ri)
                cols_b.append(ei)
                data_b.append(1.0)

                rows_k.append(ri)
                cols_k.append(ei)
                data_k.append(float(kap))

            used_rows += len(small)

        print(f"  [{fi}/{len(files)}] {path.name}: used sample-edge rows={used_rows:,}", flush=True)

    n_samples = len(samples)

    B = coo_matrix((data_b, (rows_b, cols_b)), shape=(n_samples, n_edges), dtype=np.float32).tocsr()
    B.data[:] = 1.0

    K = coo_matrix((data_k, (rows_k, cols_k)), shape=(n_samples, n_edges), dtype=np.float32).tocsr()
    X = hstack([B, K], format="csr")

    save_npz(out_dir / "feature_matrix_B_K0.npz", X)

    print(
        f"[pass2 done] X shape={X.shape}, nnz={X.nnz:,}, "
        f"time={(time.time() - t0) / 60:.1f} min",
        flush=True,
    )

    return X


def build_or_load_features(args, metadata_all: pd.DataFrame):
    out_dir = Path(args.output_dir).expanduser()
    out_dir.mkdir(parents=True, exist_ok=True)

    feature_dir = Path(args.feature_dir).expanduser() if args.feature_dir else out_dir

    matrix_path = feature_dir / "feature_matrix_B_K0.npz"
    meta_path = feature_dir / "matched_metadata.csv"
    edge_path = feature_dir / "edge_metadata.csv"

    if args.feature_dir or args.reuse_features:
        if matrix_path.exists() and meta_path.exists() and edge_path.exists():
            print(f"[reuse] Loading features from {feature_dir}", flush=True)
            X = load_npz(matrix_path).tocsr()
            matched = pd.read_csv(meta_path)
            edge_meta = pd.read_csv(edge_path)

            matched["sample_id"] = matched["sample_id"].astype(str)
            matched["participant_id"] = matched["participant_id"].astype(str)
            matched["cond"] = matched["cond"].astype(str)

            if feature_dir != out_dir:
                shutil.copy2(matrix_path, out_dir / "feature_matrix_B_K0.npz")
                shutil.copy2(meta_path, out_dir / "matched_metadata.csv")
                shutil.copy2(edge_path, out_dir / "edge_metadata.csv")

            print("Feature matrix:", X.shape, "nnz=", X.nnz, flush=True)
            print("Participants:", matched["participant_id"].nunique(), flush=True)
            print(matched.drop_duplicates("participant_id")["cond"].value_counts().to_string(), flush=True)
            return X, matched, edge_meta

        if args.feature_dir:
            raise FileNotFoundError(
                f"--feature-dir was provided, but required files were not found in {feature_dir}"
            )

    files = find_ricci_files(Path(args.ricci_dir).expanduser(), args.ricci_glob)
    print("Ricci files found:", len(files), flush=True)
    for p in files[:10]:
        print(" ", p, flush=True)
    if len(files) > 10:
        print(" ...", flush=True)

    edge_to_idx, edge_process, sample_ids, detected = pass1_discover_edges(files, args.chunksize)

    ann = load_edge_annotation(Path(args.edge_annotation_csv).expanduser() if args.edge_annotation_csv else None)

    inv_edges = [None] * len(edge_to_idx)
    for e, idx in edge_to_idx.items():
        inv_edges[idx] = e

    process_labels = []
    for e in inv_edges:
        process_labels.append(ann.get(e, edge_process.get(e, "Unannotated")))

    matched = metadata_all[metadata_all["sample_id"].isin(sample_ids)].copy()
    if args.max_samples is not None:
        matched = balanced_limit_metadata(matched, args.max_samples, args.seed)

    if matched.empty:
        raise ValueError("No metadata sample IDs matched Ricci files.")

    matched = matched.reset_index(drop=True)

    print("Matched samples:", matched["sample_id"].nunique(), flush=True)
    print("Matched participants:", matched["participant_id"].nunique(), flush=True)
    print(matched.drop_duplicates("participant_id")["cond"].value_counts().to_string(), flush=True)

    X = build_sparse_features(files, matched, edge_to_idx, args.chunksize, out_dir)

    edge_meta = pd.DataFrame(
        {
            "edge_index": np.arange(len(inv_edges)),
            "edge": inv_edges,
            "process": process_labels,
        }
    )

    matched.to_csv(out_dir / "matched_metadata.csv", index=False)
    edge_meta.to_csv(out_dir / "edge_metadata.csv", index=False)
    (out_dir / "detected_columns_by_file.json").write_text(json.dumps(detected, indent=2, default=str))

    return X, matched, edge_meta


def active_kappa_values(B, K, row_i: int) -> np.ndarray:
    b0, b1 = B.indptr[row_i], B.indptr[row_i + 1]
    active_edges = B.indices[b0:b1]

    if active_edges.size == 0:
        return np.asarray([], dtype=float)

    k0, k1 = K.indptr[row_i], K.indptr[row_i + 1]
    k_idx = K.indices[k0:k1]
    k_data = K.data[k0:k1]

    vals = np.zeros(active_edges.size, dtype=float)

    if k_idx.size:
        order = np.argsort(active_edges)
        active_sorted = active_edges[order]

        pos = np.searchsorted(active_sorted, k_idx)
        ok = (pos >= 0) & (pos < active_sorted.size)
        ok[ok] &= active_sorted[pos[ok]] == k_idx[ok]

        vals_sorted = np.zeros(active_sorted.size, dtype=float)
        vals_sorted[pos[ok]] = k_data[ok]

        inv = np.empty_like(order)
        inv[order] = np.arange(order.size)
        vals = vals_sorted[inv]

    vals = vals[np.isfinite(vals)]
    return vals


def write_percentile_latex(summary: pd.DataFrame, out_path: Path):
    lines = [
        r"\begin{table}[ht]",
        r"\centering",
        r"\caption{Participant-average percentile bands of Ricci curvature values. Percentiles are first computed within each sample graph across active directed edges, then averaged within participant; condition values are mean $\pm$ SD across participants.}",
        r"\resizebox{\textwidth}{!}{%",
        r"\begin{tabular}{lr" + "r" * len(PCT_SPECS) + "}",
        r"\toprule",
        "Condition & $n$ & " + " & ".join([rf"$p_{{{lab}}}$" for _, _, lab in PCT_SPECS]) + r" \\",
        r"\midrule",
    ]

    for cond in COND_ORDER:
        sub = summary[summary["cond"] == cond]
        if sub.empty:
            continue
        row = sub.iloc[0]
        vals = [
            fmt_mean_sd(row.get(f"{col}_mean", np.nan), row.get(f"{col}_sd", np.nan))
            for _, col, _ in PCT_SPECS
        ]
        lines.append(f"{COND_LABEL[cond]} & {int(row['n'])} & " + " & ".join(vals) + r" \\")

    lines += [r"\bottomrule", r"\end{tabular}%", r"}", r"\end{table}"]
    out_path.write_text("\n".join(lines) + "\n")


def ricci_percentiles_and_density(X, matched: pd.DataFrame, edge_meta: pd.DataFrame, out_dir: Path, skip_density: bool):
    n_edges = len(edge_meta)
    B = X[:, :n_edges].tocsr()
    K = X[:, n_edges:].tocsr()

    pct_values = [x[0] for x in PCT_SPECS]
    sample_rows = []

    print("[diagnostics] Computing Ricci percentile diagnostics...", flush=True)

    for i, m in matched.reset_index(drop=True).iterrows():
        vals = active_kappa_values(B, K, i)

        row = {
            "sample_id": m["sample_id"],
            "participant_id": m["participant_id"],
            "cond": m["cond"],
            "n_active_ricci_edges": int(vals.size),
        }

        if vals.size:
            qs = np.percentile(vals, pct_values)
            for (_, col, _), q in zip(PCT_SPECS, qs):
                row[col] = float(q)
        else:
            for _, col, _ in PCT_SPECS:
                row[col] = np.nan

        sample_rows.append(row)

    sample_df = pd.DataFrame(sample_rows)
    sample_df.to_csv(out_dir / "ricci_curvature_percentiles_samplewise.csv", index=False)

    numeric_cols = ["n_active_ricci_edges"] + [col for _, col, _ in PCT_SPECS]

    participant_rows = []
    for pid, sub in sample_df.groupby("participant_id", dropna=False):
        prow = {
            "participant_id": pid,
            "cond": sub["cond"].astype(str).value_counts().idxmax(),
            "n_samples_for_participant": int(sub["sample_id"].nunique()),
        }
        for col in numeric_cols:
            vals = pd.to_numeric(sub[col], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
            prow[col] = float(vals.mean()) if len(vals) else np.nan
        participant_rows.append(prow)

    participant_df = pd.DataFrame(participant_rows)
    participant_df.to_csv(out_dir / "ricci_curvature_percentiles_participant_average.csv", index=False)

    summary_rows = []
    for cond in COND_ORDER:
        sub = participant_df if cond == "overall" else participant_df[participant_df["cond"] == cond]
        srow = {"cond": cond, "n": int(len(sub))}
        for col in numeric_cols:
            vals = pd.to_numeric(sub[col], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
            srow[f"{col}_mean"] = float(vals.mean()) if len(vals) else np.nan
            srow[f"{col}_sd"] = float(vals.std(ddof=0)) if len(vals) else np.nan
        summary_rows.append(srow)

    summary = pd.DataFrame(summary_rows)
    summary.to_csv(out_dir / "ricci_curvature_percentiles_participant_condition_summary.csv", index=False)
    write_percentile_latex(summary, out_dir / "latex_ricci_curvature_percentiles_participant_average.tex")

    print("[diagnostics] Participant counts in Ricci percentile table:", flush=True)
    print(summary[["cond", "n"]].to_string(index=False), flush=True)

    if not skip_density:
        make_density_plots(B, K, matched, out_dir)


def make_density_plots(B, K, matched: pd.DataFrame, out_dir: Path, n_bins: int = 260):
    plot_dir = out_dir / "plots"
    plot_dir.mkdir(parents=True, exist_ok=True)

    print("[density] Preparing Ricci density curves...", flush=True)

    all_vals = []
    for i in range(B.shape[0]):
        vals = active_kappa_values(B, K, i)
        if vals.size:
            all_vals.append(vals)

    if not all_vals:
        print("[density] No finite Ricci values found; skipping plots.", flush=True)
        return

    all_vals = np.concatenate(all_vals)
    all_vals = all_vals[np.isfinite(all_vals)]

    x_min = float(np.percentile(all_vals, 0.2))
    x_max = float(np.percentile(all_vals, 99.8))
    x_min = max(-40.0, min(x_min, -5.0))
    x_max = min(1.0, max(x_max, 0.5))

    if x_min >= x_max:
        x_min, x_max = -30.0, 1.0

    bins = np.linspace(x_min, x_max, n_bins + 1)
    centers = 0.5 * (bins[:-1] + bins[1:])

    sample_rows = []
    meta = matched.reset_index(drop=True)

    for i, m in meta.iterrows():
        vals = active_kappa_values(B, K, i)
        vals = vals[(vals >= x_min) & (vals <= x_max)]
        if vals.size:
            dens, _ = np.histogram(vals, bins=bins, density=True)
        else:
            dens = np.zeros(len(centers), dtype=float)

        for center, d in zip(centers, dens):
            sample_rows.append(
                {
                    "sample_id": m["sample_id"],
                    "participant_id": m["participant_id"],
                    "cond": m["cond"],
                    "kappa_bin_center": float(center),
                    "density": float(d),
                }
            )

    sample_density = pd.DataFrame(sample_rows)
    sample_density.to_csv(out_dir / "ricci_curvature_density_samplewise.csv", index=False)

    participant_density = (
        sample_density
        .groupby(["participant_id", "cond", "kappa_bin_center"], as_index=False)["density"]
        .mean()
    )
    participant_density.to_csv(out_dir / "ricci_curvature_density_participant_average.csv", index=False)

    summary_rows = []
    for cond in COND_ORDER:
        sub = participant_density if cond == "overall" else participant_density[participant_density["cond"] == cond]
        for center, g in sub.groupby("kappa_bin_center"):
            vals = pd.to_numeric(g["density"], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
            summary_rows.append(
                {
                    "cond": cond,
                    "kappa_bin_center": float(center),
                    "n_participants": int(g["participant_id"].nunique()),
                    "density_mean": float(vals.mean()) if len(vals) else np.nan,
                    "density_sd": float(vals.std(ddof=0)) if len(vals) else np.nan,
                }
            )

    summary = pd.DataFrame(summary_rows)
    summary.to_csv(out_dir / "ricci_curvature_density_condition_summary.csv", index=False)

    def draw(log_density: bool):
        fig, ax = plt.subplots(figsize=(7.2, 4.8))

        for cond in COND_ORDER:
            sub = summary[summary["cond"] == cond].sort_values("kappa_bin_center")
            if sub.empty:
                continue

            x = sub["kappa_bin_center"].to_numpy(dtype=float)
            y = sub["density_mean"].to_numpy(dtype=float)
            sd = sub["density_sd"].to_numpy(dtype=float)
            sd = np.where(np.isfinite(sd), sd, 0.0)

            if log_density:
                eps = 1e-8
                y_plot = np.log10(y + eps)
                lo = np.log10(np.maximum(y - sd, 0.0) + eps)
                hi = np.log10(y + sd + eps)
                ylabel = r"$\log_{10}$ density"
                title = "Participant-average Ricci curvature log-density"
                out_base = plot_dir / "ricci_curvature_log_density_by_condition"
            else:
                y_plot = y
                lo = np.maximum(y - sd, 0.0)
                hi = y + sd
                ylabel = "Density"
                title = "Participant-average Ricci curvature density"
                out_base = plot_dir / "ricci_curvature_density_by_condition"

            line, = ax.plot(x, y_plot, linewidth=2.0, label=COND_LABEL[cond])
            ax.fill_between(x, lo, hi, alpha=0.15, color=line.get_color(), linewidth=0)

        ax.set_xlabel(r"Ricci curvature $\kappa$")
        ax.set_ylabel(ylabel)
        ax.set_title(title)
        ax.grid(True, alpha=0.25)
        ax.legend(frameon=False)
        fig.tight_layout()

        fig.savefig(str(out_base) + ".png", dpi=300)
        fig.savefig(str(out_base) + ".pdf")
        plt.close(fig)

    draw(log_density=False)
    draw(log_density=True)

    print("[density] Wrote:", flush=True)
    print(" ", plot_dir / "ricci_curvature_density_by_condition.png", flush=True)
    print(" ", plot_dir / "ricci_curvature_log_density_by_condition.png", flush=True)


def class_weight_value(name: str):
    return None if name == "none" else name


def make_model(C: float, class_weight_name: str, max_iter: int, tol: float, seed: int, n_jobs: int):
    return LogisticRegression(
        penalty="l1",
        solver="saga",
        C=float(C),
        class_weight=class_weight_value(class_weight_name),
        max_iter=int(max_iter),
        tol=float(tol),
        random_state=int(seed),
        n_jobs=int(n_jobs),
    )


def safe_auc(y_true: np.ndarray, proba: np.ndarray, n_classes: int) -> float:
    try:
        if len(np.unique(y_true)) < 2:
            return np.nan
        if n_classes == 2:
            return float(roc_auc_score(y_true, proba[:, 1]))
        return float(
            roc_auc_score(
                y_true,
                proba,
                labels=list(range(n_classes)),
                multi_class="ovr",
                average="macro",
            )
        )
    except Exception:
        return np.nan


def score_predictions(y_true: np.ndarray, pred: np.ndarray, proba: np.ndarray, n_classes: int) -> dict[str, float]:
    return {
        "accuracy": float(accuracy_score(y_true, pred)),
        "balanced_accuracy": float(balanced_accuracy_score(y_true, pred)),
        "macro_f1": float(f1_score(y_true, pred, average="macro", zero_division=0)),
        "roc_auc": safe_auc(y_true, proba, n_classes),
    }


def safe_group_splits(y: np.ndarray, groups: np.ndarray, requested: int, display: str) -> int:
    counts = []
    for cls in sorted(np.unique(y)):
        counts.append(len(set(groups[y == cls])))

    if len(counts) < 2:
        raise ValueError(f"{display}: only one class is present after filtering.")

    n_splits = min(int(requested), min(counts))
    if n_splits < 2:
        raise ValueError(
            f"{display}: not enough participant groups per class for grouped CV. "
            f"Groups per class: {counts}"
        )

    if n_splits < requested:
        print(
            f"[CV] Reducing n_splits from {requested} to {n_splits} for {display}; "
            f"groups per class={counts}",
            flush=True,
        )

    return n_splits


def parse_float_grid(s: str) -> list[float]:
    vals = []
    for part in s.split(","):
        part = part.strip()
        if part:
            vals.append(float(part))
    if not vals:
        raise ValueError("Empty C grid.")
    return vals


def parse_class_weight_grid(s: str) -> list[str]:
    vals = []
    for part in s.split(","):
        part = part.strip().lower()
        if part in {"none", "balanced"}:
            vals.append(part)
        elif part:
            raise ValueError(f"Unknown class_weight value: {part}")
    if not vals:
        raise ValueError("Empty class_weight grid.")
    return vals


def task_subset(X, matched: pd.DataFrame, task_key: str):
    spec = TASKS[task_key]
    rows, y = [], []
    for i, cond in enumerate(matched["cond"].tolist()):
        if cond in spec["label_map"]:
            rows.append(i)
            y.append(spec["label_map"][cond])

    rows = np.asarray(rows, dtype=int)
    y = np.asarray(y, dtype=int)
    meta = matched.iloc[rows].reset_index(drop=True)
    return X[rows], y, meta


def hyperparameter_grid(args):
    Cs = parse_float_grid(args.C_grid)
    cws = parse_class_weight_grid(args.class_weight_grid)
    return [{"C": C, "class_weight": cw} for C in Cs for cw in cws]


def select_hyperparameters(
    X_train,
    y_train: np.ndarray,
    groups_train: np.ndarray,
    n_classes: int,
    task_display: str,
    args,
) -> tuple[dict[str, Any], pd.DataFrame]:
    grid = hyperparameter_grid(args)

    inner_splits = safe_group_splits(y_train, groups_train, args.inner_splits, task_display + " inner")
    sgkf = StratifiedGroupKFold(n_splits=inner_splits, shuffle=True, random_state=args.seed + 1000)

    split_iter = list(sgkf.split(X_train, y_train, groups_train))
    if args.inner_mode == "single":
        split_iter = split_iter[:1]

    rows = []

    for params in grid:
        fold_scores = []

        for inner_fold, (itr, iva) in enumerate(split_iter, start=1):
            if len(np.unique(y_train[itr])) < 2 or len(np.unique(y_train[iva])) < 2:
                continue

            model = make_model(
                C=params["C"],
                class_weight_name=params["class_weight"],
                max_iter=args.max_iter,
                tol=args.tol,
                seed=args.seed + inner_fold,
                n_jobs=args.n_jobs,
            )

            with warnings.catch_warnings(record=True) as caught:
                warnings.simplefilter("always", ConvergenceWarning)
                model.fit(X_train[itr], y_train[itr])
                conv = any(isinstance(w.message, ConvergenceWarning) for w in caught)

            pred = model.predict(X_train[iva])
            proba = model.predict_proba(X_train[iva])
            score = score_predictions(y_train[iva], pred, proba, n_classes)

            fold_scores.append(score)

            rows.append(
                {
                    "C": params["C"],
                    "class_weight": params["class_weight"],
                    "inner_fold": inner_fold,
                    "validation_samples": int(len(iva)),
                    "validation_participants": int(len(set(groups_train[iva]))),
                    "accuracy": score["accuracy"],
                    "balanced_accuracy": score["balanced_accuracy"],
                    "macro_f1": score["macro_f1"],
                    "roc_auc": score["roc_auc"],
                    "convergence_warning": bool(conv),
                }
            )

    if not rows:
        raise RuntimeError(f"No valid inner-validation fits completed for {task_display}.")

    val_df = pd.DataFrame(rows)

    agg = (
        val_df
        .groupby(["C", "class_weight"], as_index=False)
        .agg(
            val_accuracy=("accuracy", "mean"),
            val_balanced_accuracy=("balanced_accuracy", "mean"),
            val_macro_f1=("macro_f1", "mean"),
            val_roc_auc=("roc_auc", "mean"),
            convergence_warnings=("convergence_warning", "sum"),
        )
    )

    agg["cw_rank"] = agg["class_weight"].map({"balanced": 0, "none": 1}).fillna(2)
    agg = agg.sort_values(
        ["val_balanced_accuracy", "val_macro_f1", "val_roc_auc", "C", "cw_rank"],
        ascending=[False, False, False, True, True],
        na_position="last",
    ).reset_index(drop=True)

    best = agg.iloc[0].to_dict()
    selected = {
        "C": float(best["C"]),
        "class_weight": str(best["class_weight"]),
        "val_balanced_accuracy": float(best["val_balanced_accuracy"]),
        "val_macro_f1": float(best["val_macro_f1"]),
        "val_roc_auc": float(best["val_roc_auc"]) if pd.notna(best["val_roc_auc"]) else np.nan,
    }

    return selected, val_df


