PROCESS_CANDIDATES = [
    "process",
    "process_class",
    "process_category",
    "biological_process",
    "category",
    "edge_process",
    "reaction_process",
]

EDGE_CANDIDATES = [
    "edge",
    "edge_id",
    "edge_key",
    "reaction_edge",
    "directed_edge",
]

SOURCE_CANDIDATES = ["source", "src", "u", "a", "from", "tail"]
TARGET_CANDIDATES = ["target", "dst", "v", "b", "to", "head"]


def fmt(x: Any, digits: int = 3) -> str:
    try:
        x = float(x)
    except Exception:
        return "--"
    if not math.isfinite(x):
        return "--"
    return f"{x:.{digits}f}"


def fmt_mean_sd(mean: Any, sd: Any, digits: int = 3) -> str:
    return f"{fmt(mean, digits)} $\\pm$ {fmt(sd, digits)}"


def latex_escape(x: Any) -> str:
    s = str(x)
    repl = {
        "\\": r"\textbackslash{}",
        "&": r"\&",
        "%": r"\%",
        "$": r"\$",
        "#": r"\#",
        "_": r"\_",
        "{": r"\{",
        "}": r"\}",
        "~": r"\textasciitilde{}",
        "^": r"\textasciicircum{}",
    }
    for a, b in repl.items():
        s = s.replace(a, b)
    return s


def pick_col(columns, candidates, required: bool, label: str):
    cols = list(columns)
    lower = {str(c).lower(): c for c in cols}
    for cand in candidates:
        if cand in cols:
            return cand
        if cand.lower() in lower:
            return lower[cand.lower()]
    if required:
        raise ValueError(f"Could not find {label}. Tried {candidates}. Columns: {cols}")
    return None


def decode_edge_for_display(edge: str) -> str:
    """
    Best-effort display conversion for AGORA-style encoded metabolite names.

    Example:
        M_FOL__91__C__93__ -> FOL[C]

    This does not try to map abbreviations to biochemical full names. It only
    makes the edge string more readable.
    """
    s = str(edge)
    s = s.replace("__91__", "[")
    s = s.replace("__93__", "]")
    s = s.replace("M_", "")
    s = s.replace("_DASH_", "-")
    return s


def load_edge_annotation(path: Path | None) -> dict[str, dict[str, str]]:
    """
    Optional annotation file.

    Supported formats:
      edge,process
      edge,process,edge_display
      a,b,process
      source,target,process

    Returned mapping:
      key -> {"process": ..., "edge_display": ...}
    """
    if path is None:
        return {}

    df = pd.read_csv(path, low_memory=False)
    process_col = pick_col(df.columns, PROCESS_CANDIDATES, required=True, label="process column")
    edge_col = pick_col(df.columns, EDGE_CANDIDATES, required=False, label="edge column")
    display_col = pick_col(
        df.columns,
        ["edge_display", "display_edge", "edge_name", "reaction_name", "label"],
        required=False,
        label="display edge column",
    )

    if edge_col is None:
        source_col = pick_col(df.columns, SOURCE_CANDIDATES, required=True, label="source column")
        target_col = pick_col(df.columns, TARGET_CANDIDATES, required=True, label="target column")
        edge_series = df[source_col].astype(str) + " -> " + df[target_col].astype(str)
    else:
        edge_series = df[edge_col].astype(str)

    mapping = {}
    for i, edge in enumerate(edge_series):
        proc = str(df.iloc[i][process_col]) if pd.notna(df.iloc[i][process_col]) else "Unannotated"
        disp = str(df.iloc[i][display_col]) if display_col and pd.notna(df.iloc[i][display_col]) else edge
        mapping[edge] = {"process": proc, "edge_display": disp}
        mapping[decode_edge_for_display(edge)] = {"process": proc, "edge_display": disp}

    print(f"[annotation] Loaded {len(mapping):,} annotation keys from {path}", flush=True)
    return mapping


def load_inputs(feature_dir: Path, annotation_csv: Path | None):
    X_path = feature_dir / "feature_matrix_B_K0.npz"
    meta_path = feature_dir / "matched_metadata.csv"
    edge_path = feature_dir / "edge_metadata.csv"

    if not X_path.exists():
        raise FileNotFoundError(f"Missing feature matrix: {X_path}")
    if not meta_path.exists():
        raise FileNotFoundError(f"Missing matched metadata: {meta_path}")
    if not edge_path.exists():
        raise FileNotFoundError(f"Missing edge metadata: {edge_path}")

    X_sparse = load_npz(X_path).tocsr()
    meta = pd.read_csv(meta_path)
    edge_meta = pd.read_csv(edge_path)

    for c in ["sample_id", "participant_id", "cond"]:
        if c not in meta.columns:
            raise ValueError(f"matched_metadata.csv missing required column: {c}")

    if "edge" not in edge_meta.columns:
        raise ValueError("edge_metadata.csv must contain an 'edge' column.")

    if "process" not in edge_meta.columns:
        edge_meta["process"] = "Unannotated"

    meta["sample_id"] = meta["sample_id"].astype(str)
    meta["participant_id"] = meta["participant_id"].astype(str)
    meta["cond"] = meta["cond"].astype(str)

    edge_meta["edge"] = edge_meta["edge"].astype(str)
    edge_meta["process"] = edge_meta["process"].fillna("Unannotated").astype(str)

    if X_sparse.shape[0] != len(meta):
        raise ValueError(
            f"Feature rows ({X_sparse.shape[0]}) do not match metadata rows ({len(meta)})."
        )

    n_edges = len(edge_meta)
    if X_sparse.shape[1] != 2 * n_edges:
        raise ValueError(
            f"Feature columns ({X_sparse.shape[1]}) do not equal 2 * n_edges ({2*n_edges})."
        )

    ann = load_edge_annotation(annotation_csv)

    edge_display = []
    process = []

    for edge, proc0 in zip(edge_meta["edge"], edge_meta["process"]):
        decoded = decode_edge_for_display(edge)
        item = ann.get(edge) or ann.get(decoded)

        if item:
            edge_display.append(item["edge_display"])
            process.append(item["process"])
        else:
            edge_display.append(decoded)
            process.append(proc0 if proc0 else "Unannotated")

    edge_meta["edge_display"] = edge_display
    edge_meta["process"] = process

    feature_meta = pd.DataFrame(
        {
            "feature_index": np.arange(2 * n_edges),
            "feature": (
                [f"B__{e}" for e in edge_meta["edge"].tolist()]
                + [f"K__{e}" for e in edge_meta["edge"].tolist()]
            ),
            "feature_type": ["B"] * n_edges + ["K0"] * n_edges,
            "edge_index": list(range(n_edges)) + list(range(n_edges)),
            "edge": edge_meta["edge"].tolist() + edge_meta["edge"].tolist(),
            "edge_display": edge_meta["edge_display"].tolist() + edge_meta["edge_display"].tolist(),
            "process": edge_meta["process"].tolist() + edge_meta["process"].tolist(),
        }
    )

    return X_sparse, meta, edge_meta, feature_meta


def make_task_data(X_dense: np.ndarray, meta: pd.DataFrame, task_key: str):
    spec = TASKS[task_key]
    rows = []
    y = []

    for i, cond in enumerate(meta["cond"].tolist()):
        if cond in spec["label_map"]:
            rows.append(i)
            y.append(spec["label_map"][cond])

    rows = np.asarray(rows, dtype=int)
    y = np.asarray(y, dtype=int)
    meta_task = meta.iloc[rows].reset_index(drop=True)

    return X_dense[rows], y, meta_task


def make_model(C: float, max_iter: int, tol: float, seed: int, n_jobs: int, verbose: int):
    return Pipeline(
        [
            ("scaler", StandardScaler(with_mean=True, with_std=True)),
            (
                "clf",
                LogisticRegression(
                    penalty="l1",
                    solver="saga",
                    class_weight="balanced",
                    C=float(C),
                    max_iter=int(max_iter),
                    tol=float(tol),
                    random_state=int(seed),
                    n_jobs=int(n_jobs),
                    verbose=int(verbose),
                ),
            ),
        ]
    )


def safe_auc(y_true: np.ndarray, proba: np.ndarray, n_classes: int) -> float:
    try:
        if len(np.unique(y_true)) < 2:
            return np.nan
        if n_classes == 2:
            return float(roc_auc_score(y_true, proba[:, 1]))
        return float(
            roc_auc_score(
                y_true,
                proba,
                labels=list(range(n_classes)),
                multi_class="ovr",
                average="macro",
            )
        )
    except Exception:
        return np.nan


def score_model(y_true: np.ndarray, pred: np.ndarray, proba: np.ndarray, n_classes: int):
    out = {
        "accuracy": float(accuracy_score(y_true, pred)),
        "balanced_accuracy": float(balanced_accuracy_score(y_true, pred)),
        "macro_f1": float(f1_score(y_true, pred, average="macro", zero_division=0)),
        "roc_auc": safe_auc(y_true, proba, n_classes),
    }

    if n_classes == 2:
        out["positive_f1"] = float(f1_score(y_true, pred, pos_label=1, zero_division=0))
    else:
        out["positive_f1"] = np.nan

    return out


def safe_log_loss(y_true: np.ndarray, proba: np.ndarray, n_classes: int) -> float:
    try:
        return float(log_loss(y_true, proba, labels=np.arange(n_classes)))
    except Exception:
        return np.nan


def write_text_report(path: Path, text: str):
    path.write_text(text + "\n")


def run_grouped_cv(X_task, y, meta_task, task_key: str, args, task_dir: Path):
    spec = TASKS[task_key]
    label_order = spec["label_order"]
    n_classes = len(label_order)
    groups = meta_task["participant_id"].to_numpy()

    cv = StratifiedGroupKFold(
        n_splits=args.n_splits,
        shuffle=True,
        random_state=args.seed,
    )

    fold_rows = []
    pred_rows = []
    all_true = []
    all_pred = []

    print(f"\nUsing CV splitter for {spec['display']}: StratifiedGroupKFold", flush=True)

    for fold, (tr, te) in enumerate(cv.split(X_task, y, groups=groups), start=1):
        trg = set(groups[tr])
        teg = set(groups[te])
        overlap = len(trg & teg)

        print(
            f"fold {fold}: train_participants={len(trg)}, "
            f"test_participants={len(teg)}, overlap={overlap}",
            flush=True,
        )

        model = make_model(
            C=args.C,
            max_iter=args.max_iter,
            tol=args.tol,
            seed=args.seed,
            n_jobs=args.n_jobs,
            verbose=args.sklearn_verbose,
        )

        with warnings.catch_warnings(record=True) as caught:
            warnings.simplefilter("always", ConvergenceWarning)
            model.fit(X_task[tr], y[tr])
            conv = any(isinstance(w.message, ConvergenceWarning) for w in caught)

        pred = model.predict(X_task[te])
        proba = model.predict_proba(X_task[te])
        metrics = score_model(y[te], pred, proba, n_classes)

        fold_rows.append(
            {
                "fold": fold,
                "train_samples": int(len(tr)),
                "test_samples": int(len(te)),
                "train_participants": int(len(trg)),
                "test_participants": int(len(teg)),
                "participant_overlap": int(overlap),
                "accuracy": metrics["accuracy"],
                "balanced_accuracy": metrics["balanced_accuracy"],
                "macro_f1": metrics["macro_f1"],
                "positive_f1": metrics["positive_f1"],
                "roc_auc": metrics["roc_auc"],
                "convergence_warning": bool(conv),
            }
        )

        for local_idx, yy, pp, prob in zip(te, y[te], pred, proba):
            row = {
                "fold": fold,
                "sample_id": meta_task.iloc[local_idx]["sample_id"],
                "participant_id": meta_task.iloc[local_idx]["participant_id"],
                "true_label": label_order[int(yy)],
                "pred_label": label_order[int(pp)],
            }
            for ci, cname in enumerate(label_order):
                row[f"proba_{cname}"] = float(prob[ci])
            pred_rows.append(row)

        all_true.extend(y[te].tolist())
        all_pred.extend(pred.tolist())

        print(
            f"  {spec['display']} fold {fold}: "
            f"acc={metrics['accuracy']:.3f}, "
            f"bacc={metrics['balanced_accuracy']:.3f}, "
            f"macro_f1={metrics['macro_f1']:.3f}, "
            f"auc={metrics['roc_auc']:.3f}, "
            f"convergence_warning={conv}",
            flush=True,
        )

    fold_df = pd.DataFrame(fold_rows)
    pred_df = pd.DataFrame(pred_rows)
    cm = confusion_matrix(all_true, all_pred, labels=list(range(n_classes)))
    cm_df = pd.DataFrame(cm, index=label_order, columns=label_order)

    report = classification_report(
        all_true,
        all_pred,
        labels=list(range(n_classes)),
        target_names=label_order,
        zero_division=0,
    )

    fold_df.to_csv(task_dir / "fold_results.csv", index=False)
    pred_df.to_csv(task_dir / "cross_validated_predictions.csv", index=False)
    cm_df.to_csv(task_dir / "aggregated_confusion_matrix.csv")
    write_text_report(task_dir / "classification_report.txt", report)

    write_fold_latex(fold_df, spec, task_dir / "latex_fold_results.tex", args.C)
    write_confusion_latex(cm, label_order, spec["display"], task_dir / "latex_confusion_matrix.tex")

    print("\nTest-set confusion matrix, CV grouped by TRUE participant:")
    print(cm_df.to_string())
    print("\nTest-set classification report, CV grouped by TRUE participant:")
    print(report)

    print(f"\n=== 5-fold CV, original-style L1 logistic on standardised [B|K0], {spec['display']} ===")
    print(f"C                 : {args.C}")
    print(f"accuracy          : {fold_df['accuracy'].mean():.3f} ± {fold_df['accuracy'].std(ddof=0):.3f}")
    print(f"balanced accuracy : {fold_df['balanced_accuracy'].mean():.3f} ± {fold_df['balanced_accuracy'].std(ddof=0):.3f}")
    print(f"macro F1          : {fold_df['macro_f1'].mean():.3f} ± {fold_df['macro_f1'].std(ddof=0):.3f}")
    print(f"ROC-AUC           : {fold_df['roc_auc'].mean():.3f} ± {fold_df['roc_auc'].std(ddof=0):.3f}")

    return fold_df, pred_df, cm


def write_fold_latex(fold_df: pd.DataFrame, spec: dict[str, Any], out_path: Path, C: float):
    lines = [
        r"\begin{table}[ht]",
        r"\centering",
        rf"\caption{{Participant-grouped five-fold performance for the original-style Ricci classifier on {latex_escape(spec['display'])}. The model uses fold-internal standardisation of $[B\mid K_0]$ features and L1 logistic regression with $C={C}$.}}",
        r"\resizebox{\textwidth}{!}{%",
        r"\begin{tabular}{rrrrrrrr}",
        r"\toprule",
        r"Fold & Train & Test & Train participants & Test participants & Accuracy & Balanced acc. & Macro F1 / ROC-AUC \\",
        r"\midrule",
    ]

    for _, r in fold_df.iterrows():
        lines.append(
            f"{int(r['fold'])} & {int(r['train_samples'])} & {int(r['test_samples'])} & "
            f"{int(r['train_participants'])} & {int(r['test_participants'])} & "
            f"{fmt(r['accuracy'])} & {fmt(r['balanced_accuracy'])} & "
            f"{fmt(r['macro_f1'])} / {fmt(r['roc_auc'])} \\\\"
        )

    lines += [
        r"\midrule",
        "Mean & -- & -- & -- & -- & "
        + f"{fmt(fold_df['accuracy'].mean())} & "
        + f"{fmt(fold_df['balanced_accuracy'].mean())} & "
        + f"{fmt(fold_df['macro_f1'].mean())} / {fmt(fold_df['roc_auc'].mean())} \\\\",
        "SD & -- & -- & -- & -- & "
        + f"{fmt(fold_df['accuracy'].std(ddof=0))} & "
        + f"{fmt(fold_df['balanced_accuracy'].std(ddof=0))} & "
        + f"{fmt(fold_df['macro_f1'].std(ddof=0))} / {fmt(fold_df['roc_auc'].std(ddof=0))} \\\\",
        r"\bottomrule",
        r"\end{tabular}%",
        r"}",
        r"\end{table}",
    ]

    out_path.write_text("\n".join(lines) + "\n")


def write_confusion_latex(cm: np.ndarray, label_order: list[str], task_display: str, out_path: Path):
    align = "l" + "r" * len(label_order)
    lines = [
        r"\begin{table}[ht]",
        r"\centering",
        rf"\caption{{Aggregated confusion matrix for the original-style Ricci classifier on {latex_escape(task_display)}. Rows denote true labels and columns denote predicted labels.}}",
        rf"\begin{{tabular}}{{{align}}}",
        r"\toprule",
        " & " + " & ".join(f"Predicted {latex_escape(c)}" for c in label_order) + r" \\",
        r"\midrule",
    ]

    for i, cname in enumerate(label_order):
        lines.append(f"True {latex_escape(cname)} & " + " & ".join(str(int(v)) for v in cm[i]) + r" \\")

    lines += [r"\bottomrule", r"\end{tabular}", r"\end{table}"]
    out_path.write_text("\n".join(lines) + "\n")


def summarise_split(name: str, y: np.ndarray, groups: np.ndarray, label_order: list[str]):
    print(f"\n{name} summary:")
    print(f"  samples      : {len(y)}")
    print(f"  participants : {len(np.unique(groups))}")
    for class_idx, class_name in enumerate(label_order):
        c = int(np.sum(y == class_idx))
        print(f"  {class_name:8s}: {c}")


def evaluate_split(name: str, model: Pipeline, X: np.ndarray, y: np.ndarray, label_order: list[str], out_path: Path):
    n_classes = len(label_order)

    pred = model.predict(X)
    proba = model.predict_proba(X)
    metrics = score_model(y, pred, proba, n_classes)
    ll = safe_log_loss(y, proba, n_classes)

    cm = confusion_matrix(y, pred, labels=list(range(n_classes)))
    report = classification_report(
        y,
        pred,
        labels=list(range(n_classes)),
        target_names=label_order,
        zero_division=0,
    )

    lines = []
    lines.append(f"=== {name.upper()} RESULTS ===")
    lines.append(str(cm))
    lines.append("")
    lines.append(report)
    lines.append(f"{name} log loss: {ll:.4f}" if np.isfinite(ll) else f"{name} log loss: NA")

    if n_classes == 2:
        lines.append(f"{name} ROC-AUC: {metrics['roc_auc']:.4f}" if np.isfinite(metrics["roc_auc"]) else f"{name} ROC-AUC: NA")
    else:
        lines.append(f"{name} ROC-AUC macro OVR: {metrics['roc_auc']:.4f}" if np.isfinite(metrics["roc_auc"]) else f"{name} ROC-AUC macro OVR: NA")

    text = "\n".join(lines)
    print("\n" + text)
    out_path.write_text(text + "\n")

    return {
        "split": name,
        "samples": int(len(y)),
        "participants": None,
        "accuracy": metrics["accuracy"],
        "balanced_accuracy": metrics["balanced_accuracy"],
        "macro_f1": metrics["macro_f1"],
        "positive_f1": metrics["positive_f1"],
        "roc_auc": metrics["roc_auc"],
        "log_loss": ll,
    }


def original_grouped_train_val_test_and_interpret(
    X_task,
    y,
    meta_task,
    feature_meta: pd.DataFrame,
    task_key: str,
    args,
    task_dir: Path,
):
    """
    Reproduce the original run's single participant-grouped train/val/test split
    and final train+val coefficient model.

    This is not the primary performance estimate. The primary estimate is the
    participant-grouped 5-fold CV above.
    """
    spec = TASKS[task_key]
    label_order = spec["label_order"]
    n_classes = len(label_order)
    groups = meta_task["participant_id"].to_numpy()

    gss1 = GroupShuffleSplit(n_splits=1, train_size=args.train_frac, random_state=args.seed)
    train_idx, temp_idx = next(gss1.split(X_task, y, groups=groups))

    X_train, y_train, g_train = X_task[train_idx], y[train_idx], groups[train_idx]
    X_temp, y_temp, g_temp = X_task[temp_idx], y[temp_idx], groups[temp_idx]

    second_train_size = args.val_frac / (args.val_frac + args.test_frac)
    gss2 = GroupShuffleSplit(n_splits=1, train_size=second_train_size, random_state=args.seed)
    val_rel_idx, test_rel_idx = next(gss2.split(X_temp, y_temp, groups=g_temp))

    val_idx = temp_idx[val_rel_idx]
    test_idx = temp_idx[test_rel_idx]

    X_val, y_val, g_val = X_task[val_idx], y[val_idx], groups[val_idx]
    X_test, y_test, g_test = X_task[test_idx], y[test_idx], groups[test_idx]

    train_parts = set(g_train)
    val_parts = set(g_val)
    test_parts = set(g_test)

    print("\nParticipant overlap checks:")
    print(f"  train ∩ val  = {len(train_parts & val_parts)}")
    print(f"  train ∩ test = {len(train_parts & test_parts)}")
    print(f"  val   ∩ test = {len(val_parts & test_parts)}")

    summarise_split("Train", y_train, g_train, label_order)
    summarise_split("Val", y_val, g_val, label_order)
    summarise_split("Test", y_test, g_test, label_order)

    split_df = pd.DataFrame(
        {
            "sample_id": list(meta_task.iloc[train_idx]["sample_id"])
            + list(meta_task.iloc[val_idx]["sample_id"])
            + list(meta_task.iloc[test_idx]["sample_id"]),
            "split": ["train"] * len(train_idx) + ["val"] * len(val_idx) + ["test"] * len(test_idx),
            "participant_id": list(g_train) + list(g_val) + list(g_test),
            "label": [label_order[i] for i in y_train]
            + [label_order[i] for i in y_val]
            + [label_order[i] for i in y_test],
        }
    )
    split_df.to_csv(task_dir / "single_grouped_train_val_test_split.csv", index=False)

    model = make_model(
        C=args.C,
        max_iter=args.max_iter,
        tol=args.tol,
        seed=args.seed,
        n_jobs=args.n_jobs,
        verbose=args.sklearn_verbose,
    )

    model.fit(X_train, y_train)

    rows = []
    for name, Xs, ys, gs in [
        ("train", X_train, y_train, g_train),
        ("val", X_val, y_val, g_val),
        ("test", X_test, y_test, g_test),
    ]:
        row = evaluate_split(
            name,
            model,
            Xs,
            ys,
            label_order,
            task_dir / f"single_split_{name}_report.txt",
        )
        row["participants"] = int(len(set(gs)))
        rows.append(row)

    X_trainval = np.concatenate([X_train, X_val], axis=0)
    y_trainval = np.concatenate([y_train, y_val], axis=0)

    final_model = make_model(
        C=args.C,
        max_iter=args.max_iter,
        tol=args.tol,
        seed=args.seed,
        n_jobs=args.n_jobs,
        verbose=args.sklearn_verbose,
    )

    final_model.fit(X_trainval, y_trainval)

    print("\n=== FINAL MODEL (train+val fit, held-out test evaluation) ===")
    final_row = evaluate_split(
        "final_test",
        final_model,
        X_test,
        y_test,
        label_order,
        task_dir / "final_trainval_test_report.txt",
    )
    final_row["participants"] = int(len(set(g_test)))
    rows.append(final_row)

    pd.DataFrame(rows).to_csv(task_dir / "single_grouped_train_val_test_results.csv", index=False)

    write_interpretation_tables(
        final_model,
        X_trainval,
        y_trainval,
        feature_meta,
        spec,
        task_dir,
        args.top_n,
        args.max_process_rows,
    )


def write_interpretation_tables(
    final_model: Pipeline,
    X_interpret: np.ndarray,
    y_interpret: np.ndarray,
    feature_meta: pd.DataFrame,
    spec: dict[str, Any],
    task_dir: Path,
    top_n: int,
    max_process_rows: int,
):
    scaler = final_model.named_steps["scaler"]
    clf = final_model.named_steps["clf"]

    Xz = scaler.transform(X_interpret)
    coef = clf.coef_.astype(float)

    if coef.shape[0] == 1:
        beta = coef[0]
        avg_push = np.mean(np.abs(Xz * beta.reshape(1, -1)), axis=0)

        coef_df = feature_meta.copy()
        coef_df["class"] = spec["label_order"][1]
        coef_df["beta_standardised"] = beta
        coef_df["average_realised_push"] = avg_push
        selected = coef_df[np.abs(coef_df["beta_standardised"]) > 1e-12].copy()
        selected = selected.sort_values("beta_standardised", key=lambda s: s.abs(), ascending=False)

        print(f"\nNonzero coefficients: {len(selected)} / {coef.shape[1]}")
        selected.to_csv(task_dir / "selected_coefficients_final_trainval_model.csv", index=False)

        write_binary_top_feature_tables(selected, spec, task_dir, top_n)
        write_binary_process_tables(selected, spec, task_dir, max_process_rows)

    else:
        rows = []
        for ci, cname in enumerate(spec["label_order"]):
            beta = coef[ci]
            avg_push = np.mean(np.abs(Xz * beta.reshape(1, -1)), axis=0)

            temp = feature_meta.copy()
            temp["class"] = cname
            temp["class_index"] = ci
            temp["beta_standardised"] = beta
            temp["average_realised_push"] = avg_push
            temp = temp[np.abs(temp["beta_standardised"]) > 1e-12].copy()
            rows.append(temp)

        selected = pd.concat(rows, axis=0, ignore_index=True) if rows else pd.DataFrame()
        selected = selected.sort_values("beta_standardised", key=lambda s: s.abs(), ascending=False)

        print(f"\nNonzero coefficients: {len(selected)} / {coef.shape[0] * coef.shape[1]}")
        selected.to_csv(task_dir / "selected_coefficients_final_trainval_model.csv", index=False)

        write_multiclass_top_feature_tables(selected, spec, task_dir, top_n)
        write_multiclass_process_tables(selected, spec, task_dir, max_process_rows)


