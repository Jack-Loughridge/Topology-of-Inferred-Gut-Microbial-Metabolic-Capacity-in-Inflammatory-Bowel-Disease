#!/usr/bin/env python3
from pathlib import Path
import pandas as pd
import numpy as np
import re

BASE = Path.home() / "Real_Data"
RS = BASE / "Ricci_Summary"
OVER = BASE / "overleaf_paste_ready_corrected_results_no_blanks"

HOP_SAMPLE = RS / "shortest_path_hop_active_sample_level.csv"
MINIMAX_SAMPLE = RS / "shortest_path_minimax_active_sample_level.csv"

FINAL_TEX = OVER / "paste_ready_corrected_results_no_blanks_WITH_VALID_PATHS.tex"
OUT_TEX = OVER / "paste_ready_corrected_results_no_blanks_WITH_VALID_PATHS_NO_PREPOOLED_PATHS.tex"

HOP_OUT_CSV = RS / "shortest_path_hop_active_posthoc_participant_average_summary.csv"
MINIMAX_OUT_CSV = RS / "shortest_path_minimax_active_posthoc_participant_average_summary.csv"
PATH_BLOCK_OUT = OVER / "corrected_shortest_path_tables_no_prepooled_graphs.tex"


def norm_cond(x):
    s = str(x).strip().lower()
    if "crohn" in s or s == "cd":
        return "cd"
    if "ulcerative" in s or s == "uc":
        return "uc"
    if "non" in s:
        return "nonibd"
    return s


def fmt_cond(c):
    return {"cd": "CD", "uc": "UC", "nonibd": "non-IBD"}.get(c, c)


def mean_sd(sub, col):
    vals = pd.to_numeric(sub[col], errors="coerce").replace([np.inf, -np.inf], np.nan).dropna()
    if len(vals) == 0:
        return "--"
    if len(vals) == 1:
        return f"{vals.iloc[0]:.3f}"
    return f"{vals.mean():.3f} $\\pm$ {vals.std(ddof=0):.3f}"


def participant_posthoc(df, metric_cols):
    df = df.copy()
    df["cond"] = df["cond"].map(norm_cond)

    agg = {
        "cond": lambda x: x.value_counts().idxmax(),
        "sample_id": "count",
    }
    for c in metric_cols:
        agg[c] = "mean"

    part = (
        df.groupby("participant_id", as_index=False)
          .agg(agg)
          .rename(columns={"sample_id": "n_samples_for_participant"})
    )
    return part


def summarise_hop():
    df = pd.read_csv(HOP_SAMPLE)
    needed = [
        "sample_id", "participant_id", "cond",
        "mean_shortest_path_length",
        "mean_squared_weight_on_paths",
        "reachable_fraction_over_sampled_sources",
    ]
    missing = [c for c in needed if c not in df.columns]
    if missing:
        raise RuntimeError(f"Hop sample CSV missing columns: {missing}")

    df["cond"] = df["cond"].map(norm_cond)
    if len(df) < 1000 or df["participant_id"].nunique() < 100:
        raise RuntimeError("Hop sample CSV looks incomplete.")

    metric_cols = [
        "mean_shortest_path_length",
        "mean_squared_weight_on_paths",
        "reachable_fraction_over_sampled_sources",
    ]
    part = participant_posthoc(df, metric_cols)

    rows = []
    for level, subdf in [("sample graphwise", df), ("participant average", part)]:
        for cond in ["overall", "cd", "uc", "nonibd"]:
            sub = subdf if cond == "overall" else subdf[subdf["cond"] == cond]
            rows.append({
                "level": level,
                "cond": cond,
                "n": int(len(sub)),
                "path_length": mean_sd(sub, "mean_shortest_path_length"),
                "mean_w2": mean_sd(sub, "mean_squared_weight_on_paths"),
                "reachable_fraction": mean_sd(sub, "reachable_fraction_over_sampled_sources"),
            })

    out = pd.DataFrame(rows)
    out.to_csv(HOP_OUT_CSV, index=False)
    return out


