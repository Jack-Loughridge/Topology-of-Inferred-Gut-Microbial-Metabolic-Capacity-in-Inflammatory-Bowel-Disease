def latex_hop_table(df):
    lines = []
    lines.append(r"\subsubsection*{Directed shortest-path diagnostics: minimum-hop}")
    lines.append(r"\begin{table}[ht]")
    lines.append(r"\centering")
    lines.append(r"\caption{Directed minimum-hop path diagnostics on active metabolic graphs. Sample-level rows are computed on individual sample graphs. Participant-average rows are obtained by first averaging sample-level path diagnostics within participant, and then reporting mean $\pm$ SD across participants by condition.}")
    lines.append(r"\label{tab:directed_minimum_hop_paths_participant_average}")
    lines.append(r"\resizebox{\textwidth}{!}{%")
    lines.append(r"\begin{tabular}{llrrrr}")
    lines.append(r"\toprule")
    lines.append(r"Level & Condition & $n$ & Path length & Mean $w^2$ on path & Reachable fraction \\")
    lines.append(r"\midrule")
    for _, r in df.iterrows():
        lines.append(
            f"{r['level']} & {fmt_cond(r['cond'])} & {int(r['n'])} & "
            f"{r['path_length']} & {r['mean_w2']} & {r['reachable_fraction']} \\\\"
        )
    lines.append(r"\bottomrule")
    lines.append(r"\end{tabular}%")
    lines.append(r"}")
    lines.append(r"\end{table}")
    return "\n".join(lines)


def latex_minimax_table(df):
    lines = []
    lines.append(r"\subsubsection*{Directed shortest-path diagnostics: minimax}")
    lines.append(r"\begin{table}[ht]")
    lines.append(r"\centering")
    lines.append(r"\caption{Directed minimax path diagnostics on active metabolic graphs. Paths minimise the maximum edge weight along the path, with shortest-path tie-breaking. Sample-level rows are computed on individual sample graphs. Participant-average rows are obtained by first averaging sample-level path diagnostics within participant, and then reporting mean $\pm$ SD across participants by condition.}")
    lines.append(r"\label{tab:directed_minimax_paths_participant_average}")
    lines.append(r"\resizebox{\textwidth}{!}{%")
    lines.append(r"\begin{tabular}{llrrrrr}")
    lines.append(r"\toprule")
    lines.append(r"Level & Condition & $n$ & Path length & Mean $w^2$ & Bottleneck weight & Reachable fraction \\")
    lines.append(r"\midrule")
    for _, r in df.iterrows():
        lines.append(
            f"{r['level']} & {fmt_cond(r['cond'])} & {int(r['n'])} & "
            f"{r['path_length']} & {r['mean_w2']} & {r['bottleneck']} & {r['reachable_fraction']} \\\\"
        )
    lines.append(r"\bottomrule")
    lines.append(r"\end{tabular}%")
    lines.append(r"}")
    lines.append(r"\end{table}")
    return "\n".join(lines)


def main():
    hop = summarise_hop()
    minimax = summarise_minimax()

    block = latex_hop_table(hop) + "\n\n" + latex_minimax_table(minimax) + "\n"
    PATH_BLOCK_OUT.write_text(block)

    print("Corrected hop summary:")
    print(hop.to_string(index=False))
    print("\nCorrected minimax summary:")
    print(minimax.to_string(index=False))

    print("\nWrote:")
    print(" ", HOP_OUT_CSV)
    print(" ", MINIMAX_OUT_CSV)
    print(" ", PATH_BLOCK_OUT)

    if FINAL_TEX.exists():
        tex = FINAL_TEX.read_text()
        start = tex.find(r"\subsubsection*{Directed shortest-path diagnostics: minimum-hop}")
        end = tex.find(r"\subsubsection*{Directed clustering diagnostics}")

        if start == -1 or end == -1 or end <= start:
            raise RuntimeError("Could not locate shortest-path block boundaries in final TeX.")

        new_tex = tex[:start] + block + "\n" + tex[end:]
        bad_patterns = ["participant-mean active graph", "finite full-dataset shortest-path CSV outputs", "smoke-test", "broken LaTeX wrappers"]
        for pat in bad_patterns:
            if pat in new_tex:
                raise RuntimeError(f"Bad audit/method phrase still present in TeX: {pat}")

        if re.search(r"\bnan\b", new_tex, flags=re.IGNORECASE):
            raise RuntimeError("Final TeX still contains nan.")

        OUT_TEX.write_text(new_tex)
        print("\nUpdated final TeX:")
        print(" ", OUT_TEX)

    print("\n[READY] Shortest-path tables now use sample-level diagnostics averaged post hoc within participant.")
    print("Use this TeX file:")
    print(" ", OUT_TEX)


if __name__ == "__main__":
    main()
